<?php

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\FieldableEntityInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;

/**
 * Implements hook_entity_access().
 */
function mukurtu_drafts_entity_access(EntityInterface $entity, $operation, AccountInterface $account)
{
  if (!$entity instanceof FieldableEntityInterface || !$entity->hasField('moderation_state')) {
    return AccessResult::neutral();
  }

  $state = $entity->get('moderation_state')->value;
  if ($state !== 'draft') {
    return AccessResult::neutral()->addCacheableDependency($entity);
  }

  // Privileged users bypass draft visibility restrictions.
  if ($account->hasPermission('bypass node access') || $account->hasPermission('administer nodes')) {
    return AccessResult::neutral()
      ->addCacheableDependency($entity)
      ->cachePerPermissions();
  }

  if (method_exists($entity, 'getOwnerId') && $account->id() == $entity->getOwnerId()) {
    return AccessResult::allowed()
      ->addCacheableDependency($entity)
      ->addCacheContexts(['user']);
  }

  // Non-owners are blocked from viewing drafts; edit and delete are governed
  // by workflow transition permissions.
  if ($operation === 'view') {
    return AccessResult::forbidden()
      ->addCacheableDependency($entity)
      ->addCacheContexts(['user']);
  }

  return AccessResult::neutral()
    ->addCacheableDependency($entity)
    ->addCacheContexts(['user']);
}

/**
 * Implements hook_menu_local_tasks_alter().
 */
function mukurtu_drafts_menu_local_tasks_alter(array &$data, string $route_name): void {
  // Remove the "Latest version" tab added by content_moderation when a node
  // has a pending draft revision. Draft state is surfaced via the banner and
  // /user/drafts instead.
  foreach ($data['tabs'] as $level => $tabs) {
    unset($data['tabs'][$level]['node.latest_version_tab']);
  }
}

/**
 * Implements hook_entity_view().
 */
function mukurtu_drafts_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if (!$entity instanceof FieldableEntityInterface || !$entity->hasField('moderation_state')) {
    return;
  }
  if ($entity->get('moderation_state')->value !== 'draft') {
    return;
  }
  // Inject a real DOM element so assistive technology announces the draft state.
  // CSS ::before content is unreliable in screen readers.
  $build['title_prefix']['draft_banner'] = [
    '#type' => 'html_tag',
    '#tag' => 'span',
    '#value' => t('Draft'),
    '#attributes' => ['class' => ['node--draft-banner']],
    '#weight' => -100,
  ];
}

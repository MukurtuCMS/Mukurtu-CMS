<?php

use Drupal\mukurtu_browse\Plugin\views\argument\MukurtuBoundingBox;
use Drupal\node\NodeInterface;
use Drupal\node\NodeTypeInterface;
use Drupal\search_api\Plugin\views\query\SearchApiQuery;

/**
 * Implements hook_theme().
 */
function mukurtu_browse_theme($existing, $type, $theme, $path) {
  return [
    'mukurtu_browse' => [
      'variables' => [
        'is_dh' => NULL,
        'list_results' => NULL,
        'grid_results' => NULL,
        'map_results' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_ajax_render_alter().
 */
function mukurtu_browse_ajax_render_alter(array &$data) {
  // On the map browse, remove the viewsScrollTop command so
  // we don't scroll on refresh.
  $view_name = 'mukurtu_browse_by_map';
  $view_display_id = 'map_block';

  if (isset($data[0]['settings']['views']['ajaxViews'])) {
    $view = reset($data[0]['settings']['views']['ajaxViews']);

    if ($view['view_name'] == $view_name && $view['view_display_id'] == $view_display_id) {
      $selector = '.js-view-dom-id-' . $view['view_dom_id'];
      foreach ($data as $key => $value) {
        if ($value['command'] === 'viewsScrollTop' && $value['selector'] === $selector) {
          unset ($data[$key]);
          break;
        }
      }
    }
  }

}

/**
 * Implements hook_views_data_alter().
 */
function mukurtu_browse_views_data_alter(array &$data) {
  if (isset($data['search_api_index_mukurtu_default_content_index'])) {
    $data['search_api_index_mukurtu_default_content_index']['mukurtu_bounding_box'] = [
      'title' => t('Mukurtu Bounding Box'),
      'argument' => [
        'title' => t('Mukurtu Bounding Box'),
        'help' => t('Bounding box query for Leaflet maps.'),
        'field' => 'field_coverage',
        'id' => 'mukurtu_bounding_box',
      ],
    ];
  }
}


/**
 * Implements hook_views_plugins_argument_alter().
 */
function mukurtu_browse_views_plugins_argument_alter(array &$plugins) {
  $plugins['mukurtu_bounding_box'] = [
    'plugin_type' => 'argument',
    'id' => 'mukurtu_bounding_box',
    'class' => MukurtuBoundingBox::class,
    'provider' => 'mukurtu_browse',
  ];
}

/**
 * Implements hook_preprocess_node().
 */
function mukurtu_browse_preprocess_node(&$variables) {
  // Only apply to browse view mode.
  if ($variables['view_mode'] !== 'browse') {
    return;
  }
  $node = $variables['node'];
  if (!$node instanceof NodeInterface) {
    return;
  }
  $node_type = $node->type->entity;
  if (!$node_type instanceof NodeTypeInterface) {
    return;
  }
  $variables['content_type_label'] = $node_type->label();
}

/**
 * Implements hook_views_query_alter().
 *
 * Applies collapse filters for multipage item pages and community records
 * when the corresponding admin setting is enabled. The site-wide default can
 * be overridden per-request with the URL parameters mpi_collapse and
 * cr_collapse (1 = collapse, 0 = expand).
 */
function mukurtu_browse_views_query_alter($view, $query) {
  if (!$query instanceof SearchApiQuery) {
    return;
  }

  $config = \Drupal::config('mukurtu_search.settings');
  $req = \Drupal::request()->query;

  $collapse_mpi = $req->has('mpi_collapse')
    ? (bool) $req->get('mpi_collapse')
    : (bool) ($config->get('collapse_multipage_pages') ?? FALSE);

  $collapse_cr = $req->has('cr_collapse')
    ? (bool) $req->get('cr_collapse')
    : (bool) ($config->get('collapse_community_records') ?? FALSE);

  if (!$collapse_mpi && !$collapse_cr) {
    return;
  }

  $api_query = $query->getSearchApiQuery();
  $index_fields = $api_query->getIndex()->getFields();

  if ($collapse_mpi && isset($index_fields['is_additional_mpi_page'])) {
    $api_query->addCondition('is_additional_mpi_page', FALSE);
  }

  if ($collapse_cr && isset($index_fields['is_community_record'])) {
    $api_query->addCondition('is_community_record', FALSE);
  }
}

/**
 * Implements hook_multipage_item_insert().
 */
function mukurtu_browse_multipage_item_insert($entity) {
  _mukurtu_browse_reindex_mpi_pages($entity);
}

/**
 * Implements hook_multipage_item_update().
 */
function mukurtu_browse_multipage_item_update($entity) {
  _mukurtu_browse_reindex_mpi_pages($entity, $entity->original ?? NULL);
}

/**
 * Implements hook_multipage_item_delete().
 */
function mukurtu_browse_multipage_item_delete($entity) {
  _mukurtu_browse_reindex_mpi_pages($entity);
}

/**
 * Marks all pages of an MPI for reindexing in Search API.
 *
 * When a multipage_item entity is saved with pre-existing nodes as pages, those
 * nodes won't be automatically reindexed because they haven't changed. This
 * ensures the is_additional_mpi_page processor field stays accurate.
 */
function _mukurtu_browse_reindex_mpi_pages($entity, $original = NULL) {
  if (!$entity->hasField('field_pages')) {
    return;
  }

  $node_ids = [];
  foreach ($entity->field_pages as $item) {
    if ($item->target_id) {
      $node_ids[] = $item->target_id;
    }
  }

  // Include any pages that were removed so they also get reindexed.
  if ($original && $original->hasField('field_pages')) {
    foreach ($original->field_pages as $item) {
      if ($item->target_id) {
        $node_ids[] = $item->target_id;
      }
    }
  }

  $node_ids = array_unique($node_ids);
  if (empty($node_ids)) {
    return;
  }

  $index = \Drupal\search_api\Entity\Index::load('mukurtu_default_content_index');
  if (!$index || !$index->status()) {
    return;
  }

  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $item_ids = [];
  foreach ($node_ids as $node_id) {
    $node = $node_storage->load($node_id);
    if ($node) {
      foreach ($node->getTranslationLanguages() as $langcode => $language) {
        $item_ids[] = $node_id . ':' . $langcode;
      }
    }
  }

  if (!empty($item_ids)) {
    $index->trackItemsUpdated('entity:node', $item_ids);
  }
}

/**
 * Implements hook_preprocess_block().
 */
function mukurtu_browse_preprocess_block(&$variables) {
  if (!isset($variables['plugin_id']) || !in_array($variables['plugin_id'], ['views_exposed_filter_block:mukurtu_browse-mukurtu_browse_block', 'views_exposed_filter_block:mukurtu_digital_heritage_browse-mukurtu_digital_heritage_browse_block'])) {
    return;
  }
  if (isset($variables['content']['search_api_fulltext'])) {
    $variables['content']['search_api_fulltext']['#weight'] = -10.9;
  }
  if (isset($variables['content']['sort_by'])) {
    $variables['content']['sort_by']['#weight'] = -10.8;
  }
}

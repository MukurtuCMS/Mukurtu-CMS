 * (added to protocol, removed from protocol, removed from community) using
 * the same mukurtu-notification-link token, now extended to the protocol
 * and community entity types. The affected user's name in these templates
 * stays plain text -- per product decision, these are informational rather
 * than account-management notifications.
 */
function mukurtu_notifications_update_40042(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);

  );
}

/**
 * Replace three Phase 2 template names that exceeded the 32-character limit.
 *
 * Hook 40019 deployed these configs with names that are too long for Drupal
 * bundle IDs (EntityBase enforces a 32-character maximum). This hook deletes
 * the oversized configs and redeploys them under corrected short names:
 *   mukurtu_comment_on_protocol_content  -> mukurtu_protocol_comment
 *   mukurtu_content_submitted_for_review -> mukurtu_content_for_review
 *   mukurtu_content_returned_to_draft    -> mukurtu_content_to_draft
 */
function mukurtu_notifications_update_40021(): void {
  $config_factory = \Drupal::configFactory();
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  // Delete all configs that used the old oversized names.
  $old_names = [
    'message.template.mukurtu_comment_on_protocol_content',
    'message.template.mukurtu_content_submitted_for_review',
    'message.template.mukurtu_content_returned_to_draft',
    'core.entity_view_display.message.mukurtu_comment_on_protocol_content.mail_body',
    'core.entity_view_display.message.mukurtu_comment_on_protocol_content.mail_subject',
    'core.entity_view_display.message.mukurtu_content_submitted_for_review.mail_body',
    'core.entity_view_display.message.mukurtu_content_submitted_for_review.mail_subject',
    'core.entity_view_display.message.mukurtu_content_returned_to_draft.mail_body',
    'core.entity_view_display.message.mukurtu_content_returned_to_draft.mail_subject',
    'field.field.message.mukurtu_comment_on_protocol_content.field_item',
    'field.field.message.mukurtu_comment_on_protocol_content.field_user',
    'field.field.message.mukurtu_content_submitted_for_review.field_item',
    'field.field.message.mukurtu_content_submitted_for_review.field_user',
    'field.field.message.mukurtu_content_returned_to_draft.field_item',
    'field.field.message.mukurtu_content_returned_to_draft.field_user',
  ];
  foreach ($old_names as $name) {
    $config_factory->getEditable($name)->delete();
  }

  // Write the corrected configs (already in config/install with short names).
  $new_names = [
    'message.template.mukurtu_protocol_comment',
    'message.template.mukurtu_content_for_review',
    'message.template.mukurtu_content_to_draft',
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_body',
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_subject',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_body',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_subject',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_body',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_subject',
    'field.field.message.mukurtu_protocol_comment.field_item',
    'field.field.message.mukurtu_protocol_comment.field_user',
    'field.field.message.mukurtu_content_for_review.field_item',
    'field.field.message.mukurtu_content_for_review.field_user',
    'field.field.message.mukurtu_content_to_draft.field_item',
    'field.field.message.mukurtu_content_to_draft.field_user',
  ];
  foreach ($new_names as $name) {
    $config_storage->write($name, $source->read($name));
  }

  // Redeploy the view so the filter value list reflects the new template names.
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}


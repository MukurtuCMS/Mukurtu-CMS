/**
 * Deploy extended Phase 1 notification templates, mail displays, and fields.
 *
 * The original Phase 1 scope (node CRUD, user registration, collections) was
 * extended during development to include seven additional templates: comment
 * on protocol content, four editorial workflow transitions (needs_review,
 * published, archived, draft), and two group membership notifications. These
 * are deployed here rather than deferred to Phase 2 because the corresponding
 * hooks (hook_comment_insert, hook_og_membership_insert,
 * mukurtu_notifications_handle_moderation_change) are already active in this
 * branch. mail_body / mail_subject view displays and field attachments are
 * included. field_community_ref and field_protocol bundle attachments are
 * created via the Field API so the DB schema is handled correctly.
 */
function mukurtu_notifications_update_40018(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  $configs = [
    // Message templates.
    'message.template.mukurtu_protocol_comment',
    'message.template.mukurtu_content_for_review',
    'message.template.mukurtu_content_published',
    'message.template.mukurtu_content_archived',
    'message.template.mukurtu_content_to_draft',
    'message.template.mukurtu_user_added_to_community',
    'message.template.mukurtu_user_added_to_protocol',
    // Mail body view displays.
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_body',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_body',
    'core.entity_view_display.message.mukurtu_content_published.mail_body',
    'core.entity_view_display.message.mukurtu_content_archived.mail_body',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_body',
    'core.entity_view_display.message.mukurtu_user_added_to_community.mail_body',
    'core.entity_view_display.message.mukurtu_user_added_to_protocol.mail_body',
    // Mail subject view displays.
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_subject',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_subject',
    'core.entity_view_display.message.mukurtu_content_published.mail_subject',
    'core.entity_view_display.message.mukurtu_content_archived.mail_subject',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_subject',
    'core.entity_view_display.message.mukurtu_user_added_to_community.mail_subject',
    'core.entity_view_display.message.mukurtu_user_added_to_protocol.mail_subject',
    // Field attachments (field_item).
    'field.field.message.mukurtu_protocol_comment.field_item',
    'field.field.message.mukurtu_content_for_review.field_item',
    'field.field.message.mukurtu_content_published.field_item',
    'field.field.message.mukurtu_content_archived.field_item',
    'field.field.message.mukurtu_content_to_draft.field_item',
    // Field attachments (field_user).
    'field.field.message.mukurtu_protocol_comment.field_user',
    'field.field.message.mukurtu_content_for_review.field_user',
    'field.field.message.mukurtu_content_published.field_user',
    'field.field.message.mukurtu_content_archived.field_user',
    'field.field.message.mukurtu_content_to_draft.field_user',
    'field.field.message.mukurtu_user_added_to_community.field_user',
    'field.field.message.mukurtu_user_added_to_protocol.field_user',
  ];

  foreach ($configs as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }

  // field_community_ref and the field_protocol/mukurtu_user_added_to_protocol
  // attachment must be created via Field API so DB schema is handled correctly.
  mukurtu_notifications_create_field_community_ref();
  mukurtu_notifications_create_field_protocol();
}

/**
 * Rename message template labels to user-friendly names for the filter UI,
 * and redeploy the notifications view with an exposed notification type filter.
 */
function mukurtu_notifications_update_40019(): void {
  $label_map = [
    'message.template.mukurtu_single_node_insert' => 'Content created',
    'message.template.mukurtu_single_node_update' => 'Content updated',
    'message.template.mukurtu_single_node_delete' => 'Content deleted',
    'message.template.mukurtu_new_item_in_protocol' => 'New item in protocol',
    'message.template.mukurtu_new_item_in_community' => 'New item in community',
    'message.template.mukurtu_new_item_in_collection' => 'New item in collection',
    'message.template.mukurtu_new_user_registration' => 'New user registration',
    'message.template.mukurtu_new_user_account_created' => 'New user account created',
    'message.template.mukurtu_batch_import_report' => 'Batch import report',
    // Phase 2 templates deployed with corrected short names by hook 40020.
    'message.template.mukurtu_protocol_comment' => 'Comment on protocol content',
    'message.template.mukurtu_content_for_review' => 'Content submitted for review',
    'message.template.mukurtu_content_to_draft' => 'Content returned to draft',
  ];

  $config_factory = \Drupal::configFactory();
  foreach ($label_map as $config_name => $new_label) {
    $config = $config_factory->getEditable($config_name);
    if (!$config->isNew()) {
      $config->set('label', $new_label)->save();
    }
  }

  // Redeploy the view with the exposed notification type filter.
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );
}

/**
 * Replace three Phase 2 template names that exceeded the 32-character limit.
 *
 * Hook 40018 deployed these configs with names that are too long for Drupal
 * bundle IDs (EntityBase enforces a 32-character maximum). This hook deletes
 * the oversized configs and redeploys them under corrected short names:
 *   mukurtu_comment_on_protocol_content  -> mukurtu_protocol_comment
 *   mukurtu_content_submitted_for_review -> mukurtu_content_for_review
 *   mukurtu_content_returned_to_draft    -> mukurtu_content_to_draft
 */
function mukurtu_notifications_update_40020(): void {
  $config_factory = \Drupal::configFactory();
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  // Delete all configs that used the old oversized names.
  $old_names = [
    'message.template.mukurtu_comment_on_protocol_content',
    'message.template.mukurtu_content_submitted_for_review',
    'message.template.mukurtu_content_returned_to_draft',
    'core.entity_view_display.message.mukurtu_comment_on_protocol_content.mail_body',
    'core.entity_view_display.message.mukurtu_comment_on_protocol_content.mail_subject',
    'core.entity_view_display.message.mukurtu_content_submitted_for_review.mail_body',
    'core.entity_view_display.message.mukurtu_content_submitted_for_review.mail_subject',
    'core.entity_view_display.message.mukurtu_content_returned_to_draft.mail_body',
    'core.entity_view_display.message.mukurtu_content_returned_to_draft.mail_subject',
    'field.field.message.mukurtu_comment_on_protocol_content.field_item',
    'field.field.message.mukurtu_comment_on_protocol_content.field_user',
    'field.field.message.mukurtu_content_submitted_for_review.field_item',
    'field.field.message.mukurtu_content_submitted_for_review.field_user',
    'field.field.message.mukurtu_content_returned_to_draft.field_item',
    'field.field.message.mukurtu_content_returned_to_draft.field_user',
  ];
  foreach ($old_names as $name) {
    $config_factory->getEditable($name)->delete();
  }

  // Write the corrected configs (already in config/install with short names).
  $new_names = [
    'message.template.mukurtu_protocol_comment',
    'message.template.mukurtu_content_for_review',
    'message.template.mukurtu_content_to_draft',
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_body',
    'core.entity_view_display.message.mukurtu_protocol_comment.mail_subject',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_body',
    'core.entity_view_display.message.mukurtu_content_for_review.mail_subject',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_body',
    'core.entity_view_display.message.mukurtu_content_to_draft.mail_subject',
    'field.field.message.mukurtu_protocol_comment.field_item',
    'field.field.message.mukurtu_protocol_comment.field_user',
    'field.field.message.mukurtu_content_for_review.field_item',
    'field.field.message.mukurtu_content_for_review.field_user',
    'field.field.message.mukurtu_content_to_draft.field_item',
    'field.field.message.mukurtu_content_to_draft.field_user',
  ];
  foreach ($new_names as $name) {
    $config_storage->write($name, $source->read($name));
  }

  // Redeploy the view so the filter value list reflects the new template names.
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}

/**
 * Fix notification feed display issues.
 *
 * Supersedes view redeployments in 40005, 40009, 40013, 40014, 40015, 40016,
 * 40017, 40019. This is the authoritative final view config for this branch.
 *
 * - Redeploy membership templates with corrected text: username instead of
 *   "You", entity:label instead of entity:title for community/protocol names.
 * - Redeploy the view with delta:0 on get_text (stop doubling), reduce:false
 *   on the type filter (always show all options), and the new Notification
 *   type column.
 */
function mukurtu_notifications_update_40021(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'message.template.mukurtu_user_added_to_community',
    'message.template.mukurtu_user_added_to_protocol',
    'views.view.mukurtu_message_log',
  ] as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }
}

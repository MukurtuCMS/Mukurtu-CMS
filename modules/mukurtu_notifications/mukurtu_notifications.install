/**
 * Fully removes the community/protocol follow buttons.
 *
 * Two independent leaks had to be closed, on top of update_40029/40030:
 * - flag.flagTypeConfig.show_in_links is a second, independent rendering
 *   mechanism that shows the flag link directly in the entity's "links"
 *   area regardless of view display field visibility.
 * - update_40029 removed the flag_mukurtu_follow_* and flag_mukurtu_email_*
 *   pseudo-fields from the community/protocol view displays' `content`
 *   section, but never added them to `hidden`. Drupal defaults any
 *   undeclared extra field to visible, so the buttons kept reappearing.
 *   Every community/protocol view mode is now covered, not just the
 *   canonical one.
 */
function mukurtu_notifications_update_40032(): void {
  $notifications_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $protocol_path = \Drupal::service('extension.list.module')->getPath('mukurtu_protocol') . '/config/install';
  $notifications_source = new FileStorage($notifications_path);
  $protocol_source = new FileStorage($protocol_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'flag.flag.mukurtu_follow_content',
    'flag.flag.mukurtu_follow_collection',
  ] as $config_name) {
    $config_storage->write($config_name, $notifications_source->read($config_name));
  }
  mukurtu_notifications_create_flag_follow_community();
  mukurtu_notifications_create_flag_follow_protocol();

  foreach ([
    'core.entity_view_display.community.community.full',
    'core.entity_view_display.community.community.default',
    'core.entity_view_display.community.community.browse',
    'core.entity_view_display.protocol.protocol.default',
  ] as $config_name) {
    $config_storage->write($config_name, $protocol_source->read($config_name));
  }
}

/**
 * Deploys the 9 new notification templates (user deleted/approved/set
 * pending/blocked/unblocked, removed from community/protocol, comment
 * approved/denied) and their mail_subject/mail_body displays, and attaches
 * field_protocol/field_community_ref to the two new "removed from" bundles.
 */
function mukurtu_notifications_update_40033(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  $templates = [
    'mukurtu_user_deleted',
    'mukurtu_user_approved',
    'mukurtu_user_set_pending',
    'mukurtu_user_blocked',
    'mukurtu_user_unblocked',
    'mukurtu_removed_from_community',
    'mukurtu_removed_from_protocol',
    'mukurtu_comment_approved',
    'mukurtu_comment_denied',
  ];

  $configs = [];
  foreach ($templates as $template) {
    $configs[] = 'message.template.' . $template;
    $configs[] = 'core.entity_view_display.message.' . $template . '.mail_subject';
    $configs[] = 'core.entity_view_display.message.' . $template . '.mail_body';
  }

  // field_user attachments (all but mukurtu_user_deleted, which uses
  // field_title instead since the user entity is gone by view time).
  foreach (array_diff($templates, ['mukurtu_user_deleted']) as $template) {
    $configs[] = 'field.field.message.' . $template . '.field_user';
  }

  // field_item attachments for the two comment templates.
  $configs[] = 'field.field.message.mukurtu_comment_approved.field_item';
  $configs[] = 'field.field.message.mukurtu_comment_denied.field_item';

  // field_title for mukurtu_user_deleted.
  $configs[] = 'field.field.message.mukurtu_user_deleted.field_title';

  // field_number_imported attachment for the batch import report, wired up
  // for the first time in this release.
  $configs[] = 'field.field.message.mukurtu_batch_import_report.field_number_imported';

  foreach ($configs as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }

  // field_protocol/field_community_ref on the two new "removed from"
  // bundles (idempotent -- these helpers skip bundles that already exist).
  mukurtu_notifications_create_field_protocol();
  mukurtu_notifications_create_field_community_ref();
}

/**
 * Migrates existing users' field_notify_email_categories selections from
 * the old category taxonomy to the new one (User account, Memberships,
 * Comments, Publishing, Content, Roundtrip).
 *
 * Unlike mukurtu_notifications_create_field_notify_email_categories()'s
 * backfill (which resets everyone to "all categories on" -- appropriate
 * only the first time the field is created), this preserves each user's
 * existing opt-out choices by remapping old selections to their closest
 * new-category equivalent. 'deleted_content' has no replacement since it
 * never gated any email delivery.
 */
function mukurtu_notifications_update_40034(): void {
  $map = [
    'group_membership' => ['memberships'],
    'comment' => ['comments'],
    'publishing' => ['publishing'],
    'new_content' => ['content'],
    'updated_content' => ['publishing'],
    'deleted_content' => [],
    'administration' => ['user_account', 'roundtrip'],
  ];

  $uids = \Drupal::entityQuery('user')->accessCheck(FALSE)->execute();
  foreach (\Drupal\user\Entity\User::loadMultiple($uids) as $user) {
    if (!$user->hasField('field_notify_email_categories')) {
      continue;
    }
    $old_values = array_column($user->get('field_notify_email_categories')->getValue(), 'value');
    $new_values = [];
    foreach ($old_values as $old_key) {
      foreach ($map[$old_key] ?? [] as $new_key) {
        $new_values[] = $new_key;
      }
    }
    $user->set('field_notify_email_categories', array_values(array_unique($new_values)));
    $user->save();
  }
}

/**
 * Fixes community/protocol name tokens across 6 message templates.
 *
 * [message:field_community_ref:entity:label] and
 * [message:field_protocol:entity:label]/:title never resolved -- 'label'
 * and 'title' aren't real fields on the community/protocol entities (their
 * entity_keys.label is 'name'), and token exposure for these custom entity
 * types only covers actual field names, not generic label/title aliases.
 * Confirmed empirically: [community:name]/[protocol:name] resolve
 * correctly, [community:label]/[protocol:title] do not. Also removes
 * "Added to community" as a notification type per product decision --
 * mukurtu_user_added_to_community's text is fixed for consistency even
 * though nothing creates it anymore.
 */
function mukurtu_notifications_update_40035(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'message.template.mukurtu_removed_from_community',
    'message.template.mukurtu_removed_from_protocol',
    'message.template.mukurtu_user_added_to_protocol',
    'message.template.mukurtu_user_added_to_community',
    'message.template.mukurtu_new_item_in_community',
    'message.template.mukurtu_new_item_in_protocol',
  ] as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }
}

/**
 * Installs the field_digest_pending base field on the message entity.
 *
 * Declared via hook_entity_base_field_info() so it applies to every message
 * bundle at once; on existing sites the storage schema itself still needs
 * to be installed explicitly via the entity definition update manager.
 */
function mukurtu_notifications_update_40036(): void {
  $storage_definition = \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
    ->setLabel(t('Digest pending'))
    ->setDescription(t('Whether this message is waiting to be included in a digest email rather than sent immediately.'))
    ->setDefaultValue(FALSE)
    ->setDisplayConfigurable('form', FALSE)
    ->setDisplayConfigurable('view', FALSE);

  \Drupal::entityDefinitionUpdateManager()->installFieldStorageDefinition(
    'field_digest_pending',
    'message',
    'mukurtu_notifications',
    $storage_definition
  );
}

/**
 * Deploys the email-frequency preference field and the admin "all
 * notifications" view display.
 *
 * The new menu link in mukurtu_notifications.links.menu.yml needs no
 * explicit deployment step -- links.menu.yml entries are discovered plugin
 * definitions, not config entities, so they appear automatically once the
 * updated file is in place and caches are rebuilt.
 */
function mukurtu_notifications_update_40037(): void {
  mukurtu_notifications_create_field_notify_frequency();


/**
 * Creates a flag from $values, or updates it in place if it already exists.
 *
 * Flag::create() with an id that already exists in config storage throws
 * EntityStorageException, so an existing flag must be loaded and have its
 * properties set individually instead of being recreated.
 */
function _mukurtu_notifications_save_flag(array $values): void {
  $flag = Flag::load($values['id']);
  if ($flag) {
    foreach ($values as $property => $value) {
      $flag->set($property, $value);
    }
  }
  else {
    $flag = Flag::create($values);
  }
  $flag->save();
}

/**
 * Install new user account created message template and view displays.
 */
function mukurtu_notifications_update_40001(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  $configs = [
    'message.template.mukurtu_new_user_account_created',
    'core.entity_view_display.message.mukurtu_new_user_account_created.mail_subject',
    'core.entity_view_display.message.mukurtu_new_user_account_created.mail_body',
  ];

  foreach ($configs as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }
}

/**
 * Update new user account notification email body.
 */
function mukurtu_notifications_update_40002(): void {
  $config = \Drupal::service('config.factory')->getEditable('message.template.mukurtu_new_user_account_created');
  if ($config->isNew()) {
    return;
  }
  $text = $config->get('text');
  $text[1]['value'] = "<p>A new user account <a href=\"[message:field_user:entity:url]\">[message:field_user:entity:field_display_name] ([message:field_user:entity:account-name])</a> has been created. You may want to add them to more communities or protocols. <a href=\"[message:field_user:entity:url]\">Review their account</a>.</p>\r\n";
  $config->set('text', $text)->save();
}

/**
 * Attach field_user to the mukurtu_new_user_account_created message template.
 */
function mukurtu_notifications_update_40003(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');
  $config_storage->write(
    'field.field.message.mukurtu_new_user_account_created.field_user',
    $source->read('field.field.message.mukurtu_new_user_account_created.field_user')
  );

  // Rebuild entity type and field definitions so the new field is recognised.
  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}

/**
 * Remove message_digest bulk actions for the email_user flag, which does not
 * exist in Mukurtu and caused fatal errors in Views bulk forms.
 */
function mukurtu_notifications_update_40004(): void {
  $config_factory = \Drupal::configFactory();
  $actions = [
    'system.action.message_digest_interval.email_user.daily',
    'system.action.message_digest_interval.email_user.immediate',
    'system.action.message_digest_interval.email_user.weekly',
  ];
  foreach ($actions as $action) {
    $config_factory->getEditable($action)->delete();
  }
}

/**
 * Deploy the notifications page display for the mukurtu_message_log view.
 *
 * Adds the "Notifications" page display at /notifications, scoped to the
 * current user's messages via a uid contextual filter.
 */
function mukurtu_notifications_update_40005(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );
}

/**
 * Create missing field attachments for message templates.
 *
 * The message template field attachments were never deployed, which is why
 * most notification hooks were disabled. The field storages already exist in
 * the database; this hook only writes the bundle-level attachment configs.
 * field_protocol is handled separately in hook_update_40007 using the Field
 * API so the database schema is created correctly.
 */
function mukurtu_notifications_update_40006(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  // Deploy field attachments for templates whose storage tables already exist.
  // Note: field_community uses handler 'default:node' because the underlying
  // field storage (field.storage.message.field_community) targets node -- this
  // is intentional for now. Phase 2 will update it to target the community
  // entity type once the follow-community flag is updated.
  $field_configs = [
    'field.field.message.mukurtu_single_node_insert.field_item',
    'field.field.message.mukurtu_single_node_update.field_item',
    'field.field.message.mukurtu_single_node_delete.field_title',
    'field.field.message.mukurtu_single_node_delete.field_content_type',
    'field.field.message.mukurtu_single_node_delete.field_user',
    'field.field.message.mukurtu_new_item_in_community.field_item',
    'field.field.message.mukurtu_new_item_in_community.field_community',
    'field.field.message.mukurtu_new_item_in_protocol.field_item',
    'field.field.message.mukurtu_new_item_in_collection.field_item',
    'field.field.message.mukurtu_new_item_in_collection.field_collection',
    'field.field.message.mukurtu_new_user_registration.field_user',
  ];

  foreach ($field_configs as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }

  // Rebuild entity type and field definitions.
  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}

/**
 * Create field_protocol storage and attachment for message templates via Field API.
 *
 * Raw config writes (used in hook_update_40006) do not create database tables.
 * This hook uses FieldStorageConfig and FieldConfig so the schema is created.
 */
function mukurtu_notifications_update_40007(): void {
  // Remove any bad config written without schema in a previous run.
  \Drupal::configFactory()->getEditable('field.storage.message.field_protocol')->delete();
  \Drupal::configFactory()->getEditable('field.field.message.mukurtu_new_item_in_protocol.field_protocol')->delete();

  // Create the field storage and attachment with proper DB schema.
  mukurtu_notifications_create_field_protocol();
}

/**
 * Fix non-descriptive "Details" link text in batch import report template.
 */
function mukurtu_notifications_update_40008(): void {
  $config = \Drupal::configFactory()->getEditable('message.template.mukurtu_batch_import_report');
  if ($config->isNew()) {
    return;
  }
  $text = $config->get('text');
  if (!empty($text[0]['value'])) {
    $text[0]['value'] = str_replace(
      '>Details</a>',
      '>View batch import report</a>',
      $text[0]['value']
    );
    $config->set('text', $text)->save();
  }
}


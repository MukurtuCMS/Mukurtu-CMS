    'weight' => 2,
    'flag_short' => 'Flag this item',
    'flag_long' => '',
    'flag_message' => '',
    'unflag_short' => 'Unflag this item',
    'unflag_long' => '',
    'unflag_message' => '',
    'unflag_denied_text' => '',
    'flag_type' => 'entity:community',
    'link_type' => 'ajax_link',
    'flagTypeConfig' => [
      'show_in_links' => [],
      'show_as_field' => TRUE,
      'show_on_form' => FALSE,
      'show_contextual_link' => FALSE,
      'extra_permissions' => ['owner' => '0'],
    ],
    'linkTypeConfig' => [],
  ]);
}


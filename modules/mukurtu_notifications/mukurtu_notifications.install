<?php

/**
 * @file
 * Install, update and uninstall functions for the mukurtu_notifications module.
 */

use Drupal\Core\Config\FileStorage;
use Drupal\flag\Entity\Flag;

/**
 * Implements hook_install().
 *
 * Creates field_protocol and field_community_ref storages and attachments via
 * Field API, and the community/protocol follow/email flags via the Flag API,
 * on fresh installs. These cannot live in config/install because their
 * dependencies on custom entity types owned by mukurtu_protocol cause
 * UnmetDependenciesException: mukurtu_protocol and mukurtu_notifications
 * depend on each other (mukurtu_protocol calls notification functions from a
 * form submit handler; mukurtu_notifications checks node objects against
 * mukurtu_protocol's CulturalProtocolControlledInterface), so the module
 * installer cannot guarantee mukurtu_protocol is already active when
 * mukurtu_notifications' config/install is processed on a fresh install.
 */
function mukurtu_notifications_install(): void {
  mukurtu_notifications_create_field_protocol();
  mukurtu_notifications_create_field_community_ref();
  mukurtu_notifications_create_field_notify_email_categories();
  mukurtu_notifications_create_field_notify_frequency();
  mukurtu_notifications_create_flag_email_community();
  mukurtu_notifications_create_flag_email_protocol();
  mukurtu_notifications_create_flag_follow_community();
  mukurtu_notifications_create_flag_follow_protocol();
  mukurtu_notifications_configure_message_subscribe();
}

/**
 * Sets the flag_prefix (and other) settings message_subscribe and
 * message_subscribe_email need to auto-discover subscribers via our
 * mukurtu_follow_ and mukurtu_email_ prefixed flags.
 *
 * These cannot live in config/install because message_subscribe and
 * message_subscribe_email already install their own default
 * message_subscribe.settings/message_subscribe_email.settings config, and
 * Drupal's config installer throws PreExistingConfigException if another
 * module's config/install tries to provide a config object that already
 * exists in active configuration.
 */
function mukurtu_notifications_configure_message_subscribe(): void {
  \Drupal::configFactory()->getEditable('message_subscribe.settings')
    ->set('use_queue', FALSE)
    ->set('notify_own_actions', FALSE)
    ->set('flag_prefix', 'mukurtu_follow')
    ->set('debug_mode', FALSE)
    ->set('default_notifiers', ['email'])
    ->set('range', 100)
    ->save();

  \Drupal::configFactory()->getEditable('message_subscribe_email.settings')
    ->set('flag_prefix', 'mukurtu_email')
    ->save();
}

/**
 * Creates the field_protocol storage and all bundle attachments if missing.
 */
function mukurtu_notifications_create_field_protocol(): void {
  if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('message', 'field_protocol')) {
    \Drupal\field\Entity\FieldStorageConfig::create([
      'field_name' => 'field_protocol',
      'entity_type' => 'message',
      'type' => 'entity_reference',
      'settings' => ['target_type' => 'protocol'],
      'cardinality' => 1,
    ])->save();
  }

  $storage = \Drupal\field\Entity\FieldStorageConfig::loadByName('message', 'field_protocol');
  $bundles = [
    'mukurtu_new_item_in_protocol',
    'mukurtu_user_added_to_protocol',
    'mukurtu_removed_from_protocol',
  ];
  foreach ($bundles as $bundle) {
    if (!\Drupal\message\Entity\MessageTemplate::load($bundle)) {
      continue;
    }
    if (!\Drupal\field\Entity\FieldConfig::loadByName('message', $bundle, 'field_protocol')) {
      \Drupal\field\Entity\FieldConfig::create([
        'field_storage' => $storage,
        'bundle' => $bundle,
        'label' => 'Protocol',
      ])->save();
    }
  }

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}

/**
 * Creates the field_community_ref storage and all bundle attachments if missing.
 *
 * field_community_ref is a proper entity_reference to the community entity
 * type. The existing field_community targets node (a legacy mismatch) and
 * cannot be used for community entity references.
 */
function mukurtu_notifications_create_field_community_ref(): void {
  if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('message', 'field_community_ref')) {
    \Drupal\field\Entity\FieldStorageConfig::create([
      'field_name' => 'field_community_ref',
      'entity_type' => 'message',
      'type' => 'entity_reference',
      'settings' => ['target_type' => 'community'],
      'cardinality' => 1,
    ])->save();
  }

  $storage = \Drupal\field\Entity\FieldStorageConfig::loadByName('message', 'field_community_ref');
  $bundles = [
    'mukurtu_user_added_to_community',
    'mukurtu_new_item_in_community',
    'mukurtu_removed_from_community',
  ];
  foreach ($bundles as $bundle) {
    if (!\Drupal\message\Entity\MessageTemplate::load($bundle)) {
      continue;
    }
    if (!\Drupal\field\Entity\FieldConfig::loadByName('message', $bundle, 'field_community_ref')) {
      \Drupal\field\Entity\FieldConfig::create([
        'field_storage' => $storage,
        'bundle' => $bundle,
        'label' => 'Community',
      ])->save();
    }
  }

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}

/**
 * Creates the field_notify_email_categories storage and attachment on
 * the user entity if missing, defaulting existing and new users to "all
 * categories on" so no one's email volume silently drops.
 *
 * Uses the Field API rather than config/install (like field_protocol and
 * field_community_ref above) because writing field storage config directly
 * via config storage in an update hook does not create the underlying
 * database table -- only the Field API's create()->save() triggers that.
 */
function mukurtu_notifications_create_field_notify_email_categories(): void {
  if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('user', 'field_notify_email_categories')) {
    \Drupal\field\Entity\FieldStorageConfig::create([
      'field_name' => 'field_notify_email_categories',
      'entity_type' => 'user',
      'type' => 'list_string',
      'cardinality' => -1,
      'settings' => [
        'allowed_values' => [],
        'allowed_values_function' => 'mukurtu_notifications_notification_categories_allowed_values',
      ],
    ])->save();
  }

  $all_categories = array_keys(_mukurtu_notifications_category_labels());
  if (!\Drupal\field\Entity\FieldConfig::loadByName('user', 'user', 'field_notify_email_categories')) {
    \Drupal\field\Entity\FieldConfig::create([
      'field_name' => 'field_notify_email_categories',
      'entity_type' => 'user',
      'bundle' => 'user',
      'label' => 'Email notifications',
      'description' => "Choose which types of activity you'd like to receive email notifications about. You'll still see all activity in your notifications feed regardless of these settings.",
      'required' => FALSE,
      'default_value' => array_map(static fn (string $key) => ['value' => $key], $all_categories),
    ])->save();
  }

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();

  // Backfill existing users to "all categories on".
  $uids = \Drupal::entityQuery('user')->accessCheck(FALSE)->execute();
  foreach (\Drupal\user\Entity\User::loadMultiple($uids) as $user) {
    $user->set('field_notify_email_categories', $all_categories);
    $user->save();
  }
}

/**
 * Creates the field_notify_frequency storage and attachment on the user
 * entity if missing.
 *
 * No backfill needed: _mukurtu_notifications_user_wants_digest() already
 * treats an empty/unset value as "immediate" (today's behavior for every
 * existing user), so only the default for brand-new users needs setting.
 */
function mukurtu_notifications_create_field_notify_frequency(): void {
  if (!\Drupal\field\Entity\FieldStorageConfig::loadByName('user', 'field_notify_frequency')) {
    \Drupal\field\Entity\FieldStorageConfig::create([
      'field_name' => 'field_notify_frequency',
      'entity_type' => 'user',
      'type' => 'list_string',
      'cardinality' => 1,
      'settings' => [
        'allowed_values' => [],
        'allowed_values_function' => 'mukurtu_notifications_notification_frequency_allowed_values',
      ],
    ])->save();
  }

  if (!\Drupal\field\Entity\FieldConfig::loadByName('user', 'user', 'field_notify_frequency')) {
    \Drupal\field\Entity\FieldConfig::create([
      'field_name' => 'field_notify_frequency',
      'entity_type' => 'user',
      'bundle' => 'user',
      'label' => 'Email frequency',
      'description' => 'How often you want to receive notification emails.',
      'required' => FALSE,
      'default_value' => [['value' => 'immediate']],
    ])->save();
  }

  \Drupal::service('entity_field.manager')->clearCachedFieldDefinitions();
}


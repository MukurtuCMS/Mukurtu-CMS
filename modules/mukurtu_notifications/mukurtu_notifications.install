  foreach ([
    'mukurtu_user_added_to_protocol',
    'mukurtu_removed_from_protocol',
    'mukurtu_removed_from_community',
  ] as $template) {
    $config_storage->write('message.template.' . $template, $source->read('message.template.' . $template));
  }
}

/**
 * Fixes the "added to community" notification's broken link.
 *
 * mukurtu_user_added_to_community was missed by update_40042 -- it still
 * hand-composed <a href="[message:field_community_ref:entity:url]">, which
 * mukurtu_html's filter_html strips down to a bare "url]" fragment before
 * tokens are ever replaced (see mukurtu_notifications_tokens() for the full
 * explanation). This redeploys it to use the mukurtu-notification-link
 * token instead, matching the other three membership-notification
 * templates.
 */
function mukurtu_notifications_update_40043(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  \Drupal::service('config.storage')->write(
    'message.template.mukurtu_user_added_to_community',
    $source->read('message.template.mukurtu_user_added_to_community')
  );
}

/**
 * Fixes blank notification email bodies across 14 templates.
 *
 * message_notify maps the "mail_subject" view mode to a template's text
 * delta 0 and "mail_body" to delta 1 (see mukurtu_notifications_tokens()'s
 * neighboring functions and message_notify.module for the convention). These
 * 14 templates only ever defined one text entry (delta 0), so their
 * mail_body display -- which every bundle in this module points at delta 1
 * -- had nothing to render and sent a blank email body. This redeploys each
 * template with its text duplicated into both deltas, matching the working
 * two-delta templates (e.g. mukurtu_content_published) that were never
 * affected.
 */
function mukurtu_notifications_update_40044(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'mukurtu_batch_import_report',
    'mukurtu_comment_approved',
    'mukurtu_comment_denied',
    'mukurtu_new_user_registration',
    'mukurtu_removed_from_community',
    'mukurtu_removed_from_protocol',
    'mukurtu_single_node_delete',
    'mukurtu_single_node_insert',
    'mukurtu_single_node_update',
    'mukurtu_user_approved',
    'mukurtu_user_blocked',
    'mukurtu_user_deleted',
    'mukurtu_user_set_pending',
    'mukurtu_user_unblocked',
  ] as $template) {
    $config_storage->write('message.template.' . $template, $source->read('message.template.' . $template));
  }
}

/**
 * Adds title/content-type snapshot fields to 8 content-referencing
 * templates, and redeploys their text to use the new mukurtu-content-link
 * token in place of the raw entity-reference link.
 *
 * These templates reference content via the field_item entity reference.
 * Message::processTokens() re-resolves that reference live on every view
 * (never a stored snapshot), so once the referenced node is deleted, the
 * chained [message:field_item:entity:...] tokens have nothing left to
 * resolve and either go blank (clear: true) or show literal unresolved
 * token text (clear: false) in any previously-sent notification still in
 * the log. field_title/field_content_type (the same plain-string fields
 * mukurtu_single_node_delete already uses, for the same reason) are
 * populated at send time alongside field_item, and
 * mukurtu_notifications_tokens()'s new mukurtu-content-link token uses them
 * as a fallback when field_item's target no longer loads -- see that
 * function for the full explanation.
 */
function mukurtu_notifications_update_40045(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  $templates = [
    'mukurtu_content_for_review',
    'mukurtu_content_published',
    'mukurtu_content_archived',
    'mukurtu_content_to_draft',
    'mukurtu_protocol_comment',
    'mukurtu_comment_approved',
    'mukurtu_comment_denied',
    'mukurtu_single_node_update',
  ];

  foreach ($templates as $template) {
    foreach (['field_title', 'field_content_type'] as $field_name) {
      $config_name = 'field.field.message.' . $template . '.' . $field_name;
      if (!$config_storage->exists($config_name)) {
        $config_storage->write($config_name, $source->read($config_name));
      }
    }
    $config_storage->write('message.template.' . $template, $source->read('message.template.' . $template));
  }
}

/**
 * Adds the mukurtu_protocol_comment_pending template and the comment-insert
 * wording branch that uses it.
 *
 * mukurtu_notifications_comment_insert() previously always sent
 * mukurtu_protocol_comment ("was posted"), even for a comment that actually
 * requires approval first and isn't published yet. This adds the sibling
 * bundle used for that pending-review case ("was submitted for review"),
 * mirroring the existing mukurtu_content_published/mukurtu_content_for_review
 * split for node moderation.
 */
function mukurtu_notifications_update_40046(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'message.template.mukurtu_protocol_comment_pending',
    'field.field.message.mukurtu_protocol_comment_pending.field_item',
    'field.field.message.mukurtu_protocol_comment_pending.field_user',
    'field.field.message.mukurtu_protocol_comment_pending.field_title',
    'field.field.message.mukurtu_protocol_comment_pending.field_content_type',
    'core.entity_view_display.message.mukurtu_protocol_comment_pending.mail_body',
    'core.entity_view_display.message.mukurtu_protocol_comment_pending.mail_subject',
  ] as $config_name) {
    $config_storage->write($config_name, $source->read($config_name));
  }
}

/**
 * Widens the "All notifications" admin page's access to Mukurtu Managers.
 *
 * mukurtu_notifications_resolve_notify_groups(TRUE, ...) has always notified
 * both the administrator and mukurtu_manager roles (e.g. for
 * mukurtu_new_user_registration, which is deliberately excluded from the
 * personal Activity Page's type filter -- see
 * _mukurtu_notifications_type_groups()). But the only display where that
 * admin-facing template isn't filtered out, the Admin Page
 * (mukurtu_notifications_admin_page, path admin/notifications), was
 * access-restricted to the administrator role only, so a Mukurtu Manager
 * without the administrator role had a Message row created for them with no
 * page anywhere that would ever show it.
 */
function mukurtu_notifications_update_40047(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );
}

/**
 * Rewrites message template subjects to be short and link-free, and adds a
 * third, real-link text partial for the notifications log page.
 *
 * Nearly every template used the same plain-text-safe
 * mukurtu-notification-link/mukurtu-content-link token in both its subject
 * (text delta 0, used for the email subject and -- until this update -- also
 * for the notifications log page) and its body (delta 1). That token
 * deliberately renders as "Label (URL)" plain text rather than a real link
 * (see mukurtu_notifications_tokens()), which is correct for an email
 * subject line but meant the raw URL text leaked into the subject, and the
 * log page (which needs a real clickable link, not email-safe plain text)
 * showed the same dead "Label (URL)" text instead of a link.
 *
 * This redeploys: each template's rewritten subject (delta 0, now short and
 * link-free), a new delta 2 using the new mukurtu-notification-html-link/
 * mukurtu-content-html-link tokens (a real <a> tag, safe here because the
 * log page is a plain web page, not the mail pipeline), and the Views
 * "get_text" field's delta (already updated to 2 in mukurtu_notifications_
 * update_40047's views.view.mukurtu_message_log redeploy) picking up delta
 * 2 instead of delta 0.
 */
function mukurtu_notifications_update_40048(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  foreach ([
    'mukurtu_batch_import_report',
    'mukurtu_comment_approved',
    'mukurtu_comment_denied',
    'mukurtu_content_archived',
    'mukurtu_content_for_review',
    'mukurtu_content_published',
    'mukurtu_content_to_draft',
    'mukurtu_new_user_account_created',
    'mukurtu_new_user_registration',
    'mukurtu_protocol_comment',
    'mukurtu_protocol_comment_pending',
    'mukurtu_removed_from_community',
    'mukurtu_removed_from_protocol',
    'mukurtu_single_node_insert',
    'mukurtu_single_node_update',
    'mukurtu_user_added_to_community',
    'mukurtu_user_added_to_protocol',
    'mukurtu_user_approved',
    'mukurtu_user_blocked',
    'mukurtu_user_set_pending',
    'mukurtu_user_unblocked',
  ] as $template) {
    $config_storage->write('message.template.' . $template, $source->read('message.template.' . $template));

    // The new delta-2 partial is a dynamically-registered extra field
    // (message_entity_extra_field_info()); a display that doesn't
    // explicitly hide it shows it by default, so it must be added to
    // 'hidden' on both the mail_subject and mail_body displays or it
    // bleeds into both the subject and body.
    foreach (['mail_subject', 'mail_body'] as $view_mode) {
      $config_name = 'core.entity_view_display.message.' . $template . '.' . $view_mode;
      if ($config_storage->exists($config_name)) {
        $config_storage->write($config_name, $source->read($config_name));
      }
    }
  }

  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );
}

/**
 * Redeploys the new-user-registration wording fix and the admin
 * notifications page's new "Recipient" column.
 *
 * mukurtu_new_user_registration's mail/log body text previously said
 * "requires action" instead of "needs review", inconsistent with its
 * subject line. views.view.mukurtu_message_log's admin display
 * (mukurtu_notifications_admin_page) shows one row per recipient by
 * design (see _mukurtu_notifications_notify() in the .module file), but
 * had no column identifying which recipient each row belongs to, so
 * multiple rows for one action read as exact duplicates. This adds a
 * "Recipient" field (a new uid relationship + field_display_name field,
 * mirroring the existing actor-facing "User" column) to that display only.
 */
function mukurtu_notifications_update_40049(): void {
  $config_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $source = new FileStorage($config_path);
  $config_storage = \Drupal::service('config.storage');

  $config_storage->write(
    'message.template.mukurtu_new_user_registration',
    $source->read('message.template.mukurtu_new_user_registration')
  );
  $config_storage->write(
    'views.view.mukurtu_message_log',
    $source->read('views.view.mukurtu_message_log')
  );
}

/**
 * Removes the mukurtu_new_item_in_collection/_community/_protocol message
 * templates and their fields/displays.
 *
 * These three were phase-1 leftovers: mukurtu_notifications_notify_content_
 * created()'s docblock explains they were replaced by reusing
 * mukurtu_single_node_insert for both the "created" and "added to
 * protocol/community" cases, and mukurtu_new_item_in_collection was never
 * wired up to a notify() call site at all. None of the three has any
 * hook_ENTITY_TYPE_insert()/_update() caller left in this module, so they're
 * dead code -- and their mail_body displays still only have one text delta
 * (never received the update_40044/_40048 fixes the live templates got),
 * so they would send blank-body emails if anyone ever reintroduced a caller.
 * Formally dropped from phase-2 scope (2026-07-17 PR #1760 discussion)
 * rather than fixed, since nothing currently reaches them.
 *
 * field.storage.message.field_collection and .field_community are deleted
 * too -- confirmed via grep that no other template's field.field config or
 * any PHP in this module references either one. field_community_ref (used by
 * the live mukurtu_user_added_to_community/mukurtu_removed_from_community
 * templates) is a distinct field and is untouched.
 */
function mukurtu_notifications_update_40050(): void {
  $config_factory = \Drupal::configFactory();

  foreach ([
    'message.template.mukurtu_new_item_in_collection',
    'message.template.mukurtu_new_item_in_community',
    'message.template.mukurtu_new_item_in_protocol',
    'core.entity_view_display.message.mukurtu_new_item_in_collection.mail_body',
    'core.entity_view_display.message.mukurtu_new_item_in_collection.mail_subject',
    'core.entity_view_display.message.mukurtu_new_item_in_community.mail_body',
    'core.entity_view_display.message.mukurtu_new_item_in_community.mail_subject',
    'core.entity_view_display.message.mukurtu_new_item_in_protocol.mail_body',
    'core.entity_view_display.message.mukurtu_new_item_in_protocol.mail_subject',
    'field.field.message.mukurtu_new_item_in_collection.field_collection',
    'field.field.message.mukurtu_new_item_in_collection.field_item',
    'field.field.message.mukurtu_new_item_in_community.field_community',
    'field.field.message.mukurtu_new_item_in_community.field_item',
    'field.field.message.mukurtu_new_item_in_protocol.field_item',
    'field.storage.message.field_collection',
    'field.storage.message.field_community',
  ] as $name) {
    $config_factory->getEditable($name)->delete();
  }
}

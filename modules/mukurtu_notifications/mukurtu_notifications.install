 *
 * mukurtu_notifications_install() calls both helpers, but that only runs on
 * fresh installs. Existing sites that predate Phase 2 need this update hook.
 * Both helpers are idempotent -- they skip creation if the field already exists.
 */
function mukurtu_notifications_update_40023(): void {
  mukurtu_notifications_create_field_community_ref();
  mukurtu_notifications_create_field_protocol();
}

/**
 * Remove the redundant word "item" from all content notification activity text.
 *
 * Templates used the pattern "[content-type] item [title] was created."
 * where "item" is always redundant. Strips it from all 11 affected templates,
 * updating both text deltas where they exist (Phase 2 templates have two).
 */
function mukurtu_notifications_update_40024(): void {
  $templates = [
    'message.template.mukurtu_single_node_insert',
    'message.template.mukurtu_single_node_update',
    'message.template.mukurtu_single_node_delete',
    'message.template.mukurtu_new_item_in_collection',
    'message.template.mukurtu_new_item_in_community',
    'message.template.mukurtu_new_item_in_protocol',
    'message.template.mukurtu_content_archived',
    'message.template.mukurtu_content_for_review',
    'message.template.mukurtu_content_published',
    'message.template.mukurtu_content_to_draft',
    'message.template.mukurtu_protocol_comment',
  ];

  $config_factory = \Drupal::configFactory();
  foreach ($templates as $config_name) {
    $config = $config_factory->getEditable($config_name);
    if ($config->isNew()) {
      continue;
    }
    $text = $config->get('text');
    $changed = FALSE;
    foreach ($text as $delta => $item) {
      if (!empty($item['value']) && str_contains($item['value'], ' item&nbsp;')) {
        $text[$delta]['value'] = str_replace(' item&nbsp;', '&nbsp;', $item['value']);
        $changed = TRUE;
      }
    }
    if ($changed) {
      $config->set('text', $text)->save();
    }
  }
}

/**
 * Deploy message_subscribe/message_subscribe_email flag_prefix overrides.
 *
 * The contrib defaults ('subscribe' and 'email') don't match any of this
 * site's enabled, user-facing follow/email flags (mukurtu_follow_content,
 * mukurtu_follow_collection, mukurtu_follow_community,
 * mukurtu_email_content, mukurtu_email_collection,
 * mukurtu_email_community), so message_subscribe's flag-based subscriber
 * auto-discovery never found any subscribers -- clicking Follow or Get
 * Email never resulted in a notification being sent. This redeploys the
 * two settings configs with prefixes that match the flags actually in use.
 */
function mukurtu_notifications_update_40025(): void {
  mukurtu_notifications_configure_message_subscribe();
}

/**
 * Implement community follow notifications: retarget flag, wire up field.
 *
 * mukurtu_follow_community previously targeted node bundle "community"
 * (legacy pre-migration content that no longer represents real
 * communities). This redeploys the flag re-targeted at the actual
 * `community` entity type, redeploys the community canonical view display
 * with the follow button added to the sidebar, attaches field_community_ref
 * to the mukurtu_new_item_in_community message bundle, and redeploys that
 * template's text (corrected to reference field_community_ref instead of
 * the node-targeted field_community). Old Flagging records tied to the
 * previous node-targeted flag are intentionally left as harmless orphans --
 * there is no meaningful way to map legacy community nodes to real
 * community entities.
 */
function mukurtu_notifications_update_40026(): void {
  $notifications_path = \Drupal::service('extension.list.module')->getPath('mukurtu_notifications') . '/config/install';
  $protocol_path = \Drupal::service('extension.list.module')->getPath('mukurtu_protocol') . '/config/install';
  $notifications_source = new FileStorage($notifications_path);
  $protocol_source = new FileStorage($protocol_path);
  $config_storage = \Drupal::service('config.storage');

  mukurtu_notifications_create_flag_follow_community();
  $config_storage->write('message.template.mukurtu_new_item_in_community', $notifications_source->read('message.template.mukurtu_new_item_in_community'));
  $config_storage->write('core.entity_view_display.community.community.full', $protocol_source->read('core.entity_view_display.community.community.full'));

  mukurtu_notifications_create_field_community_ref();
}

/**

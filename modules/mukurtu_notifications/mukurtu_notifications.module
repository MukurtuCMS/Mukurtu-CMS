/**
 * Implements hook_node_insert().
 */
function mukurtu_notifications_node_insert(Node $node) {
  // Record the node insert event for all published nodes.
  if (!$node->isPublished()) {
    return;
  }

  // Phase 1: record the event for the notifications feed. No email is sent on
  // insert; email dispatch is phase 2 once per-user opt-in preferences are wired.
  $message = Message::create([
    'template' => 'mukurtu_single_node_insert',
    'uid' => $node->getOwnerId(),
  ]);
  $message->set('field_item', $node);
  $message->set('field_user', \Drupal::currentUser()->id());
  $message->save();
}

/**
 * Implements hook_node_update().
 */
function mukurtu_notifications_node_update(Node $node) {
  // Handle content moderation state changes regardless of published status.
  if ($node->hasField('moderation_state') && isset($node->original)) {
    $old_state = $node->original->get('moderation_state')->value;
    $new_state = $node->get('moderation_state')->value;
    if ($old_state !== $new_state) {
      mukurtu_notifications_handle_moderation_change($node, $old_state, $new_state);
    }
  }

  // Don't record events or send notifications for unpublished nodes.
  if (!$node->isPublished()) {
    return;
  }

  $subscribers = \Drupal::service('message_subscribe.subscribers');
  $current_user_id = (int) \Drupal::currentUser()->id();
  $owner_id = (int) $node->getOwnerId();

  // Record the node update event.
  $message = Message::create([
    'template' => 'mukurtu_single_node_update',
    'uid' => $node->getOwnerId(),
  ]);
  $message->set('field_item', $node);
  $message->set('field_user', $current_user_id);
  $message->save();

  // Notify the node owner and protocol stewards when someone else edits.
  if ($current_user_id !== $owner_id) {
    $notify_uids = [];

    // Include the node owner.
    if ($owner_id > 0) {
      $notify_uids[] = $owner_id;
    }

    // Include protocol stewards for content with cultural protocols assigned.
    if ($node->hasField('field_cultural_protocols')) {
      $protocol_ids = $node->getProtocols();
      if (!empty($protocol_ids)) {
        $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids);
        $notify_uids = array_merge($notify_uids, $steward_uids);
      }
    }

    // Exclude the editor and deduplicate.
    $notify_uids = array_values(array_unique(array_diff($notify_uids, [$current_user_id])));

    if (!empty($notify_uids)) {
      $flags = ['subscribe_node'];
      $notifiers = ['email'];
      $subscribe_options = [
        'notify message owner' => FALSE,
        'uids' => [],
      ];
      $email_validator = \Drupal::service('email.validator');
      $recipients = User::loadMultiple($notify_uids);
      foreach ($recipients as $uid => $recipient) {
        if (!$email_validator->isValid($recipient->getEmail())) {
          continue;
        }
        $subscribe_options['uids'][$uid] = new DeliveryCandidate($flags, $notifiers, $uid);
      }
      if (!empty($subscribe_options['uids'])) {
        try {
          $subscribers->sendMessage($message, $message, [], $subscribe_options);
        }
        catch (\Exception $e) {
          \Drupal::logger('mukurtu_notifications')->warning('Failed to send node update notification: @msg', ['@msg' => $e->getMessage()]);
        }
      }
    }
  }

  // Send "Mukurtu Follow Content" notifications to flag subscribers.
  // message_subscribe calls OG functions that throw for non-group content,
  // so limit this to nodes with cultural protocols.
  if ($node->hasField('field_cultural_protocols')) {
    try {
      $subscribers->sendMessage($node, $message);
    }
    catch (\Exception $e) {
      \Drupal::logger('mukurtu_notifications')->warning('Failed to send follow-content notification: @msg', ['@msg' => $e->getMessage()]);
    }
  }

  // Phase 2: protocol and community follow notifications go here once flags
  // are updated to target the protocol/community entity types.
  // mukurtu_notifications_notify_protocol($node, $subscribers);
  // mukurtu_notifications_notify_community($node, $subscribers);

  // Check for "Mukurtu Follow Collection" notifications.
  mukurtu_notifications_notify_collection($node, $subscribers);
}

/**
 * Deletes all messages of a given template that reference a specific entity.
 *
 * @param string $template
 *   The message template machine name.
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity whose messages should be removed.
 * @param string $field
 *   The field name on the message that references the entity. Defaults to
 *   'field_item'.
 */
function mukurtu_notifications_remove_notifications($template, $entity, $field = 'field_item') {
  // Find notifications for the given template that reference the entity.
  $query = \Drupal::entityQuery('message')
    ->condition('template', $template)
    ->condition($field, $entity->id())
    ->accessCheck(FALSE);
  $results = $query->execute();

  $messages = Message::loadMultiple($results);

  if (!empty($messages)) {
    foreach ($messages as $message) {
      $message->delete();
    }
  }
}

/**
 * Implements hook_node_delete().
 */
function mukurtu_notifications_node_delete(Node $node) {
  // Remove any old notifications for the deleted node.
  mukurtu_notifications_remove_notifications('mukurtu_single_node_insert', $node);
  mukurtu_notifications_remove_notifications('mukurtu_single_node_update', $node);

  // Record the node delete event.
  $template = 'mukurtu_single_node_delete';
  $message = Message::create([
    'template' => $template,
    'uid' => $node->getOwnerId(),
  ]);

  // Add the node's title to the message.
  $message->set('field_title', $node->getTitle());

  // Record the content type.
  $message->set('field_content_type', \Drupal::token()->replace('[node:type-name]', ['node' => $node]));

  // Record the user who took the action.
  $message->set('field_user', \Drupal::currentUser()->id());

  $message->save();
}

/**
 * Implements hook_ENTITY_TYPE_insert().
 */
function mukurtu_notifications_user_insert($entity) {
  // Only want to send notifications for users that
  // require action to be unblocked.
  if ($entity->isActive()) {
    return;
  }

  // Create the new user registration message.
  $template = 'mukurtu_new_user_registration';
  $message = Message::create([
    'template' => $template,
    'uid' => 1,
  ]);

  // Record the user requesting the account.
  $message->set('field_user', $entity);
  $message->save();

  // Find all users with 'administer users' permission.
  // TODO: Eventually we want an option for these admin users to
  // be able to opt out of these emails. At that point we'll
  // need to filter for that in this query.
  $roles = user_role_names(TRUE, 'administer users');
  $rids = array_keys($roles);
  $uids = \Drupal::service('entity_type.manager')->getStorage('user')->getQuery()
    ->condition('roles', $rids, 'IN')
    ->execute();

  // Build the options required to send the message to specific
  // uids via message subscribe, rather than querying flags.
  $flags = ['subscribe_user'];
  $notifiers = ['email'];
  $notify_options = [];
  $subscribe_options = [
    'notify message owner' => FALSE,
    'uids' => [],
  ];
  $email_validator = \Drupal::service('email.validator');
  $admin_users = User::loadMultiple($uids);
  foreach ($admin_users as $uid => $admin_user) {
    if (!$email_validator->isValid($admin_user->getEmail())) {
      continue;
    }
    $subscribe_options['uids'][$uid] = new DeliveryCandidate($flags, $notifiers, $uid);
  }

  // Queue messages to our custom list of admins.
  $subscribers = \Drupal::service('message_subscribe.subscribers');
  try {
    $subscribers->sendMessage($message, $message, $notify_options, $subscribe_options);
  }
  catch (\Exception $e) {
    \Drupal::logger('mukurtu_notifications')->warning('Failed to send user registration notification: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Sends email notifications to selected users when a new account is created.
 *
 * @param \Drupal\user\Entity\User $new_user
 *   The newly created user entity.
 * @param array $notify_uids
 *   Array of user IDs to notify.
 */
function mukurtu_notifications_notify_new_account_created(User $new_user, array $notify_uids): void {
  if (empty($notify_uids)) {
    return;
  }

  $message = Message::create([
    'template' => 'mukurtu_new_user_account_created',
    'uid' => \Drupal::currentUser()->id(),
  ]);
  $message->set('field_user', $new_user);
  $message->save();

  $flags = ['subscribe_user'];
  $notifiers = ['email'];
  $subscribe_options = [
    'notify message owner' => FALSE,
    'uids' => [],
  ];
  $email_validator = \Drupal::service('email.validator');
  $notify_users = User::loadMultiple($notify_uids);
  foreach ($notify_users as $uid => $notify_user) {
    if (!$email_validator->isValid($notify_user->getEmail())) {
      continue;
    }
    $subscribe_options['uids'][$uid] = new DeliveryCandidate($flags, $notifiers, (int) $uid);
  }

  try {
    \Drupal::service('message_subscribe.subscribers')
      ->sendMessage($message, $message, [], $subscribe_options);
  }
  catch (\Exception $e) {
    \Drupal::logger('mukurtu_notifications')->warning('Failed to send new account notification: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Resolves group-based notification selections to an array of user IDs.
 *
 * @param bool $all_managers
 *   If TRUE, include all users with the administrator or mukurtu_manager role.
 * @param array $community_ids
 *   Entity IDs of communities whose community managers should be notified.
 * @param array $protocol_ids
 *   Entity IDs of protocols whose protocol stewards should be notified.
 *
 * @return array
 *   Unique array of integer user IDs.
 */
function mukurtu_notifications_resolve_notify_groups(bool $all_managers, array $community_ids, array $protocol_ids): array {
  $uids = [];

  if ($all_managers) {
    $manager_uids = \Drupal::entityQuery('user')
      ->condition('roles', ['administrator', 'mukurtu_manager'], 'IN')
      ->condition('status', 1)
      ->accessCheck(FALSE)
      ->execute();
    $uids = array_merge($uids, array_values($manager_uids));
  }

  if (!empty($community_ids)) {
    $memberships = \Drupal::entityQuery('og_membership')
      ->condition('entity_type', 'community')
      ->condition('entity_id', $community_ids, 'IN')
      ->condition('roles', 'community-community-community_manager')
      ->condition('state', 'active')
      ->accessCheck(FALSE)
      ->execute();
    $loaded = \Drupal::entityTypeManager()->getStorage('og_membership')->loadMultiple($memberships);
    foreach ($loaded as $m) {
      $uids[] = (int) $m->getOwnerId();
    }
  }

  if (!empty($protocol_ids)) {
    $memberships = \Drupal::entityQuery('og_membership')
      ->condition('entity_type', 'protocol')
      ->condition('entity_id', $protocol_ids, 'IN')
      ->condition('roles', 'protocol-protocol-protocol_steward')
      ->condition('state', 'active')
      ->accessCheck(FALSE)
      ->execute();
    $loaded = \Drupal::entityTypeManager()->getStorage('og_membership')->loadMultiple($memberships);
    foreach ($loaded as $m) {
      $uids[] = (int) $m->getOwnerId();
    }
  }

  return array_values(array_unique($uids));
}

/**
 * Extracts and resolves all notify UIDs from the shared notify form section.
 *
 * Reads notify_user_count, notify_users, notify_all_managers,
 * notify_communities, and notify_protocols from form state, then delegates
 * to mukurtu_notifications_resolve_notify_groups for group-based selections.
 *
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 *   The form state from a form that includes the shared notify section.
 *
 * @return array
 *   Unique array of integer user IDs to notify.
 */
function mukurtu_notifications_extract_notify_uids(FormStateInterface $form_state): array {
  $notifyUids = [];
  $notifyUserCount = $form_state->get('notify_user_count') ?? 1;
  for ($i = 0; $i < $notifyUserCount; $i++) {
    $uid = $form_state->getValue(['notify_users', 'user_' . $i]);
    if (!empty($uid)) {
      $notifyUids[] = (int) $uid;
    }
  }

  $allManagers = (bool) $form_state->getValue('notify_all_managers');
  $communityIds = array_keys(array_filter($form_state->getValue('notify_communities') ?? []));
  $protocolIds = [];
  foreach ($form_state->getValue('notify_protocols') ?? [] as $groupValues) {
    if (is_array($groupValues)) {
      $protocolIds = array_merge($protocolIds, array_keys(array_filter($groupValues)));
    }
  }
  $protocolIds = array_unique($protocolIds);

  $groupUids = mukurtu_notifications_resolve_notify_groups($allManagers, $communityIds, $protocolIds);
  return array_values(array_unique(array_merge($notifyUids, $groupUids)));
}


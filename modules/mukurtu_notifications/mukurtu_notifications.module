/**
 * Implements hook_token_info().
 *
 * Declares a single "safe link" token per entity type, so notification
 * template text never has to compose <a href="[...:url]">[...:title]</a> by
 * hand -- see mukurtu_notifications_tokens() for why that composition is
 * unsafe in this specific context.
 */
function mukurtu_notifications_token_info() {
  $info['tokens']['node']['mukurtu-notification-link'] = [
    'name' => t('Notification link'),
    'description' => t('"Title (URL)" text linking to the content, safe to use inside message template text.'),
  ];
  $info['tokens']['user']['mukurtu-notification-link'] = [
    'name' => t('Notification edit link'),
    'description' => t('"Name (URL)" text linking to the account\'s edit form, safe to use inside message template text.'),
  ];
  $info['tokens']['protocol']['mukurtu-notification-link'] = [
    'name' => t('Notification link'),
    'description' => t('"Name (URL)" text linking to the protocol, safe to use inside message template text.'),
  ];
  $info['tokens']['community']['mukurtu-notification-link'] = [
    'name' => t('Notification link'),
    'description' => t('"Name (URL)" text linking to the community, safe to use inside message template text.'),
  ];
  $info['tokens']['message']['mukurtu-content-link'] = [
    'name' => t('Content link (deletion-safe)'),
    'description' => t("A message's referenced content, linked if it still exists, or falling back to its title text if it's since been deleted."),
  ];
  return $info;
}

/**
 * Implements hook_tokens().
 *
 * Message templates render through their text format's filters (e.g.
 * mukurtu_html's filter_html, which calls Xss::filter() on every href/src
 * attribute) BEFORE tokens are replaced -- see
 * \Drupal\message\Entity\MessageTemplate::getText(), which is called before
 * \Drupal\message\Entity\Message::processTokens() ever runs. An unresolved
 * chained token sitting directly inside an href, e.g.
 * "[message:field_item:entity:url]", looks to
 * \Drupal\Component\Utility\UrlHelper::stripDangerousProtocols() like a
 * sequence of disallowed URI schemes ("message:", "field_item:", "entity:")
 * and gets stripped down to just its last segment ("url]") before it's ever
 * replaced -- confirmed empirically: rendering that raw template text
 * through any of this site's HTML-capable text formats reproduces the exact
 * mangled output seen in production. Token replacement itself runs after
 * that filtering and is never re-filtered, so a token whose *replacement
 * value* is plain, pre-escaped text is unaffected: there's no literal
 * "word:" text in an href attribute at filter time because the replacement
 * never contains an href at all.
 *
 * The replacement is "Label (URL)" plain text rather than an <a> tag for a
 * second reason: Drupal's mail renderer (MailFormatHelper::htmlToText())
 * converts every anchor in an HTML mail body into "Label [n]" plus a
 * "[n] URL" footnote at the bottom of the message. Emitting the URL inline
 * as plain text instead sidesteps that conversion entirely, so the link
 * prints inline right after the name in both the HTML and plain-text mail
 * views.
 */
function mukurtu_notifications_tokens($type, array $tokens, array $data, array $options, BubbleableMetadata $bubbleable_metadata) {
  $replacements = [];

  if ($type === 'node' && !empty($data['node']) && isset($tokens['mukurtu-notification-link'])) {
    $node = $data['node'];
    $bubbleable_metadata->addCacheableDependency($node);
    $url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
    $replacements[$tokens['mukurtu-notification-link']] = Markup::create(Html::escape($node->label()) . ' (' . Html::escape($url) . ')');
  }

  if ($type === 'user' && !empty($data['user']) && isset($tokens['mukurtu-notification-link'])) {
    $account = $data['user'];
    $bubbleable_metadata->addCacheableDependency($account);
    $url = $account->toUrl('edit-form', ['absolute' => TRUE])->toString();
    $replacements[$tokens['mukurtu-notification-link']] = Markup::create(Html::escape($account->label()) . ' (' . Html::escape($url) . ')');
  }

  if (in_array($type, ['protocol', 'community'], TRUE) && !empty($data[$type]) && isset($tokens['mukurtu-notification-link'])) {
    $entity = $data[$type];
    $bubbleable_metadata->addCacheableDependency($entity);
    $url = $entity->toUrl('canonical', ['absolute' => TRUE])->toString();
    $replacements[$tokens['mukurtu-notification-link']] = Markup::create(Html::escape($entity->label()) . ' (' . Html::escape($url) . ')');
  }

  if ($type === 'message' && !empty($data['message']) && isset($tokens['mukurtu-content-link'])) {
    $message = $data['message'];
    $node = ($message->hasField('field_item') && !$message->get('field_item')->isEmpty())
      ? $message->get('field_item')->entity
      : NULL;

    if ($node instanceof Node) {
      $bubbleable_metadata->addCacheableDependency($node);
      $url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
      $replacements[$tokens['mukurtu-content-link']] = Markup::create(Html::escape($node->label()) . ' (' . Html::escape($url) . ')');
    }
    elseif ($message->hasField('field_title') && !$message->get('field_title')->isEmpty()) {
      // The referenced node is gone (deleted) -- fall back to the plain
      // title snapshot taken at send time; there's nothing left to link to.
      $replacements[$tokens['mukurtu-content-link']] = Markup::create(Html::escape($message->get('field_title')->value));
    }
  }

  return $replacements;
}

/**
 * Returns the notification type group-to-template mapping.
 *
 * Derived from _mukurtu_notifications_categories(), excluding
 * 'mukurtu_new_user_registration': that template must stay opt-in-only via
 * the email preference field and never become selectable in this general
 * activity filter (it's an admin-facing pending-approval notice).
 *
 * @return array<string, string[]>
 *   Keys are human-readable group labels; values are arrays of template
 *   machine names belonging to that group.
 */
function _mukurtu_notifications_type_groups(): array {
  $groups = [];
  foreach (_mukurtu_notifications_categories() as $category) {
    $templates = array_values(array_diff($category['templates'], ['mukurtu_new_user_registration']));
    if (!empty($templates)) {
      $groups[$category['label']] = $templates;
    }
  }
  return $groups;
}

/**
 * Implements hook_form_views_exposed_form_alter().
 *
 * Replaces the notification type filter with a flat list of group labels.
 */
function mukurtu_notifications_form_views_exposed_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $view = $form_state->get('view');
  if (!$view || $view->id() !== 'mukurtu_message_log') {
    return;
  }
  if (empty($form['type']['#options'])) {
    return;
  }

  $groups = _mukurtu_notifications_type_groups();
  $current = $form['type']['#options'];

  // Build a flat list: include a group only if at least one of its templates
  // exists in the current options (i.e. there is data for it). This is a
  // multi-select "in" operator filter, so there's no synthetic "- Any -"
  // placeholder entry to preserve -- leaving everything unchecked already
  // means "no restriction".
  $options = [];
  foreach ($groups as $group_label => $machine_names) {
    if (!empty(array_intersect_key(array_flip($machine_names), $current))) {
      $options[$group_label] = $group_label;
    }
  }

  $form['type']['#options'] = $options;

  // Views already populated #default_value with the filter's actual current
  // value -- raw template machine names (e.g. the expanded result of a
  // prior submission via mukurtu_notifications_type_filter_validate()
  // below), not the group label(s) #options is keyed by above. Left as-is,
  // the widget can't match raw machine names against group-label keys, so
  // redisplay ends up showing the wrong (or extra) categories as selected.
  // Reverse-map back to the group label(s) that actually own the current
  // value so only those show as checked.
  $current_value = array_filter((array) ($form['type']['#default_value'] ?? []));
  if (!empty($current_value)) {
    $selected_groups = [];
    foreach ($groups as $group_label => $machine_names) {
      if (array_intersect($machine_names, $current_value)) {
        $selected_groups[] = $group_label;
      }
    }
    $form['type']['#default_value'] = $selected_groups;
  }

  // Expand the submitted group label(s) into real template machine names
  // via #element_validate, not hook_views_pre_execute: Views builds the
  // filter's SQL "IN (...)" condition from $filter->value during
  // ViewExecutable::build() (_build('filter'), which runs the exposed form
  // through full Form API validation/submission first), and only invokes
  // hook_views_pre_execute() afterward -- by then the query is already
  // built, so mutating $filter->value there is a no-op. #element_validate
  // runs during that same build()-time form processing, before the filter's
  // query() method reads the value.
  $form['type']['#element_validate'][] = 'mukurtu_notifications_type_filter_validate';
}

/**
 * Element validate callback for the notifications page's type filter.
 *
 * Rewrites the submitted group label(s) (e.g. "Comments") into their
 * underlying template machine names (e.g. mukurtu_protocol_comment,
 * mukurtu_comment_approved, mukurtu_comment_denied) so the bundle filter's
 * query() method -- which runs later in the same build() pass -- generates
 * the correct WHERE template IN (...) clause. When nothing is selected, the
 * personal feed display gets the curated default restriction applied here
 * instead (bypassing the exposed form's #options, which only ever expose
 * group labels) so admin-only templates like mukurtu_new_user_registration
 * don't leak into the general activity feed; the admin "all notifications"
 * display is left unrestricted, showing every template.
 */
function mukurtu_notifications_type_filter_validate(array $element, FormStateInterface $form_state, array $form): void {
  $view = $form_state->get('view');
  $selected = (array) $form_state->getValue($element['#parents']);
  $selected = array_filter($selected, static fn ($value) => $value !== 0 && $value !== '0');

  if (empty($selected)) {
    if ($view && $view->current_display === 'mukurtu_notifications_page') {
      $form_state->setValueForElement($element, _mukurtu_notifications_default_type_filter());
    }
    return;
  }

  $groups = _mukurtu_notifications_type_groups();
  $expanded = [];
  foreach ($selected as $key) {
    if (isset($groups[$key])) {
      $expanded = array_merge($expanded, $groups[$key]);
    }
    else {
      $expanded[] = $key;
    }
  }
  $form_state->setValueForElement($element, array_unique($expanded));
}

/**
 * Returns the notification templates shown by default when no type filter
 * is selected on the notifications page.
 *
 * mukurtu_new_user_registration is intentionally excluded (via
 * _mukurtu_notifications_type_groups(), which this is derived from): it is
 * an admin-facing message and should not appear in the general activity feed.
 *
 * @return string[]
 *   Template machine names.
 */
function _mukurtu_notifications_default_type_filter(): array {
  $templates = [];
  foreach (_mukurtu_notifications_type_groups() as $machine_names) {
    $templates = array_merge($templates, $machine_names);
  }
  return $templates;
}

/**
 * Returns the canonical notification category definitions.
 *
 * Single source of truth for the template-to-category mapping used to gate
 * email delivery (_mukurtu_notifications_template_category(),
 * _mukurtu_notifications_category_labels()), for the per-user email
 * preference field's allowed values, and (via _mukurtu_notifications_type_groups())
 * for the notifications page's exposed type filter.
 *
 * @return array<string, array{label: string, templates: string[]}>
 *   Keyed by category machine name.
 */
function _mukurtu_notifications_categories(): array {
  return [
    'user_account' => [
      'label' => 'User account',
      'templates' => [
        'mukurtu_new_user_registration',
        'mukurtu_new_user_account_created',
        'mukurtu_user_deleted',
        'mukurtu_user_approved',
        'mukurtu_user_set_pending',
        'mukurtu_user_blocked',
        'mukurtu_user_unblocked',
      ],
    ],
    'memberships' => [
      'label' => 'Memberships',
      'templates' => [
        'mukurtu_user_added_to_community',
        'mukurtu_user_added_to_protocol',
        'mukurtu_removed_from_community',
        'mukurtu_removed_from_protocol',
      ],
    ],
    'comments' => [
      'label' => 'Comments',
      'templates' => [
        'mukurtu_protocol_comment',
        'mukurtu_protocol_comment_pending',
        'mukurtu_comment_approved',
        'mukurtu_comment_denied',
      ],
    ],
    'publishing' => [
      'label' => 'Publishing',
      'templates' => [
        'mukurtu_content_for_review',
        'mukurtu_content_published',
        'mukurtu_content_to_draft',
        'mukurtu_content_archived',
        'mukurtu_single_node_update',
      ],
    ],
    'content' => [
      'label' => 'Content',
      'templates' => [
        'mukurtu_single_node_insert',
        'mukurtu_single_node_delete',
      ],
    ],
    'roundtrip' => [
      'label' => 'Roundtrip',
      'templates' => [
        'mukurtu_batch_import_report',
      ],
    ],
  ];
}

/**
 * Returns the canonical notification category labels, keyed by machine name.
 *
 * @return array<string, string>
 */
function _mukurtu_notifications_category_labels(): array {
  return array_map(static fn (array $category) => $category['label'], _mukurtu_notifications_categories());
}

/**
 * Maps a message template machine name to its notification category.
 *
 * @param string $template
 *   The message template machine name.
 *
 * @return string|null
 *   The category machine name, or NULL if the template isn't categorized.
 */
function _mukurtu_notifications_template_category(string $template): ?string {
  foreach (_mukurtu_notifications_categories() as $key => $category) {
    if (in_array($template, $category['templates'], TRUE)) {
      return $key;
    }
  }
  return NULL;
}

/**
 * Allowed-values callback for field_notify_email_categories.
 *
 * @return array<string, string>
 *   Category machine name => human-readable label.
 */
function mukurtu_notifications_notification_categories_allowed_values(FieldStorageDefinitionInterface $definition, ?FieldableEntityInterface $entity = NULL, &$cacheable = NULL): array {
  $cacheable = TRUE;
  return _mukurtu_notifications_category_labels();
}

/**
 * Allowed-values callback for field_notify_frequency.
 *
 * @return array<string, string>
 *   Frequency machine name => human-readable label.
 */
function mukurtu_notifications_notification_frequency_allowed_values(FieldStorageDefinitionInterface $definition, ?FieldableEntityInterface $entity = NULL, &$cacheable = NULL): array {
  $cacheable = TRUE;
  return [
    'immediate' => 'Immediate',
    'daily' => 'Daily',
    'weekly' => 'Weekly',
  ];
}

/**
 * Checks whether a user has a digest (daily/weekly) email preference.
 *
 * @param int $uid
 *   The user ID to check.
 *
 * @return bool
 *   TRUE if the user's emails should be batched into a digest rather than
 *   sent immediately.
 */
function _mukurtu_notifications_user_wants_digest(int $uid): bool {
  $user = User::load($uid);
  if (!$user || !$user->hasField('field_notify_frequency') || $user->get('field_notify_frequency')->isEmpty()) {
    return FALSE;
  }
  return in_array($user->get('field_notify_frequency')->value, ['daily', 'weekly'], TRUE);
}

/**
 * Checks whether a user wants to receive email for a notification template.
 *
 * Uncategorized templates are always emailed (there's no way for a user to
 * opt out of something with no category), which should not happen in
 * practice since every installed template is covered by
 * _mukurtu_notifications_categories().
 *
 * @param int $uid
 *   The recipient's user ID.
 * @param string $template
 *   The message template machine name.
 *
 * @return bool
 *   TRUE if the user should be emailed for this template.
 */
function _mukurtu_notifications_user_wants_email(int $uid, string $template): bool {
  $category = _mukurtu_notifications_template_category($template);
  if ($category === NULL) {
    return TRUE;
  }

  $user = User::load($uid);
  if (!$user || !$user->hasField('field_notify_email_categories')) {
    return TRUE;
  }

  $selected = array_column($user->get('field_notify_email_categories')->getValue(), 'value');
  return in_array($category, $selected, TRUE);
}

/**
 * Creates one Message per recipient and attempts email for each, gated by
 * the recipient's notification email preference.
 *
 * Every notification-worthy event should be visible in the feed of everyone
 * it concerns. Since neither the message entity nor the /notifications view
 * supports a single message with multiple viewers (the view filters
 * strictly on message.uid = current user), each recipient gets their own
 * Message row. The actor (if any) is excluded from email -- they don't need
 * to be emailed about their own action -- but if they're also a recipient
 * (e.g. the owner editing their own content) they still get a feed record.
 *
 * @param string $template
 *   The message template machine name.
 * @param array $field_values
 *   Additional field values to set on each message (e.g. field_item).
 * @param int[] $recipient_uids
 *   Uids who should see this in their feed and, subject to their email
 *   preference, be emailed.
 * @param int $actor_uid
 *   The uid who performed the triggering action, if any. Excluded from
 *   email regardless of preference. Defaults to 0 (no actor to exclude).
 */
function _mukurtu_notifications_notify(string $template, array $field_values, array $recipient_uids, int $actor_uid = 0): void {
  if (empty($recipient_uids)) {
    return;
  }

  $email_validator = \Drupal::service('email.validator');
  $subscribers = \Drupal::service('message_subscribe.subscribers');
  $recipients = User::loadMultiple($recipient_uids);

  foreach ($recipients as $uid => $recipient) {
    $uid = (int) $uid;
    $wants_email = FALSE;

    if ($uid !== $actor_uid) {
      $email = $recipient->getEmail();
      $wants_email = !empty($email) && $email_validator->isValid($email) && _mukurtu_notifications_user_wants_email($uid, $template);
    }

    // Digest-preference recipients get their email batched by cron instead
    // of sent now; the message itself still saves normally either way, so
    // the feed is unaffected.
    $wants_digest = $wants_email && _mukurtu_notifications_user_wants_digest($uid);

    $message = Message::create(['template' => $template, 'uid' => $uid] + $field_values);
    if ($wants_digest) {
      $message->set('field_digest_pending', TRUE);
    }
    $message->save();

    if (!$wants_email || $wants_digest) {
      continue;
    }

    $subscribe_options = [
      'notify message owner' => FALSE,
      'uids' => [
        $uid => new DeliveryCandidate([], ['email'], $uid),
      ],
    ];

    try {
      $subscribers->sendMessage($message, $message, [], $subscribe_options);
    }
    catch (\Exception $e) {
      \Drupal::logger('mukurtu_notifications')->warning('Failed to send @template notification: @msg', ['@template' => $template, '@msg' => $e->getMessage()]);
    }
  }
}

/**
 * Implements hook_entity_type_alter().
 */
function mukurtu_notifications_entity_type_alter(array &$entity_types) {
  $entity_types['message']->setHandlerClass('access', '\Drupal\Core\Entity\EntityAccessControlHandler');
  //$entity_types['message']->setHandlerClass('query_access', '\Drupal\entity\QueryAccess\QueryAccessHandler');
  $entity_types['message']->setHandlerClass('permission_provider', '\Drupal\Core\Entity\EntityPermissionProvider');
}

/**
 * Implements hook_entity_base_field_info().
 *
 * Adds field_digest_pending to every message bundle at once. A base field
 * (rather than the per-bundle field.field.*.yml config used elsewhere in
 * this module) is the right tool here: every one of the ~25 message
 * templates needs this identically, and per-bundle config would mean a
 * separate file for each one.
 */
function mukurtu_notifications_entity_base_field_info(\Drupal\Core\Entity\EntityTypeInterface $entity_type) {
  if ($entity_type->id() !== 'message') {
    return [];
  }

  $fields = [];
  $fields['field_digest_pending'] = \Drupal\Core\Field\BaseFieldDefinition::create('boolean')
    ->setLabel(t('Digest pending'))
    ->setDescription(t('Whether this message is waiting to be included in a digest email rather than sent immediately.'))
    ->setDefaultValue(FALSE)
    ->setDisplayConfigurable('form', FALSE)
    ->setDisplayConfigurable('view', FALSE);

  return $fields;
}

/**
 * Implements hook_entity_view_alter().
 */
function mukurtu_notifications_entity_view_alter(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display) {
  // Don't let anonymous users see flags.
  // If flag fields are shown for users without session info,
  // the server 500 errors out.
  // See https://www.drupal.org/project/flag/issues/3219804.
  $account = \Drupal::currentUser();

  // Exit early if not anonymous.
  if (!$account->isAnonymous()) {
    return;
  }

  // Get all the potential flags for the given entity/bundle type.
  $flag_service = \Drupal::service('flag');
  $flags = $flag_service->getAllFlags($entity->getEntityTypeID(), $entity->bundle());

  if (empty($flags)) {
    return;
  }

  // Remove any flags from the build array.
  foreach ($flags as $flag) {
    $flag_id = 'flag_' . $flag->id();
    if (isset($build[$flag_id])) {
      unset($build[$flag_id]);
    }
  }
}

/**
 * Implements hook_query_TAG_alter().
 *
 * Phase 2: filter message queries by the current user's protocol access grants.
 * Stubbed until the message entity type is wired to mukurtu_protocol_access.
 */
function mukurtu_notifications_query_message_access_alter(AlterableInterface $query) {
}

/**
 * Implements hook_node_insert().
 */
function mukurtu_notifications_node_insert(Node $node) {
  // The editorial workflow's default state for new content is "draft", but
  // a transition like "Submit for Review" is valid straight from "draft" --
  // so brand-new content can be created and submitted for review in a single
  // save. Treat that as a moderation state change from the implicit "draft"
  // starting point so the same notification fires as it would on a later
  // edit that makes the same transition.
  $already_notified_uids = [];
  if ($node->hasField('moderation_state')) {
    $new_state = $node->get('moderation_state')->value;
    if ($new_state !== 'draft') {
      $already_notified_uids = mukurtu_notifications_handle_moderation_change($node, 'draft', $new_state);
    }
  }

  // Record the node insert event for all published nodes.
  if (!$node->isPublished()) {
    return;
  }

  // Skip re-notifying anyone about the generic "was created" message who
  // already got a moderation-state notification for this same save (e.g.
  // "was published") -- but community managers who didn't (e.g.
  // mukurtu_notifications_handle_moderation_change() has no path that
  // reaches them) still need the "was created" message.
  mukurtu_notifications_notify_content_created($node, $already_notified_uids);
}

/**
 * Implements hook_node_update().
 */
function mukurtu_notifications_node_update(Node $node) {
  // Handle content moderation state changes regardless of published status.
  $moderation_state_changed = FALSE;
  if ($node->hasField('moderation_state') && isset($node->original)) {
    $old_state = $node->original->get('moderation_state')->value;
    $new_state = $node->get('moderation_state')->value;
    if ($old_state !== $new_state) {
      $moderation_state_changed = TRUE;
      mukurtu_notifications_handle_moderation_change($node, $old_state, $new_state);
    }
  }

  // Don't record events or send notifications for unpublished nodes.
  if (!$node->isPublished()) {
    return;
  }

  // Skip the generic "content updated" notification when a moderation state
  // change already sent its own notification for this same save (e.g.
  // "content published") -- otherwise both fire for the one save.
  if (!$moderation_state_changed) {
    $current_user_id = (int) \Drupal::currentUser()->id();
    $owner_id = (int) $node->getOwnerId();

    // Always record the update in the owner's feed. Protocol stewards are
    // added too, but only when someone other than the owner made the edit --
    // self-edits don't need steward attention. The shared helper skips
    // emailing the editor about their own action either way.
    $notify_uids = $owner_id > 0 ? [$owner_id] : [];
    if ($current_user_id !== $owner_id && $node instanceof CulturalProtocolControlledInterface) {
      $protocol_ids = $node->getProtocols();
      if (!empty($protocol_ids)) {
        $notify_uids = array_merge($notify_uids, mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node)));
      }
    }
    $notify_uids = array_values(array_unique($notify_uids));

    _mukurtu_notifications_notify('mukurtu_single_node_update', [
      'field_item' => $node,
      'field_user' => $current_user_id,
    ] + _mukurtu_notifications_node_snapshot_fields($node), $notify_uids, $current_user_id);
  }

  // Check for a newly-added protocol/community association.
  mukurtu_notifications_notify_content_created($node);
}

/**
 * Notifies the owner and any relevant protocol stewards/community managers
 * when content is created, or when a protocol/community is newly associated
 * with existing content via a later edit.
 *
 * Replaces the old separate mukurtu_new_item_in_protocol/_community
 * templates and triggers: those only fired on the "added via edit" case and
 * missed content that already had a protocol/community set at creation
 * time, and never notified the owner. Reuses the existing
 * mukurtu_single_node_insert template/text ("[content-type] [title] was
 * created.") for both cases -- the message itself doesn't need to name the
 * specific protocol/community.
 *
 * On update, only fires when a protocol/community was newly added (diffed
 * against $node->original) -- editing already-tagged content doesn't
 * re-notify; the separate "Content updated" notification already covers
 * generic edits.
 *
 * @param int[] $already_notified_uids
 *   Uids to exclude from the recipient list -- used on insert to pass the
 *   uids mukurtu_notifications_handle_moderation_change() already notified
 *   for this same save (e.g. a new node saved directly as "published"), so
 *   anyone in that set isn't double-emailed here even if they'd otherwise
 *   also qualify as a community manager.
 */
function mukurtu_notifications_notify_content_created(Node $node, array $already_notified_uids = []): void {
  $is_update = isset($node->original);

  $new_protocol_ids = [];
  $new_community_ids = [];

  if ($node instanceof CulturalProtocolControlledInterface) {
    $current_protocol_ids = $node->getProtocols();
    $old_protocol_ids = ($is_update && $node->original instanceof CulturalProtocolControlledInterface)
      ? $node->original->getProtocols()
      : [];
    $new_protocol_ids = array_diff($current_protocol_ids, $old_protocol_ids);

    $current_community_ids = array_keys($node->getCommunities());
    $old_community_ids = ($is_update && $node->original instanceof CulturalProtocolControlledInterface)
      ? array_keys($node->original->getCommunities())
      : [];
    $new_community_ids = array_diff($current_community_ids, $old_community_ids);
  }

  // On update, only fire for a newly-added protocol/community; on insert,
  // always fire (at minimum, to notify the owner, unless already notified).
  if ($is_update && empty($new_protocol_ids) && empty($new_community_ids)) {
    return;
  }

  $owner_id = (int) $node->getOwnerId();
  $recipient_uids = $owner_id > 0 ? [$owner_id] : [];

  if (!empty($new_protocol_ids)) {
    $recipient_uids = array_merge($recipient_uids, mukurtu_notifications_resolve_notify_groups(FALSE, [], $new_protocol_ids, _mukurtu_notifications_protocol_steward_roles($node)));
  }
  if (!empty($new_community_ids)) {
    $recipient_uids = array_merge($recipient_uids, mukurtu_notifications_resolve_notify_groups(FALSE, $new_community_ids, []));
  }
  $recipient_uids = array_values(array_diff(array_unique($recipient_uids), $already_notified_uids));

  if (empty($recipient_uids)) {
    return;
  }

  $actor_uid = (int) \Drupal::currentUser()->id();
  _mukurtu_notifications_notify('mukurtu_single_node_insert', [
    'field_item' => $node,
    'field_user' => $actor_uid,
  ], $recipient_uids, $actor_uid);
}

/**
 * Deletes all messages of a given template that reference a specific entity.
 *
 * @param string $template
 *   The message template machine name.
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity whose messages should be removed.
 * @param string $field
 *   The field name on the message that references the entity. Defaults to
 *   'field_item'.
 */
function mukurtu_notifications_remove_notifications($template, $entity, $field = 'field_item') {
  // Find notifications for the given template that reference the entity.
  $query = \Drupal::entityQuery('message')
    ->condition('template', $template)
    ->condition($field, $entity->id())
    ->accessCheck(FALSE);
  $results = $query->execute();

  $messages = Message::loadMultiple($results);

  if (!empty($messages)) {
    foreach ($messages as $message) {
      $message->delete();
    }
  }
}

/**
 * Implements hook_node_delete().
 */
function mukurtu_notifications_node_delete(Node $node) {
  // Remove any old notifications for the deleted node.
  mukurtu_notifications_remove_notifications('mukurtu_single_node_insert', $node);
  mukurtu_notifications_remove_notifications('mukurtu_single_node_update', $node);

  // Notify the owner and any relevant protocol stewards/community managers.
  $owner_id = (int) $node->getOwnerId();
  $recipient_uids = $owner_id > 0 ? [$owner_id] : [];

  if ($node instanceof CulturalProtocolControlledInterface) {
    $protocol_ids = $node->getProtocols();
    if (!empty($protocol_ids)) {
      $recipient_uids = array_merge($recipient_uids, mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node)));
    }
    $community_ids = array_keys($node->getCommunities());
    if (!empty($community_ids)) {
      $recipient_uids = array_merge($recipient_uids, mukurtu_notifications_resolve_notify_groups(FALSE, $community_ids, []));
    }
  }
  $recipient_uids = array_values(array_unique($recipient_uids));

  $actor_uid = (int) \Drupal::currentUser()->id();

  // field_title/field_content_type are plain strings, not entity
  // references, since the node is gone by the time this is viewed.
  _mukurtu_notifications_notify('mukurtu_single_node_delete', [
    'field_title' => $node->getTitle(),
    'field_content_type' => \Drupal::token()->replace('[node:type-name]', ['node' => $node]),
    'field_user' => $actor_uid,
  ], $recipient_uids, $actor_uid);
}

/**
 * Implements hook_ENTITY_TYPE_insert().
 */
function mukurtu_notifications_user_insert($entity) {
  // Only want to send notifications for users that
  // require action to be unblocked.
  if ($entity->isActive()) {
    return;
  }

  // Only reachable via visitor self-registration under admin approval; if
  // user.settings:register is 'admin_only' (the default), self-registration
  // is disabled and this never fires. Site admins commonly enable it
  // post-install, so this isn't dead code.

  // Mukurtu managers can opt out of "User account" category emails via
  // their own notification preferences; the in-app feed record is
  // unconditional.
  $manager_uids = mukurtu_notifications_resolve_notify_groups(TRUE, [], []);

  _mukurtu_notifications_notify('mukurtu_new_user_registration', [
    'field_user' => $entity,
  ], $manager_uids);

  // Visitor self-registration immediately follows this insert with a second,
  // update save that sets field_pending -- see
  // mukurtu_core\Hook\FormHooks::visitorRegistrationPendingSubmit(). Flag
  // this uid so mukurtu_notifications_user_update() can skip the resulting
  // "User set to pending" notification, which would otherwise duplicate the
  // registration notice just sent above for the same real-world event.
  $recent_registrations = &_mukurtu_notifications_recent_registrations();
  $recent_registrations[$entity->id()] = TRUE;
}

/**
 * Request-scoped set of uids that just received a new-registration
 * notification, keyed by uid.
 *
 * @return array<int, bool>
 *   Reference to the static storage.
 */
function &_mukurtu_notifications_recent_registrations(): array {
  $storage = &drupal_static(__FUNCTION__, []);
  return $storage;
}

/**
 * Sends notifications to Mukurtu managers and selected users when a new
 * account is created.
 *
 * Mukurtu managers are unconditional recipients; $notify_uids are additional
 * recipients selected via the account-creation form.
 *
 * @param \Drupal\user\Entity\User $new_user
 *   The newly created user entity.
 * @param array $notify_uids
 *   Array of user IDs to notify.
 */
function mukurtu_notifications_notify_new_account_created(User $new_user, array $notify_uids): void {
  $manager_uids = mukurtu_notifications_resolve_notify_groups(TRUE, [], []);
  $recipient_uids = array_values(array_unique(array_merge($manager_uids, $notify_uids)));

  _mukurtu_notifications_notify('mukurtu_new_user_account_created', [
    'field_user' => $new_user,
  ], $recipient_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Notifies Mukurtu managers and Roundtrip managers when a batch import
 * finishes.
 *
 * @param int $count
 *   The number of items imported.
 * @param string $results_summary
 *   Rendered HTML summarizing the per-migration results and any error
 *   messages from the run, stored on field_import_results so the "View
 *   batch import report" link (built from the resulting message's ID, see
 *   mukurtu_import.batch_report) has real per-batch content to show,
 *   instead of the dead /import/report/[message:mid] link this replaced.
 */
function mukurtu_notifications_notify_batch_import_report(int $count, string $results_summary = ''): void {
  $manager_uids = mukurtu_notifications_resolve_notify_groups(TRUE, [], []);
  $roundtrip_uids = \Drupal::entityQuery('user')
    ->condition('roles', 'mukurtu_roundtrip_manager')
    ->accessCheck(FALSE)
    ->execute();
  $recipient_uids = array_values(array_unique(array_merge($manager_uids, array_values($roundtrip_uids))));

  _mukurtu_notifications_notify('mukurtu_batch_import_report', [
    'field_number_imported' => $count,
    'field_import_results' => [
      'value' => $results_summary,
      'format' => 'mukurtu_html',
    ],
  ], $recipient_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Returns the account state implied by a user's status/field_pending values.
 *
 * Accounts are one of three states: 'active' (status=1), 'pending'
 * (status=0, field_pending=1), or 'blocked' (status=0, field_pending=0) --
 * see mukurtu_core.install:706 for how field_pending distinguishes pending
 * from blocked.
 */
function _mukurtu_notifications_user_account_state(bool $status, bool $pending): string {
  if ($status) {
    return 'active';
  }
  return $pending ? 'pending' : 'blocked';
}

/**
 * Implements hook_ENTITY_TYPE_update() for user.
 *
 * Notifies Mukurtu managers when an account's approval state changes:
 * pending->active (approved), any->pending (set pending), blocked->active
 * (unblocked), or active/pending->blocked (blocked).
 */
function mukurtu_notifications_user_update($account) {
  if (!isset($account->original)) {
    return;
  }

  $old_state = _mukurtu_notifications_user_account_state(
    (bool) $account->original->get('status')->value,
    $account->original->hasField('field_pending') ? (bool) $account->original->get('field_pending')->value : FALSE
  );
  $new_state = _mukurtu_notifications_user_account_state(
    (bool) $account->get('status')->value,
    $account->hasField('field_pending') ? (bool) $account->get('field_pending')->value : FALSE
  );

  if ($old_state === $new_state) {
    return;
  }

  $template = match (TRUE) {
    $old_state === 'pending' && $new_state === 'active' => 'mukurtu_user_approved',
    $new_state === 'pending' => 'mukurtu_user_set_pending',
    $old_state === 'blocked' && $new_state === 'active' => 'mukurtu_user_unblocked',
    $new_state === 'blocked' => 'mukurtu_user_blocked',
    default => NULL,
  };

  if (!$template) {
    return;
  }

  if ($template === 'mukurtu_user_set_pending') {
    $recent_registrations = &_mukurtu_notifications_recent_registrations();
    if (!empty($recent_registrations[$account->id()])) {
      unset($recent_registrations[$account->id()]);
      return;
    }
  }

  $manager_uids = mukurtu_notifications_resolve_notify_groups(TRUE, [], []);
  _mukurtu_notifications_notify($template, [
    'field_user' => $account->id(),
  ], $manager_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_ENTITY_TYPE_delete() for user.
 *
 * Notifies Mukurtu managers when a user account is deleted. field_title
 * (a plain string, reused from mukurtu_single_node_delete's pattern) stores
 * the deleted user's display name, since the user entity itself won't be
 * loadable when the message is later viewed.
 */
function mukurtu_notifications_user_delete($account) {
  $display_name = $account->hasField('field_display_name') && !$account->get('field_display_name')->isEmpty()
    ? $account->get('field_display_name')->value
    : $account->getAccountName();

  $manager_uids = mukurtu_notifications_resolve_notify_groups(TRUE, [], []);
  _mukurtu_notifications_notify('mukurtu_user_deleted', [
    'field_title' => $display_name,
  ], $manager_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_cron().
 *
 * Note that Drupal 11.x does not yet support cron implementations using
 * classes/services. See https://www.drupal.org/project/drupal/issues/3383487.
 */
function mukurtu_notifications_cron() {
  mukurtu_notifications_process_digest('daily', 86400);
  mukurtu_notifications_process_digest('weekly', 604800);
}

/**
 * Sends batched digest emails to users with the given frequency preference.
 *
 * Only runs once the interval has elapsed since its last run (tracked via
 * State, matching mukurtu_local_contexts_cron()'s pattern). For each user
 * with pending digest messages, sends one email listing all of them (each
 * rendered via its existing 'mail_subject' view mode -- no new per-template
 * rendering logic needed) and clears field_digest_pending on all of them,
 * whether or not the send succeeded (best-effort, matching how immediate
 * sends already just log and swallow failures without retrying).
 *
 * @param string $frequency
 *   'daily' or 'weekly', matching field_notify_frequency's allowed values.
 * @param int $interval
 *   Minimum seconds between runs for this frequency.
 */
function mukurtu_notifications_process_digest(string $frequency, int $interval): void {
  $state = \Drupal::state();
  $now = \Drupal::time()->getCurrentTime();
  $last_run = (int) $state->get('mukurtu_notifications.digest_last_run.' . $frequency, 0);

  if ($now - $last_run < $interval) {
    return;
  }
  $state->set('mukurtu_notifications.digest_last_run.' . $frequency, $now);

  $uids = \Drupal::entityQuery('user')
    ->condition('field_notify_frequency', $frequency)
    ->accessCheck(FALSE)
    ->execute();

  if (empty($uids)) {
    return;
  }

  $site_name = \Drupal::config('system.site')->get('name');
  $frequency_label = ucfirst($frequency);
  $view_builder = \Drupal::entityTypeManager()->getViewBuilder('message');
  $renderer = \Drupal::service('renderer');
  $mail_manager = \Drupal::service('plugin.manager.mail');

  foreach (User::loadMultiple($uids) as $uid => $user) {
    $mids = \Drupal::entityQuery('message')
      ->condition('uid', $uid)
      ->condition('field_digest_pending', TRUE)
      ->accessCheck(FALSE)
      ->execute();

    if (empty($mids)) {
      continue;
    }

    $messages = Message::loadMultiple($mids);
    $email = $user->getEmail();

    if (!empty($email)) {
      $items = [];
      foreach ($messages as $message) {
        $build = $view_builder->view($message, 'mail_subject');
        $items[] = (string) $renderer->renderInIsolation($build);
      }

      $body = [
        '#theme' => 'item_list',
        '#items' => $items,
        '#prefix' => '<p>Recent activity:</p>',
      ];

      $params = [
        'subject' => "Your {$frequency_label} {$site_name} digest",
        'body' => $renderer->renderInIsolation($body),
      ];

      try {
        $mail_manager->mail('mukurtu_notifications', 'digest', $email, $user->getPreferredLangcode(), $params);
      }
      catch (\Exception $e) {
        \Drupal::logger('mukurtu_notifications')->warning('Failed to send @frequency digest to uid @uid: @msg', ['@frequency' => $frequency, '@uid' => $uid, '@msg' => $e->getMessage()]);
      }
    }

    foreach ($messages as $message) {
      $message->set('field_digest_pending', FALSE);
      $message->save();
    }
  }
}

/**
 * Implements hook_mail().
 */
function mukurtu_notifications_mail($key, &$message, $params) {
  if ($key !== 'digest') {
    return;
  }
  $message['subject'] = $params['subject'];
  $message['body'][] = $params['body'];
}

/**
 * Resolves group-based notification selections to an array of user IDs.
 *
 * @param bool $all_managers
 *   If TRUE, include all users with the administrator or mukurtu_manager role.
 * @param array $community_ids
 *   Entity IDs of communities whose community managers should be notified.
 * @param array $protocol_ids
 *   Entity IDs of protocols whose protocol stewards should be notified.
 * @param string[] $protocol_roles
 *   The protocol OG role(s) to resolve for $protocol_ids. Defaults to
 *   protocol stewards only; pass the result of
 *   _mukurtu_notifications_protocol_steward_roles() to also include
 *   language stewards for dictionary word/word list content.
 *
 * @return array
 *   Unique array of integer user IDs.
 */
function mukurtu_notifications_resolve_notify_groups(bool $all_managers, array $community_ids, array $protocol_ids, array $protocol_roles = ['protocol-protocol-protocol_steward']): array {
  $uids = [];

  if ($all_managers) {
    $manager_uids = \Drupal::entityQuery('user')
      ->condition('roles', ['administrator', 'mukurtu_manager'], 'IN')
      ->condition('status', 1)
      ->accessCheck(FALSE)
      ->execute();
    $uids = array_merge($uids, array_values($manager_uids));
  }

  if (!empty($community_ids)) {
    $memberships = \Drupal::entityQuery('og_membership')
      ->condition('entity_type', 'community')
      ->condition('entity_id', $community_ids, 'IN')
      ->condition('roles', 'community-community-community_manager')
      ->condition('state', 'active')
      ->accessCheck(FALSE)
      ->execute();
    $loaded = \Drupal::entityTypeManager()->getStorage('og_membership')->loadMultiple($memberships);
    foreach ($loaded as $m) {
      $uids[] = (int) $m->getOwnerId();
    }
  }

  if (!empty($protocol_ids)) {
    $memberships = \Drupal::entityQuery('og_membership')
      ->condition('entity_type', 'protocol')
      ->condition('entity_id', $protocol_ids, 'IN')
      ->condition('roles', $protocol_roles, 'IN')
      ->condition('state', 'active')
      ->accessCheck(FALSE)
      ->execute();
    $loaded = \Drupal::entityTypeManager()->getStorage('og_membership')->loadMultiple($memberships);
    foreach ($loaded as $m) {
      $uids[] = (int) $m->getOwnerId();
    }
  }

  return array_values(array_unique($uids));
}

/**
 * Returns the protocol OG roles that should be notified about a node.
 *
 * Language stewards manage dictionary words and word lists specifically
 * (see config/install/og.og_role.protocol-protocol-language_steward.yml)
 * and should get the same content notifications as protocol stewards, but
 * only for those two bundles -- not all content types.
 *
 * @param \Drupal\node\Entity\Node $node
 *   The node the notification is about.
 *
 * @return string[]
 *   Protocol OG role machine names to resolve.
 */
function _mukurtu_notifications_protocol_steward_roles(Node $node): array {
  $roles = ['protocol-protocol-protocol_steward'];
  if (in_array($node->bundle(), ['dictionary_word', 'word_list'], TRUE)) {
    $roles[] = 'protocol-protocol-language_steward';
  }
  return $roles;
}

/**
 * Extracts and resolves all notify UIDs from the shared notify form section.
 *
 * Reads notify_user_count, notify_users, notify_all_managers,
 * notify_communities, and notify_protocols from form state, then delegates
 * to mukurtu_notifications_resolve_notify_groups for group-based selections.
 *
 * @param \Drupal\Core\Form\FormStateInterface $form_state
 *   The form state from a form that includes the shared notify section.
 *
 * @return array
 *   Unique array of integer user IDs to notify.
 */
function mukurtu_notifications_extract_notify_uids(FormStateInterface $form_state): array {
  $notifyUids = [];
  $notifyUserCount = $form_state->get('notify_user_count') ?? 1;
  for ($i = 0; $i < $notifyUserCount; $i++) {
    $uid = $form_state->getValue(['notify_users', 'user_' . $i]);
    if (!empty($uid)) {
      $notifyUids[] = (int) $uid;
    }
  }

  $allManagers = (bool) $form_state->getValue('notify_all_managers');
  $communityIds = array_keys(array_filter($form_state->getValue('notify_communities') ?? []));
  $protocolIds = [];
  foreach ($form_state->getValue('notify_protocols') ?? [] as $groupValues) {
    if (is_array($groupValues)) {
      $protocolIds = array_merge($protocolIds, array_keys(array_filter($groupValues)));
    }
  }
  $protocolIds = array_unique($protocolIds);

  $groupUids = mukurtu_notifications_resolve_notify_groups($allManagers, $communityIds, $protocolIds);
  return array_values(array_unique(array_merge($notifyUids, $groupUids)));
}

/**
 * Builds the plain-text title/content-type snapshot fields shared by
 * templates that reference content via field_item, so old notifications
 * still show a title after the referenced node is deleted -- see
 * mukurtu_notifications_tokens()'s "mukurtu-content-link" token, which reads
 * these back as its fallback when field_item's target no longer loads.
 *
 * @return array{field_title: string, field_content_type: string}
 */
function _mukurtu_notifications_node_snapshot_fields(Node $node): array {
  return [
    'field_title' => $node->getTitle(),
    'field_content_type' => \Drupal::token()->replace('[node:type-name]', ['node' => $node]),
  ];
}

/**
 * Records and dispatches a notification when content moderation state changes.
 *
 * @param \Drupal\node\Entity\Node $node
 *   The node whose state changed.
 * @param string|null $old_state
 *   The previous moderation state machine name, or NULL if the field wasn't
 *   yet populated (e.g. a node saved before its bundle had the field).
 * @param string|null $new_state
 *   The new moderation state machine name, or NULL if the field isn't
 *   populated yet (e.g. a programmatically-created node that hasn't been
 *   through the moderation form).
 *
 * @return int[]
 *   The uids actually notified, or an empty array if no notification was
 *   sent -- used by mukurtu_notifications_node_insert() to keep
 *   mukurtu_notifications_notify_content_created() from double-notifying
 *   anyone who already got a moderation-state message for this same save.
 */
function mukurtu_notifications_handle_moderation_change(Node $node, ?string $old_state, ?string $new_state): array {
  if ($new_state === NULL) {
    return [];
  }

  $current_user_id = (int) \Drupal::currentUser()->id();
  $owner_id = (int) $node->getOwnerId();
  $template = NULL;

  switch ($new_state) {
    case 'needs_review':
      $template = 'mukurtu_content_for_review';
      break;

    case 'published':
      $template = 'mukurtu_content_published';
      break;

    case 'archived':
      $template = 'mukurtu_content_archived';
      break;

    case 'draft':
      // Only notify on reversion from a non-draft state.
      if (!in_array($old_state, ['needs_review', 'published', 'archived'])) {
        return [];
      }
      $template = 'mukurtu_content_to_draft';
      break;

    default:
      return [];
  }

  $notify_uids = $owner_id > 0 ? [$owner_id] : [];
  if ($node instanceof CulturalProtocolControlledInterface) {
    $protocol_ids = $node->getProtocols();
    if (!empty($protocol_ids)) {
      $notify_uids = array_merge($notify_uids, mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node)));
    }
  }
  $notify_uids = array_values(array_unique($notify_uids));

  $field_values = [
    'field_item' => $node,
    'field_user' => $current_user_id,
  ] + _mukurtu_notifications_node_snapshot_fields($node);

  // A contributor submitting their own content for review wants a
  // confirmation that it went through, unlike an ordinary self-edit -- so
  // the owner's copy of this specific template isn't subject to the usual
  // "don't email people about their own action" exclusion. Actor uid 0
  // excludes no one, per _mukurtu_notifications_notify()'s contract.
  if ($template === 'mukurtu_content_for_review' && $owner_id > 0 && $owner_id === $current_user_id) {
    _mukurtu_notifications_notify($template, $field_values, [$owner_id], 0);
    $other_uids = array_values(array_diff($notify_uids, [$owner_id]));
    _mukurtu_notifications_notify($template, $field_values, $other_uids, $current_user_id);
    return $notify_uids;
  }

  _mukurtu_notifications_notify($template, $field_values, $notify_uids, $current_user_id);
  return $notify_uids;
}

/**
 * Implements hook_comment_insert().
 */
function mukurtu_notifications_comment_insert(CommentInterface $comment) {
  $node = $comment->getCommentedEntity();
  if (!($node instanceof Node)) {
    return;
  }
  if (!$node instanceof CulturalProtocolControlledInterface) {
    return;
  }
  $protocol_ids = $node->getProtocols();
  if (empty($protocol_ids)) {
    return;
  }

  $current_user_id = (int) \Drupal::currentUser()->id();
  $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node));
  $notify_uids = array_values(array_unique(array_merge([$current_user_id], $steward_uids)));

  // A comment that requires approval hasn't actually "been posted" yet from
  // readers' perspective -- use the pending-review wording so stewards know
  // it needs their action, matching mukurtu_comment_approved/_denied's use
  // of publish state as the same signal elsewhere in this file.
  $template = $comment->isPublished() ? 'mukurtu_protocol_comment' : 'mukurtu_protocol_comment_pending';

  _mukurtu_notifications_notify($template, [
    'field_item' => $node,
    'field_user' => $current_user_id,
  ] + _mukurtu_notifications_node_snapshot_fields($node), $notify_uids, $current_user_id);
}

/**
 * Implements hook_ENTITY_TYPE_update() for comment.
 *
 * Notifies the commenter and protocol stewards when a pending comment is
 * approved (transitions from unpublished to published).
 */
function mukurtu_notifications_comment_update(CommentInterface $comment) {
  if (!isset($comment->original) || $comment->original->isPublished() || !$comment->isPublished()) {
    return;
  }

  $node = $comment->getCommentedEntity();
  if (!($node instanceof Node) || !($node instanceof CulturalProtocolControlledInterface)) {
    return;
  }
  $protocol_ids = $node->getProtocols();
  if (empty($protocol_ids)) {
    return;
  }

  $commenter_uid = (int) $comment->getOwnerId();
  $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node));
  $notify_uids = array_values(array_unique(array_merge([$commenter_uid], $steward_uids)));

  _mukurtu_notifications_notify('mukurtu_comment_approved', [
    'field_item' => $node,
    'field_user' => $commenter_uid,
  ] + _mukurtu_notifications_node_snapshot_fields($node), $notify_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_ENTITY_TYPE_delete() for comment.
 *
 * Notifies the commenter and protocol stewards when a pending (unpublished)
 * comment is denied by deletion.
 */
function mukurtu_notifications_comment_delete(CommentInterface $comment) {
  if ($comment->isPublished()) {
    return;
  }

  $node = $comment->getCommentedEntity();
  if (!($node instanceof Node) || !($node instanceof CulturalProtocolControlledInterface)) {
    return;
  }
  $protocol_ids = $node->getProtocols();
  if (empty($protocol_ids)) {
    return;
  }

  $commenter_uid = (int) $comment->getOwnerId();
  $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids, _mukurtu_notifications_protocol_steward_roles($node));
  $notify_uids = array_values(array_unique(array_merge([$commenter_uid], $steward_uids)));

  _mukurtu_notifications_notify('mukurtu_comment_denied', [
    'field_item' => $node,
    'field_user' => $commenter_uid,
  ] + _mukurtu_notifications_node_snapshot_fields($node), $notify_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_og_membership_insert().
 */
function mukurtu_notifications_og_membership_insert(OgMembership $membership) {
  $group = $membership->getGroup();
  if (!$group) {
    return;
  }

  $group_entity_type = $membership->getGroupEntityType();
  $added_user = $membership->getOwner();
  if (!$added_user || $added_user->id() == 0) {
    return;
  }

  $added_uid = (int) $added_user->id();
  $field_values = ['field_user' => $added_uid];

  if ($group_entity_type === 'community') {
    $template = 'mukurtu_user_added_to_community';
    $field_values['field_community_ref'] = (int) $group->id();
    $group_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [$group->id()], []);
  }
  elseif ($group_entity_type === 'protocol') {
    $template = 'mukurtu_user_added_to_protocol';
    $field_values['field_protocol'] = (int) $group->id();
    $group_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], [$group->id()]);
  }
  else {
    return;
  }

  $recipient_uids = array_values(array_unique(array_merge([$added_uid], $group_uids)));

  // The added user is a recipient, so their own feed shows "you were added"
  // -- the message's uid for their copy must be the added user, not the
  // actor who added them (the shared helper handles this per recipient).
  _mukurtu_notifications_notify($template, $field_values, $recipient_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_og_membership_delete().
 *
 * Mirrors mukurtu_notifications_og_membership_insert() for removals.
 */
function mukurtu_notifications_og_membership_delete(OgMembership $membership) {
  $group = $membership->getGroup();
  if (!$group) {
    return;
  }

  $group_entity_type = $membership->getGroupEntityType();
  $removed_user = $membership->getOwner();
  if (!$removed_user || $removed_user->id() == 0) {
    return;
  }

  $removed_uid = (int) $removed_user->id();
  $field_values = ['field_user' => $removed_uid];
  if ($group_entity_type === 'community') {
    $template = 'mukurtu_removed_from_community';
    $field_values['field_community_ref'] = (int) $group->id();
    $group_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [$group->id()], []);
  }
  elseif ($group_entity_type === 'protocol') {
    $template = 'mukurtu_removed_from_protocol';
    $field_values['field_protocol'] = (int) $group->id();
    $group_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], [$group->id()]);
  }
  else {
    return;
  }

  $recipient_uids = array_values(array_unique(array_merge([$removed_uid], $group_uids)));

  _mukurtu_notifications_notify($template, $field_values, $recipient_uids, (int) \Drupal::currentUser()->id());
}

/**
 * Implements hook_module_implements_alter().
 *
 * Moves mukurtu_notifications_node_insert() to run after
 * pathauto_entity_insert(). A brand-new node can be created and submitted
 * for review in the same save (see mukurtu_notifications_node_insert()'s own
 * comment on this), which sends a mukurtu_content_for_review notification
 * containing a link built from $node->toUrl(). hook_node_insert() otherwise
 * runs before Pathauto's hook_entity_insert() creates the URL alias, so that
 * link would permanently bake in the not-yet-aliased /node/{id} path instead
 * of the friendly URL. Scoped to node_insert only so other hooks this module
 * implements aren't affected.
 */
function mukurtu_notifications_module_implements_alter(&$implementations, $hook): void {
  if ($hook !== 'node_insert' || !isset($implementations['mukurtu_notifications'], $implementations['pathauto'])) {
    return;
  }
  $group = $implementations['mukurtu_notifications'];
  unset($implementations['mukurtu_notifications']);
  $implementations['mukurtu_notifications'] = $group;
}

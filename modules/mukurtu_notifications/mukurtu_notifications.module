/**
 * Sends notifications to collection followers when new items are added.
 *
 * @param \Drupal\node\Entity\Node $node
 *   The node being updated (must be a Collection).
 * @param \Drupal\message_subscribe\SubscribersInterface $subscribers
 *   The message_subscribe service.
 */
function mukurtu_notifications_notify_collection(Node $node, $subscribers) {
  // Only handling existing collections here.
  if (!($node instanceof Collection) || !isset($node->original)) {
    return;
  }

  // Check if there are any new items in the collection.
  $currentItems = mukurtu_core_flatten_entity_ref_field($node, MUKURTU_COLLECTION_FIELD_NAME_ITEMS);
  $oldItems = mukurtu_core_flatten_entity_ref_field($node->original, MUKURTU_COLLECTION_FIELD_NAME_ITEMS);
  $newItems = array_diff($currentItems, $oldItems);

  if (empty($newItems)) {
    return;
  }

  $message = Message::create([
    'template' => 'mukurtu_new_item_in_collection',
    'uid' => $node->getOwnerId(),
  ]);
  $message->set('field_collection', $node);
  $message->set('field_item', array_values($newItems));
  $message->save();

  try {
    $subscribers->sendMessage($node, $message);
  }
  catch (\Exception $e) {
    \Drupal::logger('mukurtu_notifications')->warning('Failed to send collection notification: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Records and dispatches a notification when content moderation state changes.
 *
 * @param \Drupal\node\Entity\Node $node
 *   The node whose state changed.
 * @param string $old_state
 *   The previous moderation state machine name.
 * @param string $new_state
 *   The new moderation state machine name.
 */
function mukurtu_notifications_handle_moderation_change(Node $node, string $old_state, string $new_state): void {
  $current_user_id = (int) \Drupal::currentUser()->id();
  $template = NULL;
  $notify_uids = [];

  switch ($new_state) {
    case 'needs_review':
      $template = 'mukurtu_content_for_review';
      if ($node->hasField('field_cultural_protocols')) {
        $protocol_ids = $node->getProtocols();
        if (!empty($protocol_ids)) {
          $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids);
          $notify_uids = array_values(array_unique(array_diff($steward_uids, [$current_user_id])));
        }
      }
      break;

    case 'published':
      $template = 'mukurtu_content_published';
      $owner_id = (int) $node->getOwnerId();
      if ($owner_id > 0 && $owner_id !== $current_user_id) {
        $notify_uids = [$owner_id];
      }
      break;

    case 'archived':
      $template = 'mukurtu_content_archived';
      $owner_id = (int) $node->getOwnerId();
      if ($owner_id > 0 && $owner_id !== $current_user_id) {
        $notify_uids = [$owner_id];
      }
      break;

    case 'draft':
      // Only notify on reversion from a non-draft state.
      if (!in_array($old_state, ['needs_review', 'published', 'archived'])) {
        return;
      }
      $template = 'mukurtu_content_to_draft';
      $owner_id = (int) $node->getOwnerId();
      if ($owner_id > 0 && $owner_id !== $current_user_id) {
        $notify_uids = [$owner_id];
      }
      break;

    default:
      return;
  }

  if (!$template) {
    return;
  }

  $message = Message::create([
    'template' => $template,
    'uid' => $node->getOwnerId(),
  ]);
  $message->set('field_item', $node);
  $message->set('field_user', $current_user_id);
  $message->save();

  if (empty($notify_uids)) {
    return;
  }

  $subscribe_options = [
    'notify message owner' => FALSE,
    'uids' => [],
  ];
  $email_validator = \Drupal::service('email.validator');
  $recipients = User::loadMultiple($notify_uids);
  foreach ($recipients as $uid => $recipient) {
    if (!$email_validator->isValid($recipient->getEmail())) {
      continue;
    }
    $subscribe_options['uids'][$uid] = new DeliveryCandidate(['subscribe_node'], ['email'], $uid);
  }

  if (!empty($subscribe_options['uids'])) {
    try {
      \Drupal::service('message_subscribe.subscribers')->sendMessage($message, $message, [], $subscribe_options);
    }
    catch (\Exception $e) {
      \Drupal::logger('mukurtu_notifications')->warning('Failed to send moderation notification: @msg', ['@msg' => $e->getMessage()]);
    }
  }
}

/**
 * Implements hook_comment_insert().
 */
function mukurtu_notifications_comment_insert(CommentInterface $comment) {
  $node = $comment->getCommentedEntity();
  if (!($node instanceof Node)) {
    return;
  }
  if (!$node->hasField('field_cultural_protocols')) {
    return;
  }
  $protocol_ids = $node->getProtocols();
  if (empty($protocol_ids)) {
    return;
  }

  $current_user_id = (int) \Drupal::currentUser()->id();
  $steward_uids = mukurtu_notifications_resolve_notify_groups(FALSE, [], $protocol_ids);
  $notify_uids = array_values(array_unique(array_diff($steward_uids, [$current_user_id])));

  $message = Message::create([
    'template' => 'mukurtu_protocol_comment',
    'uid' => $current_user_id,
  ]);
  $message->set('field_item', $node);
  $message->set('field_user', $current_user_id);
  $message->save();

  if (empty($notify_uids)) {
    return;
  }

  $subscribe_options = [
    'notify message owner' => FALSE,
    'uids' => [],
  ];
  $email_validator = \Drupal::service('email.validator');
  $recipients = User::loadMultiple($notify_uids);
  foreach ($recipients as $uid => $recipient) {
    if (!$email_validator->isValid($recipient->getEmail())) {
      continue;
    }
    $subscribe_options['uids'][$uid] = new DeliveryCandidate(['subscribe_node'], ['email'], $uid);
  }

  if (!empty($subscribe_options['uids'])) {
    try {
      \Drupal::service('message_subscribe.subscribers')->sendMessage($message, $message, [], $subscribe_options);
    }
    catch (\Exception $e) {
      \Drupal::logger('mukurtu_notifications')->warning('Failed to send comment notification: @msg', ['@msg' => $e->getMessage()]);
    }
  }
}

/**
 * Implements hook_og_membership_insert().
 */
function mukurtu_notifications_og_membership_insert(OgMembership $membership) {
  $group = $membership->getGroup();
  if (!$group) {
    return;
  }

  $group_entity_type = $membership->getGroupEntityType();
  $added_user = $membership->getOwner();
  if (!$added_user || $added_user->id() == 0) {
    return;
  }

  if ($group_entity_type === 'community') {
    $template = 'mukurtu_user_added_to_community';
  }
  elseif ($group_entity_type === 'protocol') {
    $template = 'mukurtu_user_added_to_protocol';
  }
  else {
    return;
  }

  $current_user_id = (int) \Drupal::currentUser()->id();
  $message = Message::create([
    'template' => $template,
    'uid' => $current_user_id,
  ]);
  $message->set('field_user', (int) $added_user->id());
  if ($group_entity_type === 'community') {
    $message->set('field_community_ref', (int) $group->id());
  }
  else {
    $message->set('field_protocol', (int) $group->id());
  }
  $message->save();

  $email_validator = \Drupal::service('email.validator');
  if (!$email_validator->isValid($added_user->getEmail())) {
    return;
  }

  $added_uid = (int) $added_user->id();
  $subscribe_options = [
    'notify message owner' => FALSE,
    'uids' => [
      $added_uid => new DeliveryCandidate(['subscribe_node'], ['email'], $added_uid),
    ],
  ];

  try {
    \Drupal::service('message_subscribe.subscribers')->sendMessage($message, $message, [], $subscribe_options);
  }
  catch (\Exception $e) {
    \Drupal::logger('mukurtu_notifications')->warning('Failed to send membership notification: @msg', ['@msg' => $e->getMessage()]);
  }
}

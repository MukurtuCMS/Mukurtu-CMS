parameters:
  level: 0
  paths:
    - .
  excludePaths:
    # Drupal Console is deprecated and no longer maintained for Drupal 10+.
    # These commands use Drupal Console classes which are not available.
    - src/Command/GetValueCommand.php
    - src/Command/SetValueCommand.php
  ignoreErrors:
    # This is standard Drupal pattern for dependency injection.
    - '#Unsafe usage of new static\(\)#'

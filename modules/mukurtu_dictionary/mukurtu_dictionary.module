<?php

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\CloseModalDialogCommand;
use Drupal\Core\Ajax\RedirectCommand;
use Drupal\Core\Ajax\HtmlCommand;
use Drupal\Core\Ajax\InvokeCommand;
use Drupal\Core\Ajax\MessageCommand;
use Drupal\Core\Session\AccountInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\core\Entity\EntityTypeInterface;
use Drupal\Core\Field\FieldStorageDefinitionInterface;
use Drupal\mukurtu_core\BaseFieldDefinition;
use Drupal\mukurtu_dictionary\Entity\DictionaryWord;
use Drupal\mukurtu_dictionary\Entity\DictionaryWordEntry;
use Drupal\mukurtu_dictionary\Entity\SampleSentence;
use Drupal\mukurtu_dictionary\Entity\WordList;
use Drupal\Core\Form\FormStateInterface;
use Drupal\views\ViewExecutable;

/**
 * Implements hook_theme().
 */
function mukurtu_dictionary_theme($existing, $type, $theme, $path) {
  return [
    'mukurtu_dictionary_page' => [
      'variables' => [
        'list_results' => NULL,
        'map_results' => NULL,
        'glossary' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_views_post_execute().
 */
function mukurtu_dictionary_views_post_execute(ViewExecutable $view) {
  // Check if this view is using our custom glossary sort.
  if (!isset($view->glossary_weights) || !isset($view->glossary_field) || !isset($view->glossary_order)) {
    return;
  }

  $weights = $view->glossary_weights;
  $field = $view->glossary_field;
  $order = $view->glossary_order;

  // Get the maximum weight for unweighted entries.
  $max_weight = !empty($weights) ? max($weights) + 1 : PHP_INT_MAX;

  // Sort the results based on glossary weights.
  usort($view->result, function ($a, $b) use ($weights, $field, $order, $max_weight) {
    // Get the glossary entry value from each result row.
    $value_a = '';
    $value_b = '';

    // Try to get the field value from the search result.
    if (isset($a->_item) && method_exists($a->_item, 'getField')) {
      try {
        $field_obj = $a->_item->getField($field);
        if ($field_obj) {
          $values = $field_obj->getValues();
          $value_a = reset($values) ?: '';
        }
      }
      catch (\Exception $e) {
        // Field not available, continue with empty value.
      }
    }

    if (isset($b->_item) && method_exists($b->_item, 'getField')) {
      try {
        $field_obj = $b->_item->getField($field);
        if ($field_obj) {
          $values = $field_obj->getValues();
          $value_b = reset($values) ?: '';
        }
      }
      catch (\Exception $e) {
        // Field not available, continue with empty value.
      }
    }

    // Get weights for both values.
    $weight_a = $weights[$value_a] ?? $max_weight;
    $weight_b = $weights[$value_b] ?? $max_weight;

    // First compare by weight.
    if ($weight_a != $weight_b) {
      $comparison = $weight_a <=> $weight_b;
      return $order === 'DESC' ? -$comparison : $comparison;
    }

    // If weights are equal, use alphabetical comparison.
    return strnatcasecmp($value_a, $value_b);
  });
}

/**
 * Implements hook_entity_bundle_info_alter().
 */
function mukurtu_dictionary_entity_bundle_info_alter(array &$bundles): void {
  // Dictionary word bundle class.
  if (isset($bundles['node']['dictionary_word'])) {
    $bundles['node']['dictionary_word']['class'] = DictionaryWord::class;
  }

  // Word list bundle class.
  if (isset($bundles['node']['word_list'])) {
    $bundles['node']['word_list']['class'] = WordList::class;
  }

  // Dictionary Word Entry bundle class.
  if (isset($bundles['paragraph']['dictionary_word_entry'])) {
    $bundles['paragraph']['dictionary_word_entry']['class'] = DictionaryWordEntry::class;
  }

  // Sample sentences bundle class.
  if (isset($bundles['paragraph']['sample_sentence'])) {
    $bundles['paragraph']['sample_sentence']['class'] = SampleSentence::class;
  }
}

/**
 * Implements hook_entity_field_storage_info().
 */
function mukurtu_dictionary_entity_field_storage_info(EntityTypeInterface $entity_type){
  if ($entity_type->id() == 'paragraph') {
    $fields = SampleSentence::bundleFieldDefinitions($entity_type, 'sample_sentence', []);
    $fields += DictionaryWordEntry::bundleFieldDefinitions($entity_type, 'dictionary_word_entry', []);
    return $fields;
  }

  if ($entity_type->id() == 'node') {
    $fields = DictionaryWord::bundleFieldDefinitions($entity_type, 'dictionary_word', []);
    $fields += WordList::bundleFieldDefinitions($entity_type, 'word_list', []);
    return $fields;
  }
}

/**
 * Implements hook_entity_access().
 */
function mukurtu_dictionary_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  if ($entity->getEntityTypeId() === 'paragraphs_type') {
    if($entity->id() === 'dictionary_word_entry' && $operation === 'delete') {
      // Don't allow the dictionary word entry paragraph type to be deleted.
      return AccessResult::forbidden();
    }
  }
}

/**
 * Implements hook_entity_bundle_field_info().
 */
function mukurtu_dictionary_entity_bundle_field_info(EntityTypeInterface $entity_type, $bundle, array $base_field_definitions) {
  if ($entity_type->id() == 'node' && $bundle == 'dictionary_word') {
    $fields = [];
    $fields['field_in_word_list'] = BaseFieldDefinition::create('entity_reference')
      ->setName('field_in_word_list')
      ->setLabel(t('Word Lists'))
      ->setDescription(t('Word lists this word is contained in.'))
      ->setComputed(TRUE)
      ->setClass('Drupal\mukurtu_dictionary\Plugin\Field\MukurtuInWordListFieldItemsList')
      ->setTargetEntityTypeId('node')
      ->setTargetBundle('word_list')
      ->setRevisionable(FALSE)
      ->setTranslatable(FALSE)
      ->setCardinality(FieldStorageDefinitionInterface::CARDINALITY_UNLIMITED)
      ->setDisplayConfigurable('view', TRUE);

    return $fields;
  }
}

/**
 * Implements hook_form_form_id_alter().
 */
function mukurtu_dictionary_form_node_dictionary_word_form_alter(&$form, FormStateInterface $form_state) {
  mukurtu_dictionary_language_field_config_helper($form, $form_state);
}

/**
 * Implements hook_form_form_id_alter().
 */
function mukurtu_dictionary_form_node_dictionary_word_edit_form_alter(&$form, FormStateInterface $form_state) {
  mukurtu_dictionary_language_field_config_helper($form, $form_state);
}

/**
 * Implements hook_form_form_id_alter().
 *
 * When the "Add to Word List" form is opened inside a modal dialog (see the
 * "use-ajax" local task link in mukurtu_dictionary.links.task.yml), wire its
 * submit button to an AJAX callback that closes the dialog on success
 * instead of doing a full page navigation. The ?mukurtu_modal=1 query flag
 * persists across the drupal_modal -> drupal_ajax wrapper format switch
 * Drupal's dialog JS performs on submit, so it reliably signals "this form
 * is in a modal."
 */
function mukurtu_dictionary_form_mukurtu_dictionary_add_word_to_list_form_alter(&$form, FormStateInterface $form_state) {
  if (\Drupal::request()->query->get('mukurtu_modal')) {
    $form['submit']['#ajax'] = [
      'callback' => 'mukurtu_dictionary_add_word_to_list_dialog_ajax',
      'progress' => ['type' => 'throbber'],
    ];
  }
}

/**
 * Implements hook_module_implements_alter().
 *
 * field_group moves its own hook_form_alter() to the end of the module list
 * so it can attach group metadata after everyone else has had a chance to
 * alter the form. Our own alter needs to run after that (to strip the tabs
 * from the embedded "create a new word list" form), so move
 * mukurtu_dictionary to the end too - since this runs after field_group's
 * own reordering, it ends up after field_group.
 */
function mukurtu_dictionary_module_implements_alter(&$implementations, $hook) {
  if ($hook === 'form_alter' && isset($implementations['mukurtu_dictionary'])) {
    $group = $implementations['mukurtu_dictionary'];
    unset($implementations['mukurtu_dictionary']);
    $implementations['mukurtu_dictionary'] = $group;
  }
}

/**
 * Implements hook_form_alter().
 *
 * Trims the embedded "create a new word list" entity form down to just the
 * fields needed for a quick create - keep only Title and Cultural Protocols
 * (both required; Cultural Protocols can't be defaulted, since it must
 * reflect an actual protocol the user belongs to). Everything else can be
 * filled in later by editing the word list normally. Also wires the form's
 * submit button to close the modal dialog on success, mirroring
 * mukurtu_dictionary_form_mukurtu_dictionary_add_word_to_list_form_alter().
 */
function mukurtu_dictionary_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if ($form_id !== 'node_word_list_form' || \Drupal::routeMatch()->getRouteName() !== 'mukurtu_dictionary.add_word_to_list') {
    return;
  }

  $hideFields = [
    'field_summary', 'field_description', 'field_word_list_image',
    'field_source', 'field_words', 'field_related_content',
    'field_keywords', 'field_coverage', 'field_coverage_description', 'field_location',
    'field_local_contexts_projects', 'field_local_contexts_labels_and_notices',
    'revision_log', 'path', 'promote', 'sticky', 'og_audience', 'uid', 'created',
    'comment', 'moderation_state',
  ];
  foreach ($hideFields as $fieldName) {
    if (isset($form[$fieldName])) {
      $form[$fieldName]['#access'] = FALSE;
    }
  }

  $form['#fieldgroups'] = [];
  $form['#group_children'] = [];

  // Not useful for a quick "create and add" flow.
  if (isset($form['actions']['preview'])) {
    $form['actions']['preview']['#access'] = FALSE;
  }

  // Marks this as a quick-create dialog form for mukurtu_gin_custom's CSS,
  // which shrinks field description text so it doesn't visually dominate
  // this short form.
  $form['#attributes']['class'][] = 'mukurtu-quick-create-form';

  // Status, Menu settings, and Review note aren't set directly on $form by
  // this point - Status/Menu settings come from core (NodeForm/menu_ui) and
  // Review note is added by mukurtu_workflows_form_node_form_alter(), all
  // via hook_form_BASE_FORM_ID_alter() implementations that can run after
  // this hook_form_alter(), so #access can't be set on them here yet. Must
  // be a #pre_render callback, which runs at actual render time after all
  // alters/#process callbacks have finished, regardless of module order.
  $form['#pre_render'][] = function (array $element): array {
    foreach (['status', 'menu', 'review_note'] as $key) {
      if (isset($element[$key])) {
        $element[$key]['#access'] = FALSE;
      }
    }
    return $element;
  };

  if (\Drupal::request()->query->get('mukurtu_modal')) {
    // This is the embedded "create a new word list" entity form. It has no
    // "node" value of its own, so stash the item being added (taken from
    // the route, since that's what the controller built this form for) so
    // the AJAX callback knows where to send the user back to.
    $node = \Drupal::routeMatch()->getParameter('node');
    if ($node) {
      $form['mukurtu_return_node'] = [
        '#type' => 'hidden',
        '#value' => $node->id(),
      ];
    }
    $form['actions']['submit']['#ajax'] = [
      'callback' => 'mukurtu_dictionary_add_word_to_list_dialog_ajax',
      'progress' => ['type' => 'throbber'],
    ];
    // Core's dialog JS hoists any ".form-actions" button into the dialog's
    // shared buttonpane (see prepareDialogButtons() in
    // core/misc/dialog/dialog.ajax.js), even while this form's <details> is
    // collapsed. With two forms in one dialog that makes this form's Save
    // button look like "the" dialog action and swallow clicks meant for the
    // other (picker) form. Strip the class so it stays inline. Must be a
    // #pre_render callback, not done directly here - the class is added by
    // Actions::processActions(), which runs later than hook_form_alter, so
    // it isn't there yet to remove at this point. Must be a closure, not a
    // plain function name string - #pre_render requires either an anonymous
    // function or a TrustedCallbackInterface method.
    $form['actions']['#pre_render'][] = function (array $element): array {
      if (!empty($element['#attributes']['class'])) {
        $element['#attributes']['class'] = array_diff($element['#attributes']['class'], ['form-actions']);
      }
      return $element;
    };
  }
}

/**
 * AJAX callback for the "Add to Word List" form (including the embedded
 * "create a new word list" form) when submitted from a modal dialog.
 *
 * Closes the dialog and returns to the word's page on a clean save; replaces
 * the dialog content with the rebuilt form (including validation messages)
 * when there are errors.
 */
function mukurtu_dictionary_add_word_to_list_dialog_ajax(array &$form, FormStateInterface $form_state): AjaxResponse {
  $response = new AjaxResponse();
  if ($form_state->isExecuted()) {
    $nodeId = $form_state->getValue('node') ?? $form_state->getValue('mukurtu_return_node');
    $response->addCommand(new CloseModalDialogCommand());

    // mukurtu_stay marks this as opened from a browse-card quick action
    // (see Drupal\mukurtu_dictionary\Hook\BrowseHooks::browseQuickActionsAlter())
    // rather than the full-page tab this callback was originally built for
    // - stay on the listing instead of navigating to the item's own page.
    if (\Drupal::request()->query->get('mukurtu_stay')) {
      // Messages set via messenger() during submitForm() would normally
      // ride along with the redirect below to the next page load; since
      // there's no redirect in this branch, convert them to AJAX commands
      // instead so the "Added X to Y" confirmation isn't silently lost.
      foreach (\Drupal::messenger()->all() as $type => $messages) {
        foreach ($messages as $message) {
          $response->addCommand(new MessageCommand($message, NULL, ['type' => $type]));
        }
      }
      \Drupal::messenger()->deleteAll();

      if ($nodeId) {
        $response->addCommand(new InvokeCommand('[data-quick-action-trigger="word-list-' . $nodeId . '"]', 'focus'));
      }
    }
    else {
      $node = $nodeId ? \Drupal::entityTypeManager()->getStorage('node')->load($nodeId) : NULL;
      if ($node) {
        $response->addCommand(new RedirectCommand($node->toUrl()->toString()));
      }
    }
  }
  else {
    // Drupal form validation errors are in $form_state->getErrors(), not the
    // messenger queue. Copy them over so status_messages renders them visibly.
    foreach ($form_state->getErrors() as $error) {
      \Drupal::messenger()->addError($error);
    }
    /** @var \Drupal\Core\Render\RendererInterface $renderer */
    $renderer = \Drupal::service('renderer');
    $status_messages = ['#type' => 'status_messages'];
    $form['#prefix'] = ($form['#prefix'] ?? '') . $renderer->renderRoot($status_messages);
    $output = $renderer->renderRoot($form);
    $response->setAttachments($form['#attached']);
    // Use HtmlCommand (not ReplaceCommand) - ".ui-dialog-content" is the
    // #drupal-modal wrapper itself, not a child of it. Replacing the wrapper
    // would break focus restoration and CloseModalDialogCommand's selector.
    $response->addCommand(new HtmlCommand('.ui-dialog-content', $output));
  }
  return $response;
}

// Helper method to pull dictionary language field options from config.
function mukurtu_dictionary_language_field_config_helper(&$form, FormStateInterface $form_state) {
  $config = \Drupal::config('mukurtu_dictionary_languages.settings');
  $allowedLanguages = $config->get('available_languages');
  $languageOptions = [];
  if ($allowedLanguages) {
    foreach ($allowedLanguages as $tid => $value) {
      $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($tid);
      if ($term) {
        $languageOptions[$tid] = $term->getName();
      }
    }
    // If there's only one language on the site, select it automatically.
    if (count($allowedLanguages) == 1) {
      $form['field_dictionary_word_language']['widget']['#default_value'] = array_key_first($languageOptions);
    }
    $form['field_dictionary_word_language']['widget']['#options'] = $languageOptions;
  }
}

/**
 * Add field_coverage to the dictionary search index for map view support.
 */
function mukurtu_dictionary_update_40023(): void {
  $index = \Drupal\search_api\Entity\Index::load('mukurtu_dictionary_index');
  if (!$index) {
    return;
  }

  if (!$index->getField('field_coverage')) {
    $field = new \Drupal\search_api\Item\Field($index, 'field_coverage');
    $field->setType('string');
    $field->setPropertyPath('field_coverage');
    $field->setDatasourceId('entity:node');
    $field->setLabel('Map Points');
    $index->addField($field);
    $index->save();
    $index->reindex();
  }
}

/**
 * Update dictionary word and word list teaser view displays for issue #1622.
 */
function mukurtu_dictionary_update_40024(): void {
  $config_factory = \Drupal::configFactory();

  // dictionary_word teaser: show translation label inline; resize thumbnail.
  $display = $config_factory->getEditable('core.entity_view_display.node.dictionary_word.teaser');
  if (!$display->isNew()) {
    $display
      ->set('content.field_translation.label', 'inline')
      ->set('content.field_thumbnail.settings.view_mode', 'small_250px_')
      ->save();
  }

  // Audio teaser: hide contributor label so the Twig template can supply "Speaker".
  $audio_display = $config_factory->getEditable('core.entity_view_display.media.audio.audio_for_dictionary_teaser');
  if (!$audio_display->isNew()) {
    $audio_display
      ->set('content.field_contributor.label', 'hidden')
      ->save();
  }

  // word_list teaser: use smaller image style; add field_summary.
  $wl_display = $config_factory->getEditable('core.entity_view_display.node.word_list.teaser');
  if (!$wl_display->isNew()) {
    $wl_display
      ->set('content.field_representative_media.settings.image_style', 'small_250px_w_')
      ->set('content.field_summary', [
        'type' => 'string',
        'label' => 'hidden',
        'settings' => ['link_to_entity' => FALSE],
        'third_party_settings' => [],
        'weight' => 1,
        'region' => 'content',
      ]);
    // Remove field_summary from the hidden list if present.
    $hidden = $wl_display->get('hidden') ?? [];
    unset($hidden['field_summary']);
    $wl_display->set('hidden', $hidden)->save();
  }
}

/**
 * Refine dictionary word teaser: remove translation label, inline contributor label.
 */
function mukurtu_dictionary_update_40025(): void {
  $config_factory = \Drupal::configFactory();

  $display = $config_factory->getEditable('core.entity_view_display.node.dictionary_word.teaser');
  if (!$display->isNew()) {
    $display->set('content.field_translation.label', 'hidden')->save();
  }

  $audio_display = $config_factory->getEditable('core.entity_view_display.media.audio.audio_for_dictionary_teaser');
  if (!$audio_display->isNew()) {
    $audio_display->set('content.field_contributor.label', 'inline')->save();
  }
}

/**
 * Remove hide_1_result_facet processor from glossary_entry facet so the A-Z bar shows with only one letter.
 */
function mukurtu_dictionary_update_40026(): void {
  $config = \Drupal::configFactory()->getEditable('facets.facet.glossary_entry');
  if ($config->isNew()) {
    return;
  }
  $processors = $config->get('processor_configs') ?? [];
  if (isset($processors['hide_1_result_facet'])) {
    unset($processors['hide_1_result_facet']);
    $config->set('processor_configs', $processors);
    $config->save();
  }
}

/**
 * Update dictionary word display: new field order and tabbed word entry layout.
 */
function mukurtu_dictionary_update_40027(): void {
  $config_factory = \Drupal::configFactory();

  foreach ([
    'core.entity_view_display.node.dictionary_word.full',
    'core.entity_view_display.paragraph.dictionary_word_entry.default',
  ] as $config_name) {
    $config_path = \Drupal::service('extension.list.profile')->getPath('mukurtu') . '/modules/mukurtu_dictionary/config/install/' . $config_name . '.yml';
    if (!file_exists($config_path)) {
      continue;
    }
    $data = \Symfony\Component\Yaml\Yaml::parse(file_get_contents($config_path));
    $config = $config_factory->getEditable($config_name);
    $config->setData($data);
    $config->save();
  }
}

/**
 * Switch entity browser fields to rendered_entity (form_selection view mode)
 * and use the dedicated dictionary-word-only browser for field_words.
 */
function mukurtu_dictionary_update_40028(): void {
  $config = \Drupal::configFactory()->getEditable('core.entity_form_display.node.dictionary_word.default');
  if (!$config->isNew()) {
    $config->set('content.field_related_content.settings.field_widget_display', 'rendered_entity');
    $config->set('content.field_related_content.settings.field_widget_display_settings', ['view_mode' => 'form_selection']);
    $config->save();
  }

  $config = \Drupal::configFactory()->getEditable('core.entity_form_display.node.word_list.default');
  if ($config->isNew()) {
    return;
  }
  $config->set('content.field_related_content.settings.field_widget_display', 'rendered_entity');
  $config->set('content.field_related_content.settings.field_widget_display_settings', ['view_mode' => 'form_selection']);
  $config->set('content.field_words.settings.entity_browser', 'mukurtu_dictionary_word_browser');
  $config->set('content.field_words.settings.field_widget_display', 'rendered_entity');
  $config->set('content.field_words.settings.field_widget_display_settings', ['view_mode' => 'form_selection']);
  $dependencies = $config->get('dependencies.config') ?? [];
  $key = array_search('entity_browser.browser.mukurtu_content_browser', $dependencies);
  if ($key !== FALSE) {
    unset($dependencies[$key]);
  }
  if (!in_array('entity_browser.browser.mukurtu_dictionary_word_browser', $dependencies)) {
    $dependencies[] = 'entity_browser.browser.mukurtu_dictionary_word_browser';
    sort($dependencies);
    $config->set('dependencies.config', $dependencies);
  }
  $config->save(TRUE);
}

/**
 * Show field_recording on dictionary word browse view display.
 */
function mukurtu_dictionary_update_40029(): void {
  $config = \Drupal::configFactory()->getEditable('core.entity_view_display.node.dictionary_word.browse');
  if ($config->isNew()) {
    return;
  }
  $config->set('content.field_recording', [
    'type' => 'entity_reference_entity_view',
    'label' => 'hidden',
    'settings' => ['view_mode' => 'browse', 'link' => FALSE],
    'third_party_settings' => [],
    'weight' => 3,
    'region' => 'content',
  ]);
  $hidden = $config->get('hidden') ?? [];
  unset($hidden['field_recording']);
  $config->set('hidden', $hidden)->save();
}

/**
 * Switch dictionary word and word list full views to use featured view mode.
 *
 * Dictionary word: swap field_related_content for field_all_related_content and
 * update the field group children list to match. Word list: switch related
 * content from teaser to featured view mode.
 */
function mukurtu_dictionary_update_40030(): void {
  // Dictionary word: promote field_all_related_content, retire field_related_content.
  $dw = \Drupal::configFactory()->getEditable('core.entity_view_display.node.dictionary_word.full');
  if (!$dw->isNew()) {
    // Move content display config.
    $field_config = $dw->get('content.field_related_content');
    if ($field_config) {
      $field_config['settings']['view_mode'] = 'featured';
      $dw->set('content.field_all_related_content', $field_config);
      $dw->clear('content.field_related_content');
    }
    // Swap hidden flags.
    $hidden = $dw->get('hidden') ?? [];
    unset($hidden['field_all_related_content']);
    $hidden['field_related_content'] = TRUE;
    $dw->set('hidden', $hidden);
    // Update field group children list.
    $children = $dw->get('third_party_settings.field_group.group_additional_fields.children') ?? [];
    $children = array_map(fn($f) => $f === 'field_related_content' ? 'field_all_related_content' : $f, $children);
    $dw->set('third_party_settings.field_group.group_additional_fields.children', $children);
    $dw->save();
  }

  // Word list: switch field_all_related_content from teaser to featured.
  $wl = \Drupal::configFactory()->getEditable('core.entity_view_display.node.word_list.full');
  if (!$wl->isNew()) {
    $wl->set('content.field_all_related_content.settings.view_mode', 'featured');
    $wl->save();
  }
}

/**
 * Show field_word_list_image in the word_list browse display.
 */
function mukurtu_dictionary_update_40031(): void {
  $config = \Drupal::configFactory()->getEditable('core.entity_view_display.node.word_list.browse');
  if ($config->isNew()) {
    return;
  }

  $content = $config->get('content') ?? [];
  if (!isset($content['field_word_list_image'])) {
    $content['field_word_list_image'] = [
      'type' => 'entity_reference_entity_view',
      'label' => 'hidden',
      'settings' => [
        'view_mode' => 'browse',
        'link' => FALSE,
      ],
      'third_party_settings' => [],
      'weight' => -1,
      'region' => 'content',
    ];
    $config->set('content', $content);
  }

  $hidden = $config->get('hidden') ?? [];
  if (isset($hidden['field_word_list_image'])) {
    unset($hidden['field_word_list_image']);
    $config->set('hidden', $hidden);
  }

  $config->save();
}

/**
 * Ensure the comment field and its displays exist on dictionary_word.
 */
function mukurtu_dictionary_update_40032(): void {
  if (!\Drupal\field\Entity\FieldConfig::loadByName('node', 'dictionary_word', 'comment')) {
    \Drupal\field\Entity\FieldConfig::create([
      'field_name' => 'comment',
      'entity_type' => 'node',
      'bundle' => 'dictionary_word',
      'label' => 'Comments',
      'description' => '',
      'required' => FALSE,
      'translatable' => TRUE,
      'default_value' => [
        [
          'status' => 2,
          'cid' => 0,
          'last_comment_timestamp' => 0,
          'last_comment_name' => NULL,
          'last_comment_uid' => 0,
          'comment_count' => 0,
        ],
      ],
      'settings' => [
        'default_mode' => 1,
        'per_page' => 50,
        'anonymous' => 0,
        'form_location' => TRUE,
        'preview' => 1,
      ],
    ])->save();
  }

  $form_display = \Drupal::configFactory()->getEditable('core.entity_form_display.node.dictionary_word.default');
  if (!$form_display->isNew() && !$form_display->get('content.comment')) {
    $form_display->set('content.comment', [
      'type' => 'comment_default',
      'weight' => 9,
      'region' => 'content',
      'settings' => [],
      'third_party_settings' => [],
    ]);
    $form_display->save();
  }

  $view_display = \Drupal::configFactory()->getEditable('core.entity_view_display.node.dictionary_word.full');
  if (!$view_display->isNew()) {
    if (!$view_display->get('content.comment')) {
      $view_display->set('content.comment', [
        'type' => 'mukurtu_comment_default',
        'label' => 'above',
        'settings' => [
          'view_mode' => 'default',
          'pager_id' => 0,
        ],
        'third_party_settings' => [],
        'weight' => 2,
        'region' => 'content',
      ]);
    }

    $children = $view_display->get('third_party_settings.field_group.group_primary_fields.children') ?? [];
    if ($children && !in_array('comment', $children)) {
      $children[] = 'comment';
      $view_display->set('third_party_settings.field_group.group_primary_fields.children', $children);
    }

    $view_display->save();
  }
}

/**
 * Hide the export-list flag button on dictionary word and word list displays.
 */
function mukurtu_dictionary_update_40033(): void {
  $displays = [
    'core.entity_view_display.node.dictionary_word.full' => 'group_metadata',
    'core.entity_view_display.node.dictionary_word.taxonomy_record' => NULL,
    'core.entity_view_display.node.dictionary_word.search_preview' => NULL,
    'core.entity_view_display.node.word_list.default' => NULL,
    'core.entity_view_display.node.word_list.full' => NULL,
    'core.entity_view_display.node.word_list.taxonomy_record' => NULL,
  ];

  foreach ($displays as $display_id => $group_name) {
    $config = \Drupal::configFactory()->getEditable($display_id);
    if ($config->isNew()) {
      continue;
    }

    $content = $config->get('content') ?? [];
    if (isset($content['flag_export_content'])) {
      unset($content['flag_export_content']);
      $config->set('content', $content);
    }

    $hidden = $config->get('hidden') ?? [];
    $hidden['flag_export_content'] = TRUE;
    $config->set('hidden', $hidden);

    if ($group_name) {
      $children = $config->get("third_party_settings.field_group.$group_name.children") ?? [];
      $children = array_values(array_filter($children, fn($child) => $child !== 'flag_export_content'));
      $config->set("third_party_settings.field_group.$group_name.children", $children);
    }

    $config->save();
  }
}

/**
 * Show field_in_collection in List mode for dictionary_word and word_list,
 * matching every other content type's browse display, and show
 * field_in_word_list on dictionary_word (#1624).
 */
function mukurtu_dictionary_update_40034(): void {
  $config_source = new \Drupal\Core\Config\FileStorage(
    \Drupal::service('extension.list.module')->getPath('mukurtu_dictionary') . '/config/install'
  );
  $config_factory = \Drupal::configFactory();

  foreach ([
    'core.entity_view_display.node.dictionary_word.browse',
    'core.entity_view_display.node.word_list.browse',
  ] as $config_name) {
    $data = $config_source->read($config_name);
    if ($data) {
      $config_factory->getEditable($config_name)->setData($data)->save(TRUE);
    }
  }
}

/**
 * Enable the Leaflet "Reset View" recenter control on /dictionary's Map
 * mode, matching /browse and /digital-heritage (#1624).
 */
function mukurtu_dictionary_update_40035(): void {
  $config = \Drupal::configFactory()->getEditable('views.view.mukurtu_dictionary');
  if ($config->isNew()) {
    return;
  }
  $key = 'display.mukurtu_dictionary_block_map.display_options.style.options.reset_map.control';
  if ($config->get($key) !== NULL) {
    $config->set($key, TRUE)->save();
  }
}

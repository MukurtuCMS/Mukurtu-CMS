      $index->reindex();
    }
  }
}

/**
 * Add MPI and community record collapse fields to the dictionary index.
 *
 * Each processor/field pair is added only if the providing module is enabled,
 * since MPI and community records are optional features enabled after install.
 */
function mukurtu_dictionary_update_40010(): void {
  $index = \Drupal\search_api\Entity\Index::load('mukurtu_dictionary_index');
  if (!$index) {
    return;
  }

  $module_handler = \Drupal::moduleHandler();
  $processor_manager = \Drupal::service('plugin.manager.search_api.processor');
  $processors = $index->getProcessors();
  $index_changed = FALSE;

  $candidates = [
    [
      'module' => 'mukurtu_multipage_items',
      'processor_id' => 'mukurtu_multipage_page_index',
      'field_id' => 'is_additional_mpi_page',
      'field' => [
        'type' => 'boolean',
        'property_path' => 'is_additional_mpi_page',
        'datasource_id' => 'entity:node',
        'label' => 'Is additional multipage item page',
      ],
    ],
    [
      'module' => 'mukurtu_community_records',
      'processor_id' => 'mukurtu_community_record_flag',
      'field_id' => 'is_community_record',
      'field' => [
        'type' => 'boolean',
        'property_path' => 'is_community_record',
        'datasource_id' => 'entity:node',
        'label' => 'Is community record',
      ],
    ],
  ];

  foreach ($candidates as $candidate) {
    if (!$module_handler->moduleExists($candidate['module'])) {
      continue;
    }

    if (!isset($processors[$candidate['processor_id']])) {
      $processor = $processor_manager->createInstance($candidate['processor_id'], ['#index' => $index]);
      $processors[$candidate['processor_id']] = $processor;
      $index_changed = TRUE;
    }

    if (!$index->getField($candidate['field_id'])) {
      $cfg = $candidate['field'];
      $field = new \Drupal\search_api\Item\Field($index, $candidate['field_id']);
      $field->setType($cfg['type']);
      $field->setPropertyPath($cfg['property_path']);
      $field->setDatasourceId($cfg['datasource_id']);
      $field->setLabel($cfg['label']);
      $index->addField($field);
      $index_changed = TRUE;
    }
  }

  if (!$index_changed) {
    return;
  }

  $index->setProcessors($processors);
  $index->save();
  $index->reindex();
}

/**
 * Re-apply MPI/CR collapse fields if the 40010 save failed.
 *
 * The 40010 hook ran (schema was bumped) but the index save may have failed
 * because the install config briefly declared those modules as hard
 * dependencies. This hook is idempotent and a no-op when 40010 succeeded.
 */
function mukurtu_dictionary_update_40011(): void {
  mukurtu_dictionary_update_40010();
}

/**
 * Remove the LanguageCommunity entity type (superseded by Community).
 */
function mukurtu_dictionary_update_40012(): void {
  $db = \Drupal::database();
  $schema = $db->schema();

  // Remove OG memberships referencing language_community groups.
  if ($schema->tableExists('og_membership')) {
    $db->delete('og_membership')
      ->condition('entity_type', 'language_community')
      ->execute();
  }

  // Drop language_community tables if they exist.
  foreach (['language_community_field_revision', 'language_community_revision', 'language_community_field_data', 'language_community'] as $table) {
    if ($schema->tableExists($table)) {
      $schema->dropTable($table);
    }
  }

  // Remove the language_community OG roles.
  $non_default_role_ids = [
    'language_community-language_community-language_steward',
    'language_community-language_community-language_contributor',
  ];
  foreach ($non_default_role_ids as $role_id) {
    $og_role = \Drupal\og\Entity\OgRole::load($role_id);
    if ($og_role) {
      $og_role->delete();
    }
  }

  // Delete default roles directly via config storage rather than the entity
  // API. OgRole::preSave() throws on roles whose type is 'member' or
  // 'non-member', blocking OgRole::delete() on those IDs even when the
  // owning group type is being removed.
  $default_role_ids = [
    'language_community-language_community-member',
    'language_community-language_community-non-member',
  ];
  foreach ($default_role_ids as $role_id) {
    $config = \Drupal::configFactory()->getEditable('og.role.' . $role_id);
    if (!$config->isNew()) {
      $config->delete();
    }
  }
}

/**
 * Add word_list to type filter, enable multi-select on facets, add community facet.
 */
function mukurtu_dictionary_update_40015(): void {
  $config = \Drupal::configFactory()->getEditable('views.view.mukurtu_dictionary');
  if (!$config) {
    return;
  }

  $base = 'display.default.display_options';

  // 1. Include word_list in the hard type filter so word lists appear in results.
  $value = $config->get("$base.filters.type.value") ?? [];
  $value['word_list'] = 'word_list';
  $config->set("$base.filters.type.value", $value);

  // 2. Enable multiple selections on all exposed facet dropdown filters.
  $multi_filters = [
    'facets_type',
    'facets_mukurtu_cultural_protocol_ids',
    'facets_language',
    'facets_keyword',
    'facets_word_lists',
    'facets_word_type',
  ];
  foreach ($multi_filters as $filter_id) {
    $config->set("$base.filters.$filter_id.expose.multiple", TRUE);
    $config->set("$base.filters.$filter_id.group_info.multiple", TRUE);
  }

  // 3. Add community facet filter.
  $community_filter = [
    'id' => 'facets_community_title',
    'table' => 'search_api_index_mukurtu_dictionary_index',
    'field' => 'facets_community_title',
    'relationship' => 'none',
    'group_type' => 'group',
    'admin_label' => '',
    'plugin_id' => 'facets_filter',
    'operator' => '=',
    'value' => '',
    'group' => 1,
    'exposed' => TRUE,
    'expose' => [
      'operator_id' => '',
      'label' => 'Community',
      'description' => '',
      'use_operator' => FALSE,
      'operator' => '',
      'operator_limit_selection' => FALSE,
      'operator_list' => [],
      'identifier' => 'community',
      'required' => FALSE,
      'remember' => FALSE,
      'multiple' => TRUE,
      'remember_roles' => ['authenticated' => 'authenticated'],
    ],
    'is_grouped' => FALSE,
    'group_info' => [
      'label' => '',
      'description' => '',
      'identifier' => '',
      'optional' => TRUE,
      'widget' => 'select',
      'multiple' => TRUE,
      'remember' => FALSE,
      'default_group' => 'All',
      'default_group_multiple' => [],
      'group_items' => [],
    ],
    'hierarchy' => FALSE,
    'label_display' => 'visible',
    'facet' => [
      'query_operator' => 'or',
      'hard_limit' => 0,
      'min_count' => 1,
      'show_numbers' => FALSE,
      'processor_configs' => [
        'display_value_widget_order' => [
          'processor_id' => 'display_value_widget_order',
          'weights' => ['sort' => 40],
          'settings' => ['sort' => 'ASC'],
        ],
      ],
    ],
  ];
  $config->set("$base.filters.facets_community_title", $community_filter);

  // 4. Add community facet to BEF filter config.
  $bef_entry = [
    'plugin_id' => 'default',
    'advanced' => [
      'rewrite' => [
        'filter_rewrite_values' => '',
        'filter_rewrite_values_key' => FALSE,
      ],
      'collapsible' => FALSE,
      'collapsible_disable_automatic_open' => FALSE,
      'open_by_default' => FALSE,
      'is_secondary' => FALSE,
      'hide_label' => FALSE,
      'field_classes' => '',
      'sort_options_unsupported' => '',
    ],
  ];
  $config->set("$base.exposed_form.options.bef.filter.facets_community_title", $bef_entry);

  $config->save();
}

/**
 * Fix word_type index field; set community facet to single-select; move before cultural protocol; reorder filters; use glossary custom order sort.
 */
function mukurtu_dictionary_update_40016(): void {
  // Fix word_type index field to use the main node field.
  $index_ids = ['mukurtu_dictionary_index', 'mukurtu_dictionary_solr_index'];
  foreach ($index_ids as $index_id) {
    $index = \Drupal\search_api\Entity\Index::load($index_id);
    if (!$index) {
      continue;
    }
    $field = $index->getField('word_type');
    if (!$field) {
      continue;
    }
    if ($field->getPropertyPath() !== 'field_word_type:entity:name') {
      $field->setPropertyPath('field_word_type:entity:name');
      $index->save();
      $index->reindex();
    }
  }

  // Set community facet to single-select and move it before cultural protocol.
  $config = \Drupal::configFactory()->getEditable('views.view.mukurtu_dictionary');
  if (!$config) {
    return;
  }
  $base = 'display.default.display_options';

  $config->set("$base.filters.facets_community_title.expose.multiple", FALSE);
  $config->set("$base.filters.facets_community_title.group_info.multiple", FALSE);

  $filters = $config->get("$base.filters");
  if (isset($filters['facets_community_title']) && isset($filters['facets_mukurtu_cultural_protocol_ids'])) {
    $community = $filters['facets_community_title'];
    unset($filters['facets_community_title']);
    $new_filters = [];
    foreach ($filters as $key => $value) {
      if ($key === 'facets_mukurtu_cultural_protocol_ids') {
        $new_filters['facets_community_title'] = $community;
      }
      $new_filters[$key] = $value;
    }
    $config->set("$base.filters", $new_filters);
  }

  // Reorder exposed filters: search > language > community > protocol > type > word_type > keyword.
  $filters = $config->get("$base.filters");
  $order = [
    'type',
    'search_api_language',
    'search_api_fulltext',
    'facets_language',
    'facets_community_title',
    'facets_mukurtu_cultural_protocol_ids',
    'facets_type',
    'facets_word_type',
    'facets_keyword',
    'facets_word_lists',
    'facets_field_glossary_entry',
  ];
  $new_filters = [];
  foreach ($order as $key) {
    if (isset($filters[$key])) {
      $new_filters[$key] = $filters[$key];
    }
  }
  foreach ($filters as $key => $value) {
    if (!isset($new_filters[$key])) {
      $new_filters[$key] = $value;
    }
  }
  $config->set("$base.filters", $new_filters);

  // Use glossary custom order sort plugin for field_glossary_entry and expose it.
  $config->set("$base.sorts.field_glossary_entry.plugin_id", 'glossary_custom_order');
  $config->set("$base.sorts.field_glossary_entry.expose.label", 'Glossary order');
  $config->set("$base.sorts.field_glossary_entry.expose.field_identifier", 'glossary_order');
  $config->set("$base.sorts.field_glossary_entry.exposed", TRUE);

  // Add search relevance sort option.
  $config->set("$base.sorts.search_api_relevance", [
    'id' => 'search_api_relevance',
    'table' => 'search_api_index_mukurtu_dictionary_index',
    'field' => 'search_api_relevance',
    'relationship' => 'none',
    'group_type' => 'group',
    'admin_label' => '',
    'plugin_id' => 'search_api',
    'order' => 'DESC',
    'expose' => [
      'label' => 'Search relevance',
      'field_identifier' => 'relevance',
    ],
    'exposed' => TRUE,
  ]);

  // Add BEF sort section.
  $config->set("$base.exposed_form.options.bef.sort", [
    'plugin_id' => 'default',
    'advanced' => [
      'combine' => FALSE,
      'combine_rewrite' => '',
      'combine_param' => 'sort_bef_combine',
      'reset' => FALSE,
      'reset_label' => '',
      'collapsible' => FALSE,
      'collapsible_label' => 'Sort options',
      'is_secondary' => FALSE,
    ],
  ]);

  $config->save();
}

/**
 * Switch field_recording to media_assets view mode on dictionary word displays.
 */
function mukurtu_dictionary_update_40018(): void {
  $config = \Drupal::configFactory()->getEditable('core.entity_view_display.node.dictionary_word.full');
  $config->set('content.field_recording.settings.view_mode', 'media_assets');
  $config->save();

  $paragraph_config = \Drupal::configFactory()->getEditable('core.entity_view_display.paragraph.dictionary_word_entry.default');
  $paragraph_config->set('content.field_recording.settings.view_mode', 'media_assets');
  $paragraph_config->save();
}

/**
 * Use audio_for_dictionary_word view mode for recording field on dictionary word entries.
 */
function mukurtu_dictionary_update_40019(): void {
  // Switch the dictionary word entry paragraph to use the new view mode.
  $paragraph_config = \Drupal::configFactory()->getEditable('core.entity_view_display.paragraph.dictionary_word_entry.default');
  $paragraph_config->set('content.field_recording.settings.view_mode', 'audio_for_dictionary_word');
  $paragraph_config->save();

  // Switch the node full display to use the new view mode (base word entry recording).
  $node_config = \Drupal::configFactory()->getEditable('core.entity_view_display.node.dictionary_word.full');
  $node_config->set('content.field_recording.settings.view_mode', 'audio_for_dictionary_word');
  $node_config->save();
}


<div class="browse-facets__wrapper">
  <div class="browse-facets">
    {{ drupal_block('views_exposed_filter_block:mukurtu_dictionary-mukurtu_dictionary_block') }}
  </div>
</div>

{% if glossary %}
<div class="glossary">
  {{ glossary }}
</div>
{% endif %}

<div class="browse-content__wrapper">
  <div class="dictionary-view-container">
    <div class="browse-links">
      <button data-browse-mode="list" aria-label="{{ 'Switch to list view'|t }}" class="active-toggle">{{ 'List'|t }}</button>
      <button data-browse-mode="map" aria-label="{{ 'Switch to map view'|t }}">{{ 'Map'|t }}</button>
    </div>
    {{ list_results }}
    {{ map_results }}
  </div>
</div>

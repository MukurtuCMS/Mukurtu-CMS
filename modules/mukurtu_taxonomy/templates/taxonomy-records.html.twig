<div class="taxonomy-term-page">
  <div class="taxonomy-term-intro">
    {% if term_description %}
      <div class="taxonomy-term-description">{{ term_description }}</div>
    {% endif %}
    <p>{{ 'All available content using the @vocab term @term.'|t({'@vocab': vocabulary_label, '@term': term_name}) }}</p>
  </div>

  {% if records|length == 1%}
  <div data-horizontal-tabs class="taxonomy-records">
    {% set singlerecord = records|first %}
    {{ singlerecord.content }}
  </div>
  {% elseif records|length > 1 %}
  <div data-horizontal-tabs class="taxonomy-records horizontal-tabs clearfix">
    <ul data-horizontal-tabs-list class="horizontal-tabs-list visually-hidden"></ul>
    <div{{ attributes.setAttribute('data-horizontal-tabs-panes', TRUE) }}>
    {% for record in records %}
      <details id="{{ record.tabid }}">
        {% if record.id == active %}
        <input style="display:none;" class="horizontal-tabs-active-tab" value="{{ record.tabid }}" type="text">
        {% endif %}
        <summary>
          <div class="details-title">
            <span>{{ record.communities }}</span>
          </div>
        </summary>
        <div class="tab-content-wrapper">
          <div class="tab-content-wrapper__content">
            {{ record.content }}
          </div>
        </div>
      </details>
    {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="browse-facets">
    {% if facets %}
      {% for facet in facets %}
        {{ facet }}
      {% endfor %}
    {% endif %}
  </div>

  {% if referenced_content is not empty %}
    <div class="referenced-content grid">
      {{ referenced_content }}
    </div>
  {% endif %}
</div>

<?php

/**
 * @file
 * Provide Mukurtu Taxonomies.
 */

use Drupal\Core\Url;
use Drupal\Core\Link;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\Core\Access\AccessResult;

/**
 * Implements hook_theme().
 */
function mukurtu_taxonomy_theme($existing, $type, $theme, $path) {
  return [
    'mukurtu_vocabulary_add_list' => [
      'template' => 'mukurtu-vocabulary-add-list',
      'variables' => ['content' => NULL],
    ],
    'taxonomy_records' => [
      'template' => 'taxonomy-records',
      'variables' => [
        'active' => NULL,
        'records' => NULL,
        'referenced_content' => NULL,
        'facets' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_entity_access().
 */
function mukurtu_taxonomy_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  if ($entity->getEntityTypeId() === 'taxonomy_vocabulary') {
    $vocabs = [
      'category',
      'community_type',
      'contributor',
      'creator',
      'format',
      'interpersonal_relationship',
      'keywords',
      'language',
      'location',
      'media_tag',
      'people',
      'publisher',
      'subject',
      'type',
      'word_type',
    ];
    if ($operation === 'delete' && in_array($entity->id(), $vocabs)) {
      // Don't allow the any of our Mukurtu taxonomy vocabs to be deleted.
      return AccessResult::forbidden();
    }
  }
}

/**
 * Implements hook_form_form_id_alter().
 */
function mukurtu_taxonomy_form_taxonomy_term_category_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  // Change Category title field label.
  $form['name']['widget'][0]['value']['#title'] = t('Category name');
  $form['name']['widget'][0]['value']['#description'] = t('Provide the category name. Categories are high-level descriptive terms that help users browse and discover digital heritage items.');

  // Add helper text to description field using a markup element.
if (isset($form['description'])) {
  // Insert help text as a separate element
  $form['description']['#suffix'] = '<div class="description"><small>The description is not normally shown to end users. It may be used for internal documentation to clarify or define the content that should be included in the category, or to provide additional details about the category.</small></div>';
}
  // Add helper text to thumbnail image field.
  if (isset($form['field_thumbnail_image'])) {
    $form['field_thumbnail_image']['widget']['#description'] = t('The thumbnail image is used in the "browse by category" page and landing page block. A thumbnail could be a photograph, graphic, or other image that represents the content or concept of the category. If a thumbnail image is not provided, a placeholder graphic will be displayed instead.<br>Note: thumbnail images require a cultural protocol (like all other media assets). If you cannot upload images here, ensure that you are enrolled in a relevant cultural protocol with permission to upload media.');
  }

  // Add helper text to path field.
  if (isset($form['path'])) {
    $form['path']['widget'][0]['#description'] = t('Leave blank to auto-generate a URL path based on the category name. Optionally, enter a custom path.');
  }

  // Hide the relations field (see issue #204).
  if (isset($form['relations'])) {
    $form['relations']['#access'] = FALSE;
  }
}

/**
 * Implements hook_form_form_id_alter().
 *
 * Change the description of the 'Terms to merge' form element for the
 * taxonomy_merge_terms form:
 * (admin/structure/taxonomy/manage/{taxonomy_vocabulary}/merge).
 */

function mukurtu_taxonomy_form_taxonomy_merge_terms_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $form['#markup'] = t('To merge multiple terms into a new target term, select all terms to merge here. The new target term will be created on the next page.<br/>To merge one or more terms into another existing target term, select them here. The target term will be selected on the next page, do not select it now.');

  $form['terms']['#description'] = t('');

  $form['actions']['submit']['#value'] = t('Next');
}

function mukurtu_taxonomy_form_taxonomy_merge_terms_target_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $form ['#title'] = t('Select target term');

  $form['description']['#markup'] = t('To merge the selected terms into a new target term, enter it in the "New term" field.<br/>To merge the selected term(s) into an existing target term, select it from the "Existing term" list.');

  $form['actions']['submit']['#value'] = t('Merge terms');
}

/**
 * Prepares variables for list of available vocabulary templates.
 *
 * Default template: mukurtu-vocabulary-add-list.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - content: An array of content types.
 */
function template_preprocess_mukurtu_vocabulary_add_list(array &$variables) {
  $variables['types'] = [];

  if (!empty($variables['content'])) {
    foreach ($variables['content'] as $type) {
      $variables['types'][$type->id()] = [
        'type' => $type->id(),
        'add_link' => Link::fromTextAndUrl($type->label(), Url::fromRoute('mukurtu_taxonomy.manage_taxonomy_vocabulary', ['taxonomy_vocabulary' => $type->id()]))->toString(),
        'description' => [
          '#markup' => $type->getDescription(),
        ],
      ];
    }
  }
}

/**
 * Implements hook_entity_bundle_field_info_alter().
 *
 * Sets target_bundles on taxonomy term reference fields from Mukurtu taxonomy
 * settings so that selection handlers and widgets see the correct bundles.
 */
function mukurtu_taxonomy_entity_bundle_field_info_alter(&$fields, EntityTypeInterface $entity_type, $bundle) {
  // Map bundle names to their fields and config keys. Person and Place are
  // node bundles that define these fields via bundleFieldDefinitions().
  $field_config_map = [
    'person' => [
      'field_other_names' => 'person_records_enabled_vocabularies',
    ],
    'place' => [
      'field_other_place_names' => 'place_records_enabled_vocabularies',
    ],
  ];

  if ($entity_type->id() !== 'node' || !isset($field_config_map[$bundle])) {
    return;
  }

  $config = \Drupal::config('mukurtu_taxonomy.settings');
  foreach ($field_config_map[$bundle] as $field_name => $config_key) {
    if (!isset($fields[$field_name])) {
      continue;
    }

    $enabled_vocabs = $config->get($config_key);
    if (!is_array($enabled_vocabs) || empty($enabled_vocabs)) {
      continue;
    }

    $target_bundles = array_combine($enabled_vocabs, $enabled_vocabs);
    $settings = $fields[$field_name]->getSettings();
    $settings['handler_settings']['target_bundles'] = $target_bundles;
    $fields[$field_name]->setSettings($settings);
  }
}


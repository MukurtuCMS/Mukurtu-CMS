<?php

/**
 * @file
 * Install, update and uninstall functions for the mukurtu_taxonomy module.
 */

/**
 * Ensure the message_digest cleanup runs before this hook installs a module.
 *
 * Installing flat_taxonomy triggers a module-list rebuild that validates
 * every module still listed in core.extension exists on disk. On sites
 * where mukurtu_notifications_update_40018() (which removes the
 * message_digest/message_digest_ui entries) hasn't run yet, that rebuild
 * fails with "The module message_digest does not exist."
 */
function mukurtu_taxonomy_update_dependencies(): array {
  return [
    'mukurtu_taxonomy' => [
      '40001' => ['mukurtu_notifications' => '40018'],
    ],
  ];
}

/**
 * Enable flat_taxonomy and mark all stock Mukurtu vocabularies as flat.
 */
function mukurtu_taxonomy_update_40001(): void {
  // Ensure the flat_taxonomy module is enabled.
  \Drupal::service('module_installer')->install(['flat_taxonomy']);

  $vids = [
    'category',
    'community_type',
    'contributor',
    'creator',
    'format',
    'interpersonal_relationship',
    'keywords',
    'language',
    'location',
    'media_tag',
    'people',
    'publisher',
    'subject',
    'type',
    'word_type',
  ];

  $vocabulary_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary');

  foreach ($vids as $vid) {
    $vocabulary = $vocabulary_storage->load($vid);
    if (!$vocabulary) {
      continue;
    }
    $vocabulary->setThirdPartySetting('flat_taxonomy', 'flat', 1);
    $vocabulary->save();

    // Strip any existing parent relationships on terms in this vocabulary so
    // live data matches the enforced flat structure.
    $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
    $tids = $term_storage->getQuery()
      ->accessCheck(FALSE)
      ->condition('vid', $vid)
      ->execute();

    foreach ($term_storage->loadMultiple($tids) as $term) {
      if (!empty($term->parent->target_id)) {
        $term->parent = 0;
        $term->save();
      }
    }
  }
}

/**
 * Mark place_type vocabulary as flat and strip any existing parent relationships.
 *
 * WARNING: No rollback. Parent term IDs are discarded and cannot be recovered
 * from this hook. Back up the taxonomy_term__parent table before running on
 * production if preserving the existing hierarchy matters.
 */
function mukurtu_taxonomy_update_40002(): void {
  $vocabulary_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary');
  $vocabulary = $vocabulary_storage->load('place_type');
  if (!$vocabulary) {
    return;
  }
  $vocabulary->setThirdPartySetting('flat_taxonomy', 'flat', 1);
  $vocabulary->save();

  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $tids = $term_storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('vid', 'place_type')
    ->execute();

  foreach ($term_storage->loadMultiple($tids) as $term) {
    if (!empty($term->parent->target_id)) {
      $term->parent = 0;
      $term->save();
    }
  }
}

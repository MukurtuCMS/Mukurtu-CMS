<?php

/**
 * @file
 * Provide Mukurtu Gin Custom.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\node\Entity\NodeType;

/**
 * Implements hook_theme().
 */
function mukurtu_gin_custom_theme(array $existing, string $type, string $theme, string $path): array {
  // Register templates so they're available to all themes, including the admin
  // theme (gin), which cannot find templates in mukurtu_v4.
  return [
    'node__form_selection' => [
      'base hook' => 'node',
      'template' => 'content/node--form-selection',
      'path' => $path . '/templates',
    ],
    'media__audio__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--audio--media-library',
      'path' => $path . '/templates',
    ],
    'media__document__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--document--media-library',
      'path' => $path . '/templates',
    ],
    'media__image__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--image--media-library',
      'path' => $path . '/templates',
    ],
    'media__remote_video__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--remote-video--media-library',
      'path' => $path . '/templates',
    ],
    'media__external_embed__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--external-embed--media-library',
      'path' => $path . '/templates',
    ],
    'media__soundcloud__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--soundcloud--media-library',
      'path' => $path . '/templates',
    ],
    'media__video__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--video--media-library',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_page_attachments()
 */
function mukurtu_gin_custom_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'mukurtu_gin_custom/mukurtu-gin-custom';
  $attachments['#attached']['drupalSettings']['mukurtu']['mediaEditUrl'] =
    Url::fromRoute('entity.media.edit_form', ['media' => 0])->toString();
  /** @var \Drupal\Core\Routing\AdminContext $admin_context */
  $admin_context = \Drupal::service('router.admin_context');
  if ($admin_context->isAdminRoute()) {
    $attachments['#attached']['drupalSettings']['mukurtu']['mediaEditUrl'] =
      Url::fromRoute('entity.media.edit_form', ['media' => 0])->toString();
    $attachments['#attached']['library'][] = 'mukurtu_gin_custom/entity-browser-toggle';
    $attachments['#attached']['library'][] = 'mukurtu_gin_custom/community-browser-select';
  }
}

/**
 * Implements hook_preprocess_html().
 */
function mukurtu_gin_custom_preprocess_html(array &$variables): void {
  $route_name = \Drupal::routeMatch()->getRouteName();
  // The Dashboards layout builder uses _admin_route => FALSE so gin_lb's
  // route check may not add glb-body. Add it explicitly so gin_lb CSS and
  // the toolbar-tray suppression behavior both apply.
  if (in_array($route_name, [
    'layout_builder.dashboards.view',
    'layout_builder.dashboards_override.view',
  ])) {
    $variables['attributes']['class'][] = 'glb-body';
    $variables['attributes']['class'][] = 'mukurtu-dashboard-layout';
  }
}

/**
 * Implements hook_preprocess_media().
 *
 * Provides the mukurtu_v4 theme path so module-owned media library templates
 * can reference theme images without hardcoding an absolute URL.
 */
function mukurtu_gin_custom_preprocess_media(&$variables) {
  $variables['mukurtu_v4_path'] = \Drupal::service('extension.list.theme')->getPath('mukurtu_v4');
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node_form.
 *
 * Attaches the JS behavior that moves the moderation state widget into
 * Gin's sticky header after the DOM is ready.
 */
function mukurtu_gin_custom_form_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (isset($form['moderation_state'])) {
    $form['#attached']['library'][] = 'mukurtu_gin_custom/moderation-state-header';

    // Always use "Save as" regardless of whether the entity is new or existing.
    // Core uses "Change to" for existing entities; this overrides it for consistency.
    if (isset($form['moderation_state']['widget'][0]['state'])) {
      $form['moderation_state']['widget'][0]['state']['#title'] = t('Save as');
    }
  }
}

/**
 * Implements hook_preprocess_node() for the form_selection view mode.
 */
function mukurtu_gin_custom_preprocess_node(&$variables) {
  if ($variables['view_mode'] !== 'form_selection') {
    return;
  }
  $node = $variables['node'];
  if (!($node instanceof NodeInterface)) {
    return;
  }
  // Remove the community/protocol list injected by hook_node_view_alter —
  // it is not relevant in the compact form-selection card context.
  unset($variables['content']['community_protocol_list']);
  $node_type = $node->type->entity;
  if ($node_type instanceof NodeType) {
    $variables['content_type_label'] = $node_type->label();
  }
}

<?php

/**
 * @file
 * Provide Mukurtu Gin Custom.
 */

use Drupal\Component\Utility\UrlHelper;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\RedirectCommand;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\node\Entity\NodeType;

/**
 * Implements hook_theme().
 */
function mukurtu_gin_custom_theme(array $existing, string $type, string $theme, string $path): array {
  // Register templates so they're available to all themes, including the admin
  // theme (gin), which cannot find templates in mukurtu_v4.
  return [
    'node__form_selection' => [
      'base hook' => 'node',
      'template' => 'content/node--form-selection',
      'path' => $path . '/templates',
    ],
    'media__audio__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--audio--media-library',
      'path' => $path . '/templates',
    ],
    'media__document__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--document--media-library',
      'path' => $path . '/templates',
    ],
    'media__image__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--image--media-library',
      'path' => $path . '/templates',
    ],
    'media__remote_video__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--remote-video--media-library',
      'path' => $path . '/templates',
    ],
    'media__external_embed__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--external-embed--media-library',
      'path' => $path . '/templates',
    ],
    'media__soundcloud__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--soundcloud--media-library',
      'path' => $path . '/templates',
    ],
    'media__video__media_library' => [
      'base hook' => 'media',
      'template' => 'media/media--video--media-library',
      'path' => $path . '/templates',
    ],
  ];
}

/**
 * Implements hook_page_attachments()
 */
function mukurtu_gin_custom_page_attachments(array &$attachments) {
  $attachments['#attached']['library'][] = 'mukurtu_gin_custom/mukurtu-gin-custom';
  $attachments['#attached']['drupalSettings']['mukurtu']['mediaEditUrl'] =
    Url::fromRoute('entity.media.edit_form', ['media' => 0])->toString();
  /** @var \Drupal\Core\Routing\AdminContext $admin_context */
  $admin_context = \Drupal::service('router.admin_context');
  if (\Drupal::currentUser()->isAuthenticated()) {
    $attachments['#attached']['library'][] = 'mukurtu_gin_custom/gin-collapsed-defaults';
  }
  if ($admin_context->isAdminRoute()) {
    $attachments['#attached']['drupalSettings']['mukurtu']['mediaEditUrl'] =
      Url::fromRoute('entity.media.edit_form', ['media' => 0])->toString();
    $attachments['#attached']['library'][] = 'mukurtu_gin_custom/entity-browser-toggle';
    $attachments['#attached']['library'][] = 'mukurtu_gin_custom/community-browser-select';
  }

  // Attach front-end LB block edit controls on node canonical pages where the
  // viewing user can configure the layout and the node has a custom LB override.
  // Edit URLs are passed via drupalSettings (not the block render array) so they
  // are always fresh and never served from a stale render cache entry.
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route === 'entity.node.canonical') {
    $node = \Drupal::routeMatch()->getParameter('node');
    if ($node instanceof NodeInterface &&
        \Drupal::currentUser()->hasPermission('configure editable ' . $node->bundle() . ' node layout overrides') &&
        $node->access('update') &&
        $node->hasField('layout_builder__layout') &&
        !$node->get('layout_builder__layout')->isEmpty()) {
      $attachments['#attached']['library'][] = 'mukurtu_gin_custom/lb-frontend-edit';
      // Build a UUID->edit-URL map for every non-field block in the layout.
      // - Reusable blocks (block_content:*): link to the entity edit form so all
      //   content fields are shown, not just the LB wrapper settings.
      // - All other non-field blocks: link to the LB configure-block form.
      $return_url = \Drupal::request()->getRequestUri();
      $storage_id = $node->getEntityTypeId() . '.' . $node->id();
      $entity_repository = \Drupal::service('entity.repository');
      $edit_urls = [];
      foreach ($node->get('layout_builder__layout')->getSections() as $delta => $section) {
        foreach ($section->getComponents() as $component) {
          $plugin_id = $component->getPlugin()->getPluginId();
          if (str_starts_with($plugin_id, 'field_block:') || str_starts_with($plugin_id, 'extra_field_block:')) {
            continue;
          }
          if (str_starts_with($plugin_id, 'block_content:')) {
            // Reusable block: edit the block_content entity directly.
            $block_uuid = substr($plugin_id, strlen('block_content:'));
            $block_content = $entity_repository->loadEntityByUuid('block_content', $block_uuid);
            if ($block_content && $block_content->access('update')) {
              $edit_urls[$component->getUuid()] = $block_content->toUrl('edit-form', [
                'query' => ['destination' => $return_url],
              ])->toString();
            }
          }
          else {
            // Inline block or other plugin: use the LB configure-block form.
            $edit_urls[$component->getUuid()] = Url::fromRoute('layout_builder.update_block', [
              'section_storage_type' => 'overrides',
              'section_storage' => $storage_id,
              'delta' => $delta,
              'region' => $component->getRegion(),
              'uuid' => $component->getUuid(),
            ], ['query' => ['frontend_edit' => '1', 'frontend_return' => $return_url]])->toString();
          }
        }
      }
      $attachments['#attached']['drupalSettings']['mukurtuLbEditUrls'] = $edit_urls;
    }
  }
}

/**
 * Implements hook_css_alter().
 *
 * When the front-end LB block edit library is attached, strip core's dark
 * off-canvas CSS so that gin_lb's white dialog override takes effect -- the
 * same stripping gin_lb/CssAlter does on actual layout_builder.* routes.
 */
function mukurtu_gin_custom_css_alter(array &$css, \Drupal\Core\Asset\AttachedAssetsInterface $assets): void {
  if (!in_array('mukurtu_gin_custom/lb-frontend-edit', $assets->getLibraries(), TRUE)) {
    return;
  }
  foreach (array_keys($css) as $path) {
    if (str_starts_with($path, 'core/misc/dialog/off-canvas/css/')) {
      unset($css[$path]);
    }
  }
}

/**
 * Implements hook_preprocess_html().
 */
function mukurtu_gin_custom_preprocess_html(array &$variables): void {
  $route_name = \Drupal::routeMatch()->getRouteName();
  // The Dashboards layout builder uses _admin_route => FALSE so gin_lb's
  // route check may not add glb-body. Add it explicitly so gin_lb CSS and
  // the toolbar-tray suppression behavior both apply.
  if (in_array($route_name, [
    'layout_builder.dashboards.view',
    'layout_builder.dashboards_override.view',
  ])) {
    $variables['attributes']['class'][] = 'glb-body';
    $variables['attributes']['class'][] = 'mukurtu-dashboard-layout';
  }
}

/**
 * Implements hook_preprocess_media().
 *
 * Provides the mukurtu_v4 theme path so module-owned media library templates
 * can reference theme images without hardcoding an absolute URL.
 */
function mukurtu_gin_custom_preprocess_media(&$variables) {
  $variables['mukurtu_v4_path'] = \Drupal::service('extension.list.theme')->getPath('mukurtu_v4');
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node_form.
 *
 * Attaches the JS behavior that moves the moderation state widget into
 * Gin's sticky header after the DOM is ready.
 */
function mukurtu_gin_custom_form_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if (isset($form['moderation_state'])) {
    $form['#attached']['library'][] = 'mukurtu_gin_custom/moderation-state-header';

    // Always use "Save as" regardless of whether the entity is new or existing.
    // Core uses "Change to" for existing entities; this overrides it for consistency.
    if (isset($form['moderation_state']['widget'][0]['state'])) {
      $form['moderation_state']['widget'][0]['state']['#title'] = t('Save as');
    }
  }

  // Basic pages manage their blocks and content via Layout Builder, which
  // this form does not expose -- point editors to the Layout tab instead.
  $entity = $form_state->getFormObject()->getEntity();
  if ($entity instanceof NodeInterface &&
      $entity->bundle() === 'page' &&
      !$entity->isNew() &&
      $entity->hasField('layout_builder__layout')) {
    $layout_url = Url::fromRoute('layout_builder.overrides.node.view', ['node' => $entity->id()]);
    if ($layout_url->access()) {
      $form['mukurtu_layout_builder_notice'] = [
        '#type' => 'container',
        '#attributes' => ['class' => ['messages', 'messages--status']],
        '#weight' => -1000,
        'message' => [
          '#markup' => t('This page uses layout builder to add and manage page blocks and content. Use the <a href=":url">Layout</a> tab to make changes.', [
            ':url' => $layout_url->toString(),
          ]),
        ],
      ];
    }
  }
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for layout_builder_configure_block.
 */
function mukurtu_gin_custom_form_layout_builder_configure_block_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getCurrentComponent')) {
    return;
  }

  // Add a Back link when adding a new inline block so editors can return to
  // the block type list without having to dismiss the entire dialog.
  if ($form_id === 'layout_builder_add_block') {
    $route_match = \Drupal::routeMatch();
    $delta = $route_match->getRawParameter('delta');
    $region = $route_match->getRawParameter('region');
    if ($delta !== NULL && $region !== NULL) {
      $section_storage = $form_object->getSectionStorage();
      $form['actions']['back'] = [
        '#type' => 'link',
        '#title' => t('Back'),
        '#url' => Url::fromRoute('layout_builder.choose_inline_block', [
          'section_storage_type' => $section_storage->getStorageType(),
          'section_storage' => $section_storage->getStorageId(),
          'delta' => $delta,
          'region' => $region,
        ]),
        '#attributes' => [
          'class' => ['use-ajax', 'button', 'button--secondary'],
          'data-dialog-type' => 'dialog',
          'data-dialog-renderer' => 'off_canvas',
        ],
        '#weight' => -10,
      ];
      $form['#attached']['library'][] = 'core/drupal.ajax';
    }
  }

  // Frontend edit mode: override the AJAX callback so the form commits its
  // tempstore changes to the entity and redirects back to the page.
  if (\Drupal::request()->query->get('frontend_edit') &&
      isset($form['actions']['submit']['#ajax'])) {
    $form['actions']['submit']['#ajax']['callback'] = 'mukurtu_gin_custom_lb_frontend_edit_ajax';
  }

  // Horizontal divider: hide the Title and Display title fields -- the block
  // is purely presentational and needs no label.
  if ($form_object->getCurrentComponent()->getPlugin()->getPluginId() !== 'inline_block:horizontal_divider') {
    return;
  }
  if (isset($form['settings']['label'])) {
    $form['settings']['label']['#access'] = FALSE;
  }
  if (isset($form['settings']['label_display'])) {
    $form['settings']['label_display']['#access'] = FALSE;
    $form['settings']['label_display']['#default_value'] = FALSE;
  }
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for block_content_form.
 *
 * Horizontal dividers have no meaningful title. Hide the required block
 * description field and pre-fill it so entity validation still passes.
 */
function mukurtu_gin_custom_form_block_content_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $entity = $form_state->getFormObject()->getEntity();
  if ($entity->bundle() !== 'horizontal_divider' || !isset($form['info'])) {
    return;
  }
  $form['info']['#attributes']['style'] = 'display:none';
  if (empty($form['info']['widget'][0]['value']['#default_value'])) {
    $form['info']['widget'][0]['value']['#default_value'] = 'Horizontal divider';
  }
}

/**
 * Implements hook_field_widget_single_element_form_alter().
 */
function mukurtu_gin_custom_field_widget_single_element_form_alter(array &$element, FormStateInterface $form_state, array $context): void {
  // The entity browser widget renders as a collapsible <details> element.
  // For field_featured_content on the featured_content Layout Builder inline
  // block, this is confusing -- the field is the only thing being configured.
  // Change it to a plain container so the selection is always visible.
  // Scoped to block_content:featured_content only -- Community and Protocol
  // entities also have a field_featured_content field and must keep their
  // normal label/description rendering (details wrapper).
  $field_name = $context['items']->getFieldDefinition()->getName();
  $entity = $context['items']->getEntity();
  if ($field_name === 'field_featured_content'
    && $entity->getEntityTypeId() === 'block_content'
    && $entity->bundle() === 'featured_content'
    && ($element['#type'] ?? '') === 'details') {
    $element['#type'] = 'container';
  }
}


/**
 * AJAX callback for the LB update-block form when opened in frontend-edit mode.
 *
 * Commits the tempstore to the entity and redirects back to the original page
 * instead of returning LB canvas-update commands.
 */
function mukurtu_gin_custom_lb_frontend_edit_ajax(array $form, FormStateInterface $form_state): AjaxResponse {
  if ($form_state->hasAnyErrors()) {
    return $form_state->getFormObject()->ajaxSubmit($form, $form_state);
  }

  $storage = $form_state->getFormObject()->getSectionStorage();
  $storage->save();
  \Drupal::service('layout_builder.tempstore_repository')->delete($storage);

  $return_url = \Drupal::request()->query->get('frontend_return') ?: '/';
  if (UrlHelper::isExternal($return_url)) {
    $return_url = '/';
  }
  $response = new AjaxResponse();
  $response->addCommand(new RedirectCommand($return_url));
  return $response;
}

/**
 * Implements hook_gin_content_form_routes().
 *
 * Opts taxonomy term, Community, and Cultural Protocol edit forms into
 * Gin's two-column edit-form layout (right-hand 'advanced' sidebar), the
 * same treatment node/media/block_content forms already receive.
 *
 * Community and Protocol creation go through separate, non-entity-form
 * classes (CommunityAddForm, ProtocolAddForm) reached via custom routes,
 * not the default entity add-form route, so only the edit routes apply
 * here.
 *
 * @see \Drupal\gin\GinContentFormHelper::isContentForm()
 */
function mukurtu_gin_custom_gin_content_form_routes(): array {
  return [
    'entity.taxonomy_term.add_form',
    'entity.taxonomy_term.edit_form',
    'entity.community.edit_form',
    'entity.protocol.edit_form',
  ];
}

/**
 * Implements hook_preprocess_node() for the form_selection view mode.
 */
function mukurtu_gin_custom_preprocess_node(&$variables) {
  if ($variables['view_mode'] !== 'form_selection') {
    return;
  }
  $node = $variables['node'];
  if (!($node instanceof NodeInterface)) {
    return;
  }
  // Remove the community/protocol list injected by hook_node_view_alter —
  // it is not relevant in the compact form-selection card context.
  unset($variables['content']['community_protocol_list']);
  $node_type = $node->type->entity;
  if ($node_type instanceof NodeType) {
    $variables['content_type_label'] = $node_type->label();
  }
}

{#
  1.3.1 / 4.1.2: The <article> element is a landmark, so it needs an accessible
  name so screen readers can distinguish it from other cards in the list.
  aria-labelledby pointing to the heading inside the card is the correct pattern.

  The title is rendered as <h3> so it participates in the page heading hierarchy.
  Entity browser widget cards appear within a field widget region which typically
  has an <h2>-level label, so h3 is an appropriate level here. Adjust if the
  surrounding markup uses a different heading level.
#}
<article{{ attributes.addClass('eb-form-selection-card') }} aria-labelledby="{{ 'eb-card-title-' ~ node.id() }}">
  {% if content.field_representative_media %}
    <div class="eb-form-selection-card__media">
      {{ content.field_representative_media }}
    </div>
  {% endif %}
  <div class="eb-form-selection-card__body">
    {# 1.3.1: Use a heading element so the card title is announced as a heading.
       The id links the aria-labelledby on the article to this element. #}
    <h3 id="eb-card-title-{{ node.id() }}" class="eb-form-selection-card__title">{{ label }}</h3>
    {% if content_type_label %}
      <div class="eb-form-selection-card__type">{{ content_type_label }}</div>
    {% endif %}
  </div>
</article>

<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;

/**
 * Implements hook_entity_type_alter().
 */
function mukurtu_export_entity_type_alter(array &$entity_types) {
  //dpm($entity_types['node']);
}

/**
 * Implements hook_preprocess_flag().
 *
 * Replaces the "Add to export list" flag link with a link to the export list
 * picker form, so users can choose which list to add the item to.
 */
function mukurtu_export_preprocess_flag(&$variables) {
  /** @var \Drupal\flag\FlagInterface $flag */
  $flag = $variables['flag'];
  if (!in_array($flag->id(), ['export_content', 'export_media'])) {
    return;
  }

  /** @var \Drupal\Core\Entity\EntityInterface $entity */
  $entity = $variables['flaggable'];
  $destination = \Drupal::request()->getRequestUri();

  $url = Url::fromRoute('mukurtu_export.add_item_to_list', [
    'entity_type' => $entity->getEntityTypeId(),
    'entity_id' => $entity->id(),
  ], [
    'query' => ['destination' => $destination],
  ]);

  // The flag template renders <a{{ attributes }}>{{ title }}</a>.
  // Replace the href with the list picker URL and strip the AJAX class so
  // the Flag module's AJAX behavior does not intercept the click.
  // Ensure attributes is an Attribute object (it may arrive as a plain array
  // when rendered inside a lazy-built placeholder).
  if (!($variables['attributes'] instanceof \Drupal\Core\Template\Attribute)) {
    $variables['attributes'] = new \Drupal\Core\Template\Attribute((array) $variables['attributes']);
  }
  $variables['attributes']['href'] = $url->toString();
  $variables['attributes']->removeClass('use-ajax');
  $variables['title'] = t('Add to export list');
}


/**
 * Implements hook_entity_operation().
 *
 * Adds "Add to export list" to the operations dropdown on node/media rows.
 */
function mukurtu_export_entity_operation(\Drupal\Core\Entity\EntityInterface $entity) {
  $supported = ['node', 'media'];
  if (!in_array($entity->getEntityTypeId(), $supported)) {
    return [];
  }
  if (!\Drupal::currentUser()->hasPermission('access mukurtu export')) {
    return [];
  }
  return [
    'add_to_export_list' => [
      'title' => t('Add to export list'),
      'url' => \Drupal\Core\Url::fromRoute('mukurtu_export.add_item_to_list', [
        'entity_type' => $entity->getEntityTypeId(),
        'entity_id' => $entity->id(),
      ], [
        'query' => ['destination' => \Drupal::request()->getRequestUri()],
      ]),
      'weight' => 50,
    ],
  ];
}

/**
 * Implements hook_form_alter().
 *
 * Intercepts Views bulk-form submissions for the export flag actions so that
 * instead of returning to the view, users land on the export list picker.
 */
function mukurtu_export_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (str_starts_with($form_id, 'views_form_')) {
    $form['#submit'][] = 'mukurtu_export_bulk_form_submit';
  }
}

/**
 * Form submit handler added by mukurtu_export_form_alter().
 */
function mukurtu_export_bulk_form_submit(&$form, FormStateInterface $form_state) {
  $export_flag_actions = [
    'flag_action.export_content_flag',
    'flag_action.export_media_flag',
  ];
  if (!in_array($form_state->getValue('action'), $export_flag_actions, TRUE)) {
    return;
  }
  $destination = \Drupal::request()->getRequestUri();
  $form_state->setRedirectUrl(\Drupal\Core\Url::fromRoute('mukurtu_export.add_items_to_list', [], ['query' => ['destination' => $destination]]));
}

function mukurtu_export_views_data() {
  $data = [];
  $data['flagging']['flagged_rendered_entity'] = [
    'field' => [
      'title' => t('Flagging: Rendered entity'),
      'help' => t('Renders the flagged entity in a view mode.'),
      'id' => 'flagged_rendered_entity',
    ],
  ];
  return $data;
}

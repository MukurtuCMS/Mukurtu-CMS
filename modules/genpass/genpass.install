<?php

/**
 * @file
 * Updates for the genpass module.
 */

/**
 * Implements hook_update_last_removed().
 */
function genpass_update_last_removed() {
  // Minimum supported version is 10.3, making 8NNN updates outmoded. Use the
  // 8.x-1.x branch to upgrade from Drupal 8 to 9, and the 2.0.x branch from
  // Drupal 9 to 10.3.
  return 8005;
}

/**
 * Adjust editorial workflow transitions and default state.
 *
 * - Remove 'archived' from save_draft.from (use the restore transition instead).
 * - Allow Stewards to publish directly from Revision Requested.
 * - Default new content to Draft so it doesn't bypass editorial review.
 */
function mukurtu_core_update_40054(): void {
  $config = \Drupal::configFactory()
    ->getEditable('workflows.workflow.mukurtu_editorial_workflow');
  if ($config->isNew()) {
    return;
  }

  $from = $config->get('type_settings.transitions.save_draft.from');
  $config->set('type_settings.transitions.save_draft.from',
    array_values(array_diff($from, ['archived'])));

  $from = $config->get('type_settings.transitions.publish.from');
  if (!in_array('revision_requested', $from, TRUE)) {
    $from[] = 'revision_requested';
    $config->set('type_settings.transitions.publish.from', $from);
  }

  $config->set('type_settings.default_moderation_state', 'draft');

  $config->save();
}

/**
 * Use content_moderation_state formatter for moderation state in views.
 */
function mukurtu_core_update_40055(): void {
  $config_factory = \Drupal::configFactory();

  $view_ids = [
    'views.view.mukurtu_manage_all_content',
    'views.view.mukurtu_content_under_review',
  ];

  foreach ($view_ids as $view_id) {
    $config = $config_factory->getEditable($view_id);
    if ($config->isNew()) {
      continue;
    }
    foreach ($config->get('display') as $display_id => $display) {
      $fields = $display['display_options']['fields'] ?? [];
      if (isset($fields['moderation_state']) && ($fields['moderation_state']['type'] ?? '') === 'string') {
        $config->set("display.$display_id.display_options.fields.moderation_state.type", 'content_moderation_state');
        $config->set("display.$display_id.display_options.fields.moderation_state.settings", []);
      }
    }
    $config->save();
  }
}

/**
 * Rename editorial workflow state "Needs Review" to "Awaiting Review".

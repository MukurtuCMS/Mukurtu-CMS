/**
 * Grant authenticated users permission to use the draft workflow transitions.
 *
 * These permissions were added to config/install in this branch but
 * config/install is only applied on fresh installs, not upgrades.
 */
function mukurtu_core_update_40050(): void {
  // Ensure the workflows module is enabled so its permissions are registered.
  if (!\Drupal::moduleHandler()->moduleExists('mukurtu_workflows')) {
    \Drupal::service('module_installer')->install(['mukurtu_workflows']);
  }

  $role = \Drupal\user\Entity\Role::load('authenticated');
  if (!$role) {
    return;
  }
  $role->grantPermission('use mukurtu_default_content_workflow transition create_new_draft');
  $role->grantPermission('use mukurtu_default_content_workflow transition publish');
  $role->save();
}


      'label_display' => 'visible',
      'provider' => 'mukurtu_setup',
      'context_mapping' => [],
    ],
    'weight' => 1,
    'additional' => [],
  ];

  $config->set('sections', $sections)->save();
}

/**
 * Grant editorial workflow transition permissions to the Language Steward role
 * so they can process dictionary words and word lists in the review queue.
 */
function mukurtu_core_update_40062(): void {
  /** @var \Drupal\og\Entity\OgRole|null $role */
  $role = \Drupal::entityTypeManager()
    ->getStorage('og_role')
    ->load('protocol-protocol-language_steward');
  if (!$role) {
    return;
  }

  $transitions = [
    'use mukurtu_editorial_workflow transition archive',
    'use mukurtu_editorial_workflow transition publish',
    'use mukurtu_editorial_workflow transition request_revision',
    'use mukurtu_editorial_workflow transition restore',
    'use mukurtu_editorial_workflow transition resubmit',
    'use mukurtu_editorial_workflow transition save_draft',
    'use mukurtu_editorial_workflow transition submit_for_review',
  ];

  foreach ($transitions as $permission) {
    if (!$role->hasPermission($permission)) {
      $role->grantPermission($permission);
    }
  }

  $role->save();
}

/**
 * Add return_to_review transition and expand request_revision to cover published state.
 */
function mukurtu_core_update_40063(): void {
  $workflow = \Drupal::configFactory()
    ->getEditable('workflows.workflow.mukurtu_editorial_workflow');
  if ($workflow->isNew()) {
    return;
  }

  // Backfill: established sites never received the revision_requested state
  // or request_revision/resubmit transitions added by the editorial workflow
  // "Part 2" commit, since that only shipped via config/install (which only
  // applies to fresh installs). Restore the canonical definitions if missing
  // or incomplete before proceeding.
  if (!$workflow->get('type_settings.states.revision_requested.weight')) {
    $workflow->set('type_settings.states.revision_requested', [
      'label' => 'Edits Needed',
      'weight' => 2,
      'published' => FALSE,
      'default_revision' => TRUE,
    ]);
  }
  if (!$workflow->get('type_settings.transitions.request_revision.to')) {
    $workflow->set('type_settings.transitions.request_revision', [
      'label' => 'Needs edits',
      'from' => ['needs_review'],
      'to' => 'revision_requested',
      'weight' => 2,
    ]);
  }
  if (!$workflow->get('type_settings.transitions.resubmit.to')) {
    $workflow->set('type_settings.transitions.resubmit', [
      'label' => 'Resubmit for review',
      'from' => ['revision_requested'],
      'to' => 'needs_review',
      'weight' => 3,
    ]);
  }

  // Add published as a valid from-state for the request_revision transition.
  $from = $workflow->get('type_settings.transitions.request_revision.from') ?? [];
  if (!in_array('published', $from)) {
    $from[] = 'published';
    $workflow->set('type_settings.transitions.request_revision.from', $from);
  }

  // Add the new return_to_review transition (published -> needs_review).
  $existing = $workflow->get('type_settings.transitions.return_to_review');
  if (empty($existing)) {
    $workflow->set('type_settings.transitions.return_to_review', [
      'label' => 'Return to Review',
      'from' => ['published'],
      'to' => 'needs_review',
      'weight' => 7,
    ]);
  }

  $workflow->save();

  // Grant the new transition permission to both steward OG roles.
  $permission = 'use mukurtu_editorial_workflow transition return_to_review';
  $og_role_storage = \Drupal::entityTypeManager()->getStorage('og_role');

  foreach (['protocol-protocol-protocol_steward', 'protocol-protocol-language_steward'] as $role_id) {
    /** @var \Drupal\og\Entity\OgRole|null $role */
    $role = $og_role_storage->load($role_id);
    if ($role && !$role->hasPermission($permission)) {
      $role->grantPermission($permission);
      $role->save();
    }
  }
}

/**
 * Rename the request_revision transition label to 'Needs edits'.
 */
function mukurtu_core_update_40064(): void {
  $workflow = \Drupal::configFactory()
    ->getEditable('workflows.workflow.mukurtu_editorial_workflow');
  if ($workflow->isNew()) {
    return;
  }
  $workflow->set('type_settings.transitions.request_revision.label', 'Needs edits');
  $workflow->save();
}

/**
 * Remove default-revision-based view filters replaced by views_query_alter.
 *
 * The status=0 filter on my_content_in_progress and the moderation_state
 * filter on review_queue both looked at the default revision, missing content
 * that was published and then re-drafted. Both are now handled in PHP using
 * EntityQuery::latestRevision().
 */
function mukurtu_core_update_40065(): void {
  $config = \Drupal::configFactory()->getEditable('views.view.mukurtu_workflow_overview');
  if ($config->isNew()) {
    return;
  }
  $config->clear('display.my_content_in_progress.display_options.filters.status');
  $config->clear('display.review_queue.display_options.filters.moderation_state');
  $config->save();
}

/**
 * Grant contributors access to view their own awaiting-review content.
 *
 * Revokes the ineffective OG-role 'view any unpublished content' permission
 * added in error -- OG role permissions never satisfy $account->hasPermission().
 * Steward access to /node/{nid}/latest is now handled by the custom
 * _mukurtu_latest_version_access route check.
 */
function mukurtu_core_update_40066(): void {
  $role = \Drupal::entityTypeManager()->getStorage('user_role')->load('authenticated');
  if ($role) {
    $changed = FALSE;
    if (!$role->hasPermission('view own unpublished content')) {
      $role->grantPermission('view own unpublished content');
      $changed = TRUE;
    }
    // view latest version was added in a prior hook; ensure it is present.
    if (!$role->hasPermission('view latest version')) {
      $role->grantPermission('view latest version');
      $changed = TRUE;
    }
    if ($changed) {
      $role->save();
    }
  }

  // Remove the OG-role permission that was added incorrectly.
  foreach (['protocol-protocol-protocol_steward', 'protocol-protocol-language_steward'] as $role_id) {
    $og_role = \Drupal::entityTypeManager()->getStorage('og_role')->load($role_id);
    if ($og_role && $og_role->hasPermission('view any unpublished content')) {
      $og_role->revokePermission('view any unpublished content');
      $og_role->save();
    }
  }
}

/**
 * Restore the geofield_mukurtu widget for field_coverage on all bundles.
 *
 * The widget was inadvertently switched to the stock leaflet_widget_default
 * widget in #1433, which routes submitted values through GeoPHP and strips
 * the GeoJSON Feature properties (including Map Point descriptions) before
 * storage.
 */
function mukurtu_core_update_40067(): void {
  $bundles = [
    'collection',
    'word_list',
    'dictionary_word',
    'place',
    'digital_heritage',
    'person',
  ];

  foreach ($bundles as $bundle) {
    $config = \Drupal::configFactory()->getEditable("core.entity_form_display.node.$bundle.default");
    if ($config->isNew() || $config->get('content.field_coverage.type') === NULL) {
      continue;
    }

    $config->set('content.field_coverage.type', 'geofield_mukurtu')->save();
  }
}

/**
 * Flush node_view cache after fixing the related content cache invalidation gap.
 */
function mukurtu_core_update_40068(): void {
  \Drupal\Core\Cache\Cache::invalidateTags(['node_view']);
}

/**
 * Remove the orphaned related content teasers display settings.
 *
 * These controls were never read anywhere in the codebase, so any value an
 * admin selected had no effect on the site.
 */
function mukurtu_core_update_40069(): void {
  \Drupal::configFactory()->getEditable('mukurtu.settings')
    ->clear('mukurtu_related_content_teasers_display_top_right')
    ->clear('mukurtu_related_content_teasers_display_bottom')
    ->save();
}

/**
 * Add the custom 403 access denied page, permission, and default config.
 */
function mukurtu_core_update_40072(): void {
  // Point the site's 403 page at the new custom access-denied route
  // (system.site.yml is not owned by Mukurtu).
  \Drupal::configFactory()
    ->getEditable('system.site')
    ->set('page.403', '/mukurtu/access-denied')
    ->save();

  // Grant the new permission to the Mukurtu Manager role.
  user_role_grant_permissions('mukurtu_manager', ['administer mukurtu access denied page']);

  // Install the default mukurtu_core.access_denied config if it doesn't
  // already exist.
  $module_path = \Drupal::service('extension.list.module')->getPath('mukurtu_core');
  $config_source = new \Drupal\Core\Config\FileStorage($module_path . '/config/install');
  $config_factory = \Drupal::configFactory();

  if ($config_factory->get('mukurtu_core.access_denied')->isNew()) {
    $data = $config_source->read('mukurtu_core.access_denied');
    if ($data) {
      $config_factory->getEditable('mukurtu_core.access_denied')->setData($data)->save();
    }
  }
}

/**
 * Show a manually-provided thumbnail image for video, remote_video, and
 * soundcloud media in the "browse" view mode used by List/Grid/Map cards,
 * falling back to the native player/embed when no thumbnail is set.
 */
function mukurtu_core_update_40073(): void {
  $config_source = new \Drupal\Core\Config\FileStorage(
    \Drupal::service('extension.list.profile')->getPath('mukurtu') . '/config/install'
  );
  $config_factory = \Drupal::configFactory();

  foreach (['media.video.browse', 'media.remote_video.browse', 'media.soundcloud.browse'] as $name) {
    $config_name = 'core.entity_view_display.' . $name;
    $data = $config_source->read($config_name);
    if ($data) {
      $config_factory->getEditable($config_name)->setData($data)->save(TRUE);
    }
  }
}

/**
 * Use the same "browse" media view mode for digital_heritage's Grid Browse
 * representative media as every other content type, instead of the
 * unrelated digital_heritage_sidebar mode.
 */
function mukurtu_core_update_40074(): void {
  $config = \Drupal::configFactory()->getEditable('core.entity_view_display.node.digital_heritage.grid_browse');
  if ($config->isNew()) {
    return;
  }
  $config->set('content.field_representative_media.settings.view_mode', 'browse')->save();
}

/**
 * Show communities/category fields in Grid mode for digital_heritage and
 * person, fix collection's Grid mode to show field_collection_image instead
 * of the unused field_representative_media, and add the collection.map_browse
 * display, so Grid/Map mode template completeness work (#1624) has the field
 * visibility it needs.
 */
function mukurtu_core_update_40075(): void {
  $config_source = new \Drupal\Core\Config\FileStorage(
    \Drupal::service('extension.list.profile')->getPath('mukurtu') . '/config/install'
  );
  $config_factory = \Drupal::configFactory();

  foreach ([
    'node.digital_heritage.grid_browse',
    'node.person.grid_browse',
    'node.collection.grid_browse',
    'node.collection.map_browse',
  ] as $name) {
    $config_name = 'core.entity_view_display.' . $name;
    $data = $config_source->read($config_name);
    if ($data) {
      $config_factory->getEditable($config_name)->setData($data)->save(TRUE);
    }
  }
}

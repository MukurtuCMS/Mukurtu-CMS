/**
 * Implements hook_theme().
 */
function mukurtu_core_theme($existing, $type, $theme, $path) {
  return [
    'mukurtu_node_add_list' => [
      'template' => 'mukurtu-node-add-list',
      'variables' => ['content' => NULL],
    ],
  ];
}

/**
 * Implements hook_entity_type_build().
 */
function mukurtu_core_entity_type_build(array &$entity_types) {
  // Prefix media URLs with 'dashboard'.
  $entity_types['media']->setLinkTemplate('add-page', '/admin/media/add');
  $entity_types['media']->setLinkTemplate('add-form', '/admin/media/add/{media_type}');
  $entity_types['media']->setLinkTemplate('canonical', '/admin/media/{media}/edit');
  $entity_types['media']->setLinkTemplate('delete-form', '/admin/media/{media}/delete');
  $entity_types['media']->setLinkTemplate('delete-multiple-form', '/admin/media/delete');
  $entity_types['media']->setLinkTemplate('edit-form', '/admin/media/{media}/edit');
  $entity_types['media']->setLinkTemplate('revision', '/admin/media/{media}/revisions/{media_revision}/view');
  //$entity_types['media']->setLinkTemplate('collection', '/admin/content/media');

  /** @var $entity_types \Drupal\Core\Entity\EntityTypeInterface[] */
  foreach (['media', 'paragraph', 'node'] as $entity_type_id) {
    if (isset($entity_types[$entity_type_id])) {
      // Take over the views_data handler until Drupal adds support for
      // fields defined via bundle class bundleFieldDefinitions.
      // See https://www.drupal.org/project/drupal/issues/2898635.
      $entity_types[$entity_type_id]->setHandlerClass('views_data', 'Drupal\mukurtu_core\MukurtuEntityViewsData');
    }
  }
}

/**
 * Implements hook_entity_field_access().
 *
 * Allow community managers to view restricted user fields (status, roles,
 * access) that core hides from non-admins.
 */
function mukurtu_core_entity_field_access($operation, \Drupal\Core\Field\FieldDefinitionInterface $field_definition, \Drupal\Core\Session\AccountInterface $account, ?\Drupal\Core\Field\FieldItemListInterface $items = NULL) {
  if ($operation !== 'view' || $field_definition->getTargetEntityTypeId() !== 'user') {
    return \Drupal\Core\Access\AccessResult::neutral();
  }
  $restricted = ['status', 'roles', 'access', 'mail'];
  if (!in_array($field_definition->getName(), $restricted)) {
    return \Drupal\Core\Access\AccessResult::neutral();
  }
  if ($account->hasPermission('administer users')) {
    return \Drupal\Core\Access\AccessResult::neutral();
  }
  $user = \Drupal\user\Entity\User::load($account->id());
  foreach (\Drupal\og\Og::getMemberships($user) as $membership) {
    if ($membership->getGroupBundle() === 'community' && $membership->hasPermission('manage members')) {
      return \Drupal\Core\Access\AccessResult::allowed()->cachePerUser()->addCacheTags(['user:' . $account->id()]);
    }
  }
  return \Drupal\Core\Access\AccessResult::neutral();
}

/**
 * Implements hook_entity_operation().
 */
function mukurtu_core_entity_operation(EntityInterface $entity) {
  $operations = [];
  if ($entity->getEntityTypeId() == 'media') {
    $operations['found_in'] = array(
      'title' => t('Found In'),
      'url' => Url::fromRoute('mukurtu_core.media_found_in', ["media" => $entity->id()]),
      'weight' => 150,
    );
  }
  if ($entity->getEntityTypeId() == 'node') {
    $operations['found_in'] = array(
      'title' => t('Found In'),
      'url' => Url::fromRoute('mukurtu_core.content_found_in', ["node" => $entity->id()]),
      'weight' => 150,
    );
  }
  if ($entity->getEntityTypeId() == 'user') {
    $account = \Drupal::currentUser();
    // Don't show approve/block on a user's own account.
    if ($account->id() == $entity->id()) {
      return $operations;
    }
    $is_site_admin = $account->hasPermission('administer users');

    // Build managed-community IDs in one pass; skip the OG query for site
    // admins who don't need community scoping.
    $cm_community_ids = [];
    if (!$is_site_admin) {
      $current_user = \Drupal\user\Entity\User::load($account->id());
      foreach (\Drupal\og\Og::getMemberships($current_user) as $membership) {
        if ($membership->getGroupBundle() === 'community' && $membership->hasPermission('manage members')) {
          $cm_community_ids[] = $membership->getGroupId();
        }
      }
    }
    $can_manage = $is_site_admin || !empty($cm_community_ids);

    if ($can_manage) {
      $target_community_ids = [];
      foreach (\Drupal\og\Og::getMemberships($entity) as $m) {
        if ($m->getGroupBundle() === 'community') {
          $target_community_ids[] = $m->getGroupId();
        }
      }

      // Show "Add to Community" unless the target is already in every community
      // the current user manages. If the current user manages no communities,
      // always show (the form handles further scoping).
      if (empty($cm_community_ids) || !empty(array_diff($cm_community_ids, $target_community_ids))) {
        $operations['add_to_community'] = [
          'title' => t('Add to Community'),
          'url' => Url::fromRoute('mukurtu_protocol.add_user_to_community', ['user' => $entity->id()]),
          'weight' => 90,
        ];
      }

      $target_is_protected = !empty(array_intersect(
        \Drupal\mukurtu_core\Controller\MukurtuUserController::PROTECTED_ROLES,
        $entity->getRoles()
      ));
      $status = $entity->get('status')->value;
      $is_pending = $entity->hasField('field_pending') && (bool) $entity->get('field_pending')->value;
      $shared_communities = array_intersect($cm_community_ids, $target_community_ids);
      $can_manage_inactive = $is_site_admin || (!$target_is_protected && !empty($shared_communities));

      if ($status == 0 && $is_pending) {
        // Pending: offer Approve (activates) or Block (explicitly blocks).
        $operations['approve_user'] = [
          'title' => t('Unblock or approve'),
          'url' => Url::fromRoute('mukurtu_core.approve_user', ['uid' => $entity->id()]),
          'weight' => 100,
          'attributes' => ['class' => ['use-ajax']],
        ];
        if ($can_manage_inactive) {
          $operations['block_user'] = [
            'title' => t('Block'),
            'url' => Url::fromRoute('mukurtu_core.block_user', ['uid' => $entity->id()]),
            'weight' => 101,
            'attributes' => ['class' => ['use-ajax']],
          ];
        }
      }
      elseif ($status == 0) {
        // Explicitly blocked: offer Approve or revert to Pending.
        $operations['approve_user'] = [
          'title' => t('Unblock or approve'),
          'url' => Url::fromRoute('mukurtu_core.approve_user', ['uid' => $entity->id()]),
          'weight' => 100,
          'attributes' => ['class' => ['use-ajax']],
        ];
        if ($can_manage_inactive) {
          $operations['set_pending_user'] = [
            'title' => t('Set pending'),
            'url' => Url::fromRoute('mukurtu_core.set_pending_user', ['uid' => $entity->id()]),
            'weight' => 101,
            'attributes' => ['class' => ['use-ajax']],
          ];
        }
      }
      else {
        // Active: offer Block or Set to Pending.
        if ($is_site_admin || !$target_is_protected) {
          if ($is_site_admin || !empty($shared_communities)) {
            $operations['block_user'] = [
              'title' => t('Block'),
              'url' => Url::fromRoute('mukurtu_core.block_user', ['uid' => $entity->id()]),
              'weight' => 100,
              'attributes' => ['class' => ['use-ajax']],
            ];
            $operations['set_pending_user'] = [
              'title' => t('Set pending'),
              'url' => Url::fromRoute('mukurtu_core.set_pending_user', ['uid' => $entity->id()]),
              'weight' => 101,
              'attributes' => ['class' => ['use-ajax']],
            ];
          }
        }
      }
    }
  }
  return $operations;
}

/**
 * Implements hook_page_attachments.
 */
function mukurtu_core_page_attachments(array &$attachments) {
  // If the user is UID 1 and there is content on the site, warn them that
  // might be a bad idea because UID 1 can do just about anything. If there's
  // no content on the site, we assume they are setting things up and we don't
  // want to bother them with the message.
  if (\Drupal::currentUser()->id() == 1) {
    $show_admin_message = TRUE;
    $query = \Drupal::entityQuery('node');
    $query->accessCheck(FALSE);
    $content_count = $query->count()->execute();
    if ($content_count === 0) {
      $show_admin_message = FALSE;
    }
    $uri = \Drupal::request()->getUri();
    $ajax_uris = [
      'ajax',
      'modal',
      'dialog',
    ];
    foreach ($ajax_uris as $ajax_uri) {
      if (str_contains($uri, $ajax_uri)) {
        $show_admin_message = FALSE;
      }
    }
    if ($show_admin_message) {
      \Drupal::messenger()->addError(t('You are logged in as the super admin (UID 1), which gives you the ability to take actions that can break the site and corrupt your data. Consider logging into a different account.'));
    }
  }

  // Add our shared JS libraries. We could scope these better.
  $attachments['#attached']['library'][] = 'mukurtu_core/mukurtu-leaflet-widget';
  $attachments['#attached']['library'][] = 'mukurtu_core/tagify-override';
  $attachments['#attached']['library'][] = 'mukurtu_core/form-disable-enter-submit';
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Changes default form values at /admin/config/people/accounts:
 *  - Disables "Enable the personal contact form by default for new users"
 */
function mukurtu_core_form_user_admin_settings_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $form['contact']['contact_default_status']['#default_value'] = false;
  $form['#attached']['library'][] = 'mukurtu_core/account-settings';
  $form['#validate'][] = 'mukurtu_core_user_admin_settings_validate';

  $form['registration_cancellation']['#weight'] = 1;
  $form['registration_cancellation']['#title'] = t('Account registration');
  $opts = &$form['registration_cancellation']['user_register']['#options'];
  $opts = [
    UserInterface::REGISTER_ADMINISTRATORS_ONLY => $opts[UserInterface::REGISTER_ADMINISTRATORS_ONLY],
    UserInterface::REGISTER_VISITORS_ADMINISTRATIVE_APPROVAL => $opts[UserInterface::REGISTER_VISITORS_ADMINISTRATIVE_APPROVAL],
    UserInterface::REGISTER_VISITORS => t('Visitors, no approval required'),
  ];
  // Move password-related fields to the bottom of the genpass registration
  // section so the form flows: who can register → genpass mode → verification.
  if (isset($form['registration_cancellation']['user_email_verification'])) {
    $form['genpass_config_registration']['user_email_verification'] = $form['registration_cancellation']['user_email_verification'];
    $form['genpass_config_registration']['user_email_verification']['#weight'] = -10;
    unset($form['registration_cancellation']['user_email_verification']);
  }
  if (isset($form['registration_cancellation']['user_password_strength'])) {
    $form['genpass_config_registration']['user_password_strength'] = $form['registration_cancellation']['user_password_strength'];
    $form['genpass_config_registration']['user_password_strength']['#weight'] = 10;
    unset($form['registration_cancellation']['user_password_strength']);
  }
  $form['genpass_config_registration']['#title'] = t('Password settings');
  $form['genpass_config_registration']['genpass_mode']['#title'] = t('Visitor password entry');
  $form['genpass_config_registration']['genpass_mode']['#options'] = [
    0 => t('Visitors <strong>must</strong> enter a password on registration. This option is not available if email verification is enabled.'),
    1 => t('Visitors <strong>may</strong> enter a password on registration. If left empty, a random password will be generated. This option is not available if email verification is enabled.'),
    2 => t('Visitors <strong>cannot</strong> enter a password on registration; a random password will be generated. This option is the only valid choice if email verification is enabled above.'),
  ];
  $form['genpass_config_registration']['#weight'] = 2;
  // blocking_deleting is created at weight 3 by FormHooks::formUserAdminSettingsAlter.

  // Combine generation parameters, service replacement, and display options
  // into a single collapsed "Generate Password Settings" group.
  $form['genpass_settings'] = [
    '#type' => 'details',
    '#title' => t('Generate Password Settings'),
    '#open' => FALSE,
    '#weight' => 4,
  ];
  foreach ([
    'genpass_display'       => 'genpass_config_registration',
    'genpass_length'        => 'genpass_config_generation',
    'genpass_override_core' => 'genpass_config_core_service',
  ] as $field => $source) {
    if (isset($form[$source][$field])) {
      $form['genpass_settings'][$field] = $form[$source][$field];
      unset($form[$source][$field]);
    }
  }
  // Visitors never see a generated password in Mukurtu — bulk-action resets
  // send a password-reset email instead. Remove the two visitor-facing options
  // so admins cannot accidentally enable them.
  if (isset($form['genpass_settings']['genpass_display']['#options'])) {
    unset(
      $form['genpass_settings']['genpass_display']['#options'][GenpassInterface::PASSWORD_DISPLAY_USER],
      $form['genpass_settings']['genpass_display']['#options'][GenpassInterface::PASSWORD_DISPLAY_BOTH],
    );
  }

  // Warn if either source group still has children after the known fields were
  // moved — a future genpass update adding new fields would otherwise be
  // silently dropped when the group is deleted below.
  foreach (['genpass_config_generation', 'genpass_config_core_service'] as $group) {
    $remaining = array_filter(
      array_keys($form[$group] ?? []),
      fn($k) => !str_starts_with($k, '#'),
    );
    if (!empty($remaining)) {
      \Drupal::logger('mukurtu_core')->warning(
        'Unexpected fields in @group will be removed from the admin settings form: @fields',
        ['@group' => $group, '@fields' => implode(', ', $remaining)],
      );
    }
  }
  unset($form['genpass_config_generation'], $form['genpass_config_core_service']);

  $form['anonymous_settings']['#weight'] = 5;
  $form['anonymous_settings']['#open'] = FALSE;
  $form['contact']['#weight'] = 6;
  $form['contact']['#open'] = FALSE;
}

/**
 * Validation handler for the account settings form.
 *
 * Genpass values and their validity:
 *   0 = "Users must enter a password"   — valid only when verify_mail is OFF.
 *   1 = "Users may enter a password"    — valid only when verify_mail is OFF.
 *   2 = "Users cannot enter a password" — always valid (the only valid choice
 *                                         when verify_mail is ON).
 *
 * admin_only: no self-registration form exists, so genpass has no effect and
 * any value is accepted.
 *
 * visitors_admin_approval: all three modes are valid. The pending-approval
 * email contains no login link; the one-time login link is only sent in the
 * activation email after the admin approves the account. Genpass flash messages
 * are suppressed for pending registrations (visitor cannot log in yet).
 */
function mukurtu_core_user_admin_settings_validate(&$form, FormStateInterface $form_state) {
  $genpass_mode = (int) $form_state->getValue('genpass_mode');
  $verify_mail = (bool) $form_state->getValue('user_email_verification');
  $register = $form_state->getValue('user_register');

  // admin_only has no self-registration, so genpass mode is irrelevant.
  if ($register === 'admin_only') {
    return;
  }

  // When email verification is on, only value 2 is valid. Values 0 and 1
  // both require a password field that Drupal core hides in this mode.
  if ($verify_mail && $genpass_mode !== 2) {
    $form_state->setError(
      $form['genpass_config_registration']['genpass_mode'],
      t('"Users cannot enter a password on registration" is the only valid choice when email verification is enabled.')
    );
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_core_form_user_login_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['#submit'][] = 'mukurtu_core_user_login_form_submit';
}

/**
 * Custom submit handler to redirect to the front page on login.
 *
 * Only redirects when no ?destination parameter is present, so mid-session
 * redirects (e.g. access-denied bounces) still land the user where they
 * were headed.
 */
function mukurtu_core_user_login_form_submit($form, FormStateInterface $form_state) {
  if (!\Drupal::request()->query->has('destination')) {
    $form_state->setRedirectUrl(Url::fromRoute('<front>'));
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_core_form_views_exposed_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $view = $form_state->getStorage('view');

  $views = ['mukurtu_manage_all_media', 'mukurtu_manage_all_content'];

  if (in_array($view['view']->id(), $views)) {
    // Replace the default textfield with an entity autocomplete.
    $form['field_mukurtu_community_target_id'] = [
      '#type' => 'entity_autocomplete',
      '#target_type' => 'node',
      '#default_value' => 0,
      '#process_default_value' => FALSE,
      '#required' => FALSE,
      '#selection_handler' => 'default',
      '#selection_settings' => [
        'target_bundles' => ['community'],
      ],
      // After entity_autocomplete sets its own #element_validate, prepend
      // ours so that '0' (the "no filter" sentinel from VBO redirect URLs)
      // is converted to '' before the autocomplete validator runs.
      '#after_build' => ['mukurtu_core_community_filter_after_build'],
    ];

    // Use our custom submit handler.
    array_unshift($form['#submit'], 'mukurtu_core_mukurtu_manage_all_content_autocomplete_submit');
  }
}

/**
 * Custom submit handler for field_mukurtu_community_target_id.
 */
function mukurtu_core_mukurtu_manage_all_content_autocomplete_submit($form, &$form_state) {
  // Hot replacing the textfield with auto complete messes up default
  // value handling. Replace it here so when there's no input
  // the view still displays results as expected.
  if (!$form_state->getValue('field_mukurtu_community_target_id')) {
    $form_state->setValue('field_mukurtu_community_target_id', 0);
  }
}

/**
 * After-build callback for the community filter autocomplete.
 *
 * Prepends a validator so that '0' (the "no filter" sentinel stored in VBO
 * redirect URLs) is treated as empty before EntityAutocomplete validation.
 */
function mukurtu_core_community_filter_after_build($element, &$form_state) {
  array_unshift($element['#element_validate'], 'mukurtu_core_community_filter_validate');
  return $element;
}

/**
 * Element validator for the community filter autocomplete.
 *
 * Converts '0' to '' so EntityAutocomplete validation treats it as empty.
 */
function mukurtu_core_community_filter_validate(&$element, FormStateInterface $form_state, &$complete_form) {
  if ($element['#value'] === '0' || $element['#value'] === 0) {
    $element['#value'] = '';
    $form_state->setValueForElement($element, '');
  }
}

/**
 * Prepares variables for list of available node type templates.
 *
 * Default template: mukurtu-node-add-list.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - content: An array of content types.
 */
function template_preprocess_mukurtu_node_add_list(array &$variables) {
  $variables['types'] = [];

  if (!empty($variables['content'])) {
    foreach ($variables['content'] as $type) {
      $variables['types'][$type->id()] = [
        'type' => $type->id(),
        'add_link' => Link::fromTextAndUrl($type->label(), Url::fromRoute('mukurtu_core.add', ['node_type' => $type->id()]))->toString(),
        'description' => [
          '#markup' => $type->getDescription(),
        ],
      ];
    }
  }
}

/**
 * Implements hook_entity_bundle_create().
 */
function mukurtu_core_entity_bundle_create($entity_type_id, $bundle) {
  // For any new node that is defined, add the content type field.
  if ($entity_type_id == 'node') {
    mukurtu_core_create_content_type_field($entity_type_id, $bundle);
  }
}

/**
 * Implements hook_entity_extra_field_info().
 */
function mukurtu_core_entity_extra_field_info() {
  $extra = [];

  foreach (NodeType::loadMultiple() as $bundle) {
    $extra['node'][$bundle->id()]['display']['field_title'] = [
      'label' => t('Title'),
      'description' => t('Title'),
      'weight' => 0,
      'visible' => TRUE,
    ];
  }
  return $extra;
}

/**
 * Implements hook_entity_base_field_info().
 */
function mukurtu_core_entity_base_field_info(EntityTypeInterface $entity_type) {
  $fields = [];

  if ($entity_type->id() == 'node') {
    // Define a computed field for representative media, a single media entity that
    // represents the specific content.

    $fields['field_representative_media'] = BaseFieldDefinition::create('entity_reference')
      ->setName('field_representative_media')
      ->setLabel(t('Representative Media'))
      ->setDescription(t('A single media item that represents the specific content.'))
      ->setComputed(TRUE)
      ->setClass('Drupal\mukurtu_core\Plugin\Field\RepresentativeMediaItemList')
      ->setSetting('target_type', 'media')
      ->setCardinality(1)
      ->setDisplayConfigurable('view', TRUE)
      ->setDisplayOptions('view', ['label' => 'hidden']);

    // Computed field for related content display.
    // @see \Drupal\mukurtu_core\Plugin\Field\AllRelatedContentItemList.
    $fields['field_all_related_content'] = BaseFieldDefinition::create('entity_reference')
      ->setName('field_all_related_content')
      ->setLabel(t('Related Content'))
      ->setDescription(t('Display field for related content.'))
      ->setComputed(TRUE)
      ->setClass('Drupal\mukurtu_core\Plugin\Field\AllRelatedContentItemList')
      ->setSetting('target_type', 'node')
      ->setCardinality(-1)
      ->setDisplayConfigurable('view', TRUE)
      ->setDisplayOptions('view', ['label' => 'hidden']);

    // Computed field for citation.
    // @see \Drupal\mukurtu_core\Plugin\Field\CitationItemList.
    $fields['field_citation'] = BaseFieldDefinition::create('text_long')
      ->setName('field_citation')
      ->setLabel(t('Citation'))
      ->setDescription(t('Citation for the item.'))
      ->setComputed(TRUE)
      ->setTranslatable(FALSE)
      ->setClass('Drupal\mukurtu_core\Plugin\Field\CitationItemList')
      ->setCardinality(1)
      ->setDisplayConfigurable('view', TRUE)
      ->setDisplayOptions('view', ['label' => 'above']);
  }

  return $fields;
}

/**
 * Implements hook_entity_type_alter().
 */
function mukurtu_core_entity_type_alter(array &$entity_types) {
  /** @var \Drupal\Core\Entity\EntityTypeInterface[] $entity_types */
  $entity_types['user']->setListBuilderClass('Drupal\mukurtu_core\MukurtuUserListBuilder');
  if (isset($entity_types['base_field_override'])) {
    $entity_types['base_field_override']->setClass(BaseFieldOverride::class);
  }
}

/**
 * Implements hook_ENTITY_TYPE_view().
 */
function mukurtu_core_node_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if ($display->getComponent('field_title')) {
    $build['field_title'] = $entity->title->view();
  }
}

/**
 * Implements hook_ENTITY_TYPE_view().
 */
function mukurtu_core_user_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  // Build status-action links on the full user profile page.
  // Skip for users viewing their own account.
  if ($view_mode == 'full' && \Drupal::currentUser()->id() != $entity->id()) {
    $status = $entity->status->value;
    $is_pending = $entity->hasField('field_pending') && (bool) $entity->get('field_pending')->value;
    $links = [];

    if ($status == 1) {
      // Active: offer Block and Set to Pending.
      $links['block'] = [
        'title' => t('Block'),
        'url' => Url::fromRoute('mukurtu_core.block_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
      $links['set_pending'] = [
        'title' => t('Set pending'),
        'url' => Url::fromRoute('mukurtu_core.set_pending_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
    }
    elseif ($is_pending) {
      // Pending: offer Approve and Block.
      $links['approve'] = [
        'title' => t('Unblock or approve'),
        'url' => Url::fromRoute('mukurtu_core.approve_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
      $links['block'] = [
        'title' => t('Block'),
        'url' => Url::fromRoute('mukurtu_core.block_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
    }
    else {
      // Blocked: offer Approve and Set to Pending.
      $links['approve'] = [
        'title' => t('Unblock or approve'),
        'url' => Url::fromRoute('mukurtu_core.approve_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
      $links['set_pending'] = [
        'title' => t('Set pending'),
        'url' => Url::fromRoute('mukurtu_core.set_pending_user', ['uid' => $entity->id()]),
        'attributes' => ['class' => ['use-ajax']],
      ];
    }

    $build['mukurtu_toggle_user_approval'] = [
      '#theme' => 'links',
      '#weight' => -2,
      '#links' => $links,
      '#attached' => ['library' => ['core/drupal.ajax']],
    ];
  }
}

/**
 * Implements hook_entity_presave().
 */
function mukurtu_core_entity_presave(EntityInterface $entity) {
  // Update content type field.
  if ($entity->getEntityTypeId() == 'node') {
    if ($entity->hasField('field_content_type')) {
      $entity->set('field_content_type', $entity->type->entity->label());
    }
  }

  // Active users are never pending; clear the flag whenever status=1.
  if ($entity->getEntityTypeId() == 'user' && $entity->hasField('field_pending')) {
    if ($entity->get('status')->value == 1) {
      $entity->set('field_pending', 0);
    }
  }

  // Prevent any code path (bulk actions, direct edits) from blocking the
  // currently logged-in user's own account.
  if ($entity instanceof \Drupal\user\Entity\User && !$entity->isNew()) {
    if ($entity->id() == \Drupal::currentUser()->id()
        && isset($entity->original)
        && $entity->original->isActive()
        && $entity->isBlocked()) {
      $entity->set('status', 1);
      \Drupal::messenger()->addWarning(t('You cannot block your own account.'));
    }
  }
}

/**
 * Implements hook_views_pre_build().
 *
 * When "Pending" is selected as the status filter, reset the exposed input to
 * "All" so BooleanOperator does not write an invalid SQL condition, and set a
 * flag for hook_views_query_alter. When "Blocked" is selected, set a flag so
 * pending users are excluded.
 */
function mukurtu_core_views_pre_build(\Drupal\views\ViewExecutable $view) {
  if ($view->storage->get('base_table') !== 'users_field_data') {
    return;
  }
  if (empty($view->filter['status'])) {
    return;
  }
  $input = $view->getExposedInput();
  $status = $input['status'] ?? NULL;

  if ($status === 'pending') {
    $input['status'] = 'All';
    $view->setExposedInput($input);
    $view->mukurtu_filter_pending = TRUE;
  }
  elseif ($status === '0') {
    // Reset so BooleanOperator adds nothing; we own the full condition.
    $input['status'] = 'All';
    $view->setExposedInput($input);
    $view->mukurtu_filter_blocked = TRUE;
  }
}

/**
 * Implements hook_views_query_alter().
 *
 * For pending: adds status=0 AND field_pending=1.
 * For blocked: adds field_pending IS NULL OR field_pending=0.
 * For mukurtu_content_browser: excludes the currently-edited node so it
 * cannot be selected as a related item, child collection, etc. (issue #776).
 */
function mukurtu_core_views_query_alter(\Drupal\views\ViewExecutable $view, \Drupal\views\Plugin\views\query\QueryPluginBase $query) {
  // Exclude the currently-edited node from the content browser to prevent
  // self-selection. original_path is added to the browser URL by the entity
  // browser Modal display plugin and contains the internal path of the calling
  // page (e.g. /node/42/edit).
  if ($view->id() === 'mukurtu_content_browser') {
    $original_path = \Drupal::request()->query->get('original_path');
    // The trailing slash after the ID is intentional: it matches edit/revision
    // paths (e.g. /node/42/edit) but not bare /node/42 view pages, which is
    // correct since the browser is only opened from node edit forms.
    if ($original_path && preg_match('#^/?node/(\d+)/#', $original_path, $matches)) {
      $query->addWhere(0, 'node_field_data.nid', (int) $matches[1], '!=');
    }
  }

  if (empty($view->mukurtu_filter_pending) && empty($view->mukurtu_filter_blocked)) {
    return;
  }
  if ($view->storage->get('base_table') !== 'users_field_data') {
    return;
  }
  /** @var \Drupal\views\Plugin\views\query\Sql $query */
  $configuration = [
    'table' => 'user__field_pending',
    'field' => 'entity_id',
    'left_table' => 'users_field_data',
    'left_field' => 'uid',
    'operator' => '=',
  ];
  $join = \Drupal::service('plugin.manager.views.join')->createInstance('standard', $configuration);
  $alias = $query->addTable('user__field_pending', NULL, $join);

  if (!empty($view->mukurtu_filter_pending)) {
    $query->addWhere(0, 'users_field_data.status', 0, '=');
    $query->addWhere(0, "$alias.field_pending_value", 1, '=');
  }
  else {
    // Blocked: status=0 AND not pending.
    $query->addWhere(0, 'users_field_data.status', 0, '=');
    $query->addWhereExpression(0, "($alias.field_pending_value IS NULL OR $alias.field_pending_value = 0)");
  }
}

/**
 * Implements hook_preprocess_views_view_field().
 *
 * Replaces "Blocked" with "Pending" in any Views status column for users
 * who have field_pending=1, so that admin-approval registrations display
 * correctly on /admin/people and similar views.
 */
function mukurtu_core_preprocess_views_view_field(&$variables) {
  $field = $variables['field'];
  if ($field->field !== 'status') {
    return;
  }
  $row = $variables['row'];
  if (empty($row->_entity) || !($row->_entity instanceof \Drupal\user\Entity\User)) {
    return;
  }
  $user = $row->_entity;
  if ($user->hasField('field_pending') && $user->get('field_pending')->value && !$user->isActive()) {
    $variables['output'] = \Drupal\Core\Render\Markup::create(t('Pending'));
  }
}

/**
 * Create the content type field.
 */
function mukurtu_core_create_content_type_field($entity_type, $bundle) {
  $entityFieldManager = \Drupal::service('entity_field.manager');
  $fields = $entityFieldManager->getFieldDefinitions($entity_type, $bundle);

  // @todo What are we doing about this field?
  if (FALSE && !isset($fields['field_content_type'])) {
    FieldConfig::create([
      'field_name' => 'field_content_type',
      'entity_type' => $entity_type,
      'bundle' => $bundle,
      'label' => 'Content Type',
      'translatable' => FALSE,
    ])->save();
  }
}

/**
 * Run $fn on the target entities, using the batch system if necessary.
 *
 * $target_entity_ids = ['node' => [1, 2, 3], 'media' => [4, 5]];
 */
function mukurtu_core_entity_batch_operation($fn, $target_entity_ids, $args = []) {
  // Count the number of entities we are processing.
  $count_entities = function ($carry, $item) {
    $carry += count($item);
    return $carry;
  };
  $item_count = array_reduce($target_entity_ids, $count_entities);

  if ($item_count == 0) {
    return;
  }

  // For fewer than 10 items, proceed without batch processing.
  if ($item_count < 10) {
    foreach ($target_entity_ids as $entity_type_id => $ids) {
      // Load the entities.
      $entity_storage = \Drupal::entityTypeManager()->getStorage($entity_type_id);
      $entities = $entity_storage->loadMultiple($ids);

      // Apply the function to each.
      foreach ($entities as $batch_entity) {
        $fn($batch_entity, $args);
      }
    }
  } else {
    // More than 10 items and we run it in batch.
    $batch_title = $args['title'] ?? t('Updating content');
    $batch = [
      'title' => $batch_title,
      'operations' => [
        [
          'mukurtu_core_entity_run_batch_operation',
          [
            [
              'entities' => $target_entity_ids,
              'fn' => $fn,
              'args' => $args,
            ],
          ],
        ],
      ],
      'file' => \Drupal::service('extension.list.module')->getPath('mukurtu_core') . '/mukurtu_core.entity_batch_operation.inc',
    ];

    batch_set($batch);
  }
}

/**
 * Flatten an entity reference field to an array of ids.
 */
function mukurtu_core_flatten_entity_ref_field($entity, $fieldname) {
  if (!$entity->hasField($fieldname)) {
    return [];
  }

  $refs = $entity->get($fieldname)->getValue();

  $flatten = function ($e) {
    return isset($e['target_id']) ? $e['target_id'] : NULL;
  };

  return array_map($flatten, $refs);
}

/**
 * Batch callback to remove an ID from an entity reference field.
 */
function mukurtu_core_batch_remove_entity_reference($entity, $args) {
  $fieldname = $args['fieldname'];
  $id_to_remove = $args['target_id'];
  if ($entity->hasField($fieldname)) {
    $current_ids = mukurtu_core_flatten_entity_ref_field($entity, $fieldname);
    if (in_array($id_to_remove, $current_ids)) {
      $entity->set($fieldname, array_diff($current_ids, [$id_to_remove]));
      $entity->save();
      return TRUE;
    }
  }
  return FALSE;
};

/**
 * Batch callback to add an ID to an entity reference field.
 */
function mukurtu_core_batch_add_entity_reference($entity, $args) {
  $fieldname = $args['fieldname'];
  $id_to_add = $args['target_id'];
  if ($entity->hasField($fieldname)) {
    $cardinality = $entity->{$fieldname}->getFieldDefinition()->getFieldStorageDefinition()->getCardinality();
    $current_ids = mukurtu_core_flatten_entity_ref_field($entity, $fieldname);
    if (!in_array($id_to_add, $current_ids)) {
      // No room to add the ref, fail.
      if ($cardinality > 0 && count($current_ids) + 1 > $cardinality) {
        return FALSE;
      }
      // Add the ref and save the entity.
      $current_ids[] = $id_to_add;
      $entity->set($fieldname, $current_ids);
      $entity->save();
      return TRUE;
    }
  }
  return FALSE;
};


/**
 * Helper function to invalidate all contained references in an ERF.
 */
function mukurtu_core_invalidate_entity_reference_field_references(EntityInterface $entity, $field) {
  $refs = $entity->get($field)->referencedEntities() ?? NULL;
  if (!empty($refs)) {
    foreach ($refs as $ref) {
      Cache::invalidateTags($ref->getCacheTagsToInvalidate());
    }
  }
}

/**
 * Implements hook_menu_links_discovered_alter().
 *
 * Add the Landing Page link in the dashboard. Cannot be defined in a
 * *.links.menu.yml file because the user can set the landing page to any node,
 * so the link to its layout page must be assembled dynamically.
 */
function mukurtu_core_menu_links_discovered_alter(&$links) {
  // Remove the core "My account" link (/user) from the account menu.
  unset($links['user.page']);

  $config = \Drupal::config('system.site');
  $homepagePath = $config->get('page.front');
  $links['mukurtu_core.landing_page_dashboard'] = [
    'title' => t('Landing Page'),
    'url' => 'internal:' . $homepagePath . '/layout',
    'menu_name' => 'dashboard-look-feel',
    'parent' => 'mukurtu_dashboard',
    'weight' => 3,
  ];

  // Add the Mukurtu Version link in the dashboard. Cannot be defined in a
  // *.links.menu.yml file because the version number will change, so the text
  // must be generated dynamically.

  // Get the version number from the VERSION.md file.
  $version = "";
  $version_path = \Drupal::service('extension.list.profile')->getPath('mukurtu') . '/VERSION.md';
  if (file_exists($version_path)) {
    if ($version_file = fopen($version_path, 'r')) {
      $version = trim(fgets($version_file));
    }
  }
  fclose($version_file);

  $links['mukurtu_core.mukurtu_version_dashboard'] = [
    'title' => t('Mukurtu Version: @version', ['@version' => $version]),
    'description' => t('Mukurtu version'),
    'menu_name' => 'dashboard-site-info',
    'parent' => 'mukurtu_dashboard',
    'url' => 'route:<nolink>',
  ];
}


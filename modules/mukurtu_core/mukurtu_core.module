}

/**
 * Implements hook_token_info_alter().
 *
 * Registers Mukurtu custom field tokens under the existing 'node' token type
 * so they appear in the token tree on the citation settings form (#1386).
 */
function mukurtu_core_token_info_alter(&$data) {
  foreach (mukurtu_core_token_fields() as $field_name => $label) {
    $data['tokens']['node'][$field_name] = [
      'name' => $label,
      'description' => t('The @label field value (Mukurtu).', ['@label' => $label]),
    ];
  }
  $data['tokens']['node']['mukurtu_communities'] = [
    'name' => t('Communities'),
    'description' => t('Comma-separated list of community names for this item (Mukurtu).'),
  ];
  $data['tokens']['node']['mukurtu_protocols'] = [
    'name' => t('Cultural Protocols'),
    'description' => t('Comma-separated list of cultural protocol names for this item (Mukurtu).'),
  ];
}

/**
 * Implements hook_tokens().
 */
function mukurtu_core_tokens($type, $tokens, array $data, array $options, BubbleableMetadata $bubbleable_metadata) {
  $replacements = [];

  if ($type !== 'node' || empty($data['node'])) {
    return $replacements;
  }

  $node = $data['node'];
  $bubbleable_metadata->addCacheableDependency($node);

  foreach (mukurtu_core_token_fields() as $field_name => $label) {
    if (!isset($tokens[$field_name])) {
      continue;
    }
    if (!$node->hasField($field_name)) {
      continue;
    }
    $replacements[$tokens[$field_name]] = mukurtu_core_token_field_value($node->get($field_name));
  }

  if (isset($tokens['mukurtu_communities']) && method_exists($node, 'getCommunities')) {
    $labels = [];
    foreach ($node->getCommunities() as $community) {
      if ($community !== NULL) {
        $labels[] = $community->label();
      }
    }
    $replacements[$tokens['mukurtu_communities']] = implode(', ', $labels);
  }

  if (isset($tokens['mukurtu_protocols']) && method_exists($node, 'getProtocolEntities')) {
    $labels = [];
    foreach ($node->getProtocolEntities() as $protocol) {
      if ($protocol !== NULL) {
        $labels[] = $protocol->label();
      }
    }
    $replacements[$tokens['mukurtu_protocols']] = implode(', ', $labels);
  }

  return $replacements;
}

/**
 * Returns a plain-text string for a field item list.
 *
 * Entity reference fields (taxonomy terms, nodes, etc.) produce a
 * comma-separated list of entity labels. Text and string fields produce
 * their plain-text value with HTML stripped.
 */
function mukurtu_core_token_field_value(FieldItemListInterface $field): string {
  if ($field->isEmpty()) {
    return '';
  }

  $field_type = $field->getFieldDefinition()->getType();

  if ($field_type === 'original_date') {
    $parts = [];
    foreach ($field as $item) {
      $date = $item->date ?? '';
      if ($date !== '') {
        $parts[] = $date;
      }
    }
    return implode(', ', $parts);
  }

  if (in_array($field_type, ['entity_reference', 'entity_reference_revisions'])) {
    $entities = $field->referencedEntities();
    // Fallback: load entities directly via storage to bypass any access-layer caching.
    if (empty($entities)) {
      $target_type = $field->getFieldDefinition()->getSetting('target_type');
      if ($target_type) {
        $storage = \Drupal::entityTypeManager()->getStorage($target_type);
        $ids = array_filter(array_column($field->getValue(), 'target_id'));
        if ($ids) {
          $entities = array_values($storage->loadMultiple($ids));
        }
      }
    }
    $labels = [];
    foreach ($entities as $entity) {
      if ($entity !== NULL) {
        $labels[] = $entity->label();
      }
    }
    return implode(', ', $labels);
  }

  $values = [];
  foreach ($field as $item) {
    $raw = strip_tags($item->getString());
    if ($raw !== '') {
      $values[] = $raw;
    }
  }
  return implode(', ', $values);
}

/**
 * Implements hook_views_data_alter().
 */
function mukurtu_core_views_data_alter(array &$data)
{

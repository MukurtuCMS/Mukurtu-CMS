<?php

use Drupal\Component\Utility\NestedArray;
use Drupal\Core\Ajax\AjaxResponse;
use Drupal\Core\Ajax\ReplaceCommand;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Link;
use Drupal\Core\Render\Element;
use Drupal\Core\Url;
use Drupal\mukurtu_media\Entity\Audio;
use Drupal\mukurtu_media\Entity\Document;
use Drupal\mukurtu_media\Entity\Image;
use Drupal\mukurtu_media\Entity\ImageInterface;
use Drupal\mukurtu_media\Entity\RemoteVideo;
use Drupal\mukurtu_media\Entity\Video;
use Drupal\mukurtu_media\Entity\ExternalEmbed;
use Drupal\mukurtu_media\Form\ExternalEmbedForm;
use Drupal\mukurtu_media\Form\MukurtuFileUploadForm;
use Drupal\media_library\Form\FileUploadForm;
use Drupal\mukurtu_media\Entity\SoundCloud;
use Symfony\Component\HttpFoundation\Request;

/**
 * Implements hook_oembed_resource_data_alter().
 *
 * Adds YouTube embed URL parameters to reduce player chrome:
 * - rel=0: suppresses related videos at end of playback
 * - modestbranding=1: removes the YouTube logo from the control bar
 */
function mukurtu_media_oembed_resource_data_alter(array &$data, string $url): void {
  if (empty($data['html']) || ($data['provider_name'] ?? '') !== 'YouTube') {
    return;
  }
  $data['html'] = preg_replace_callback(
    '/src="([^"]+)"/',
    function (array $matches): string {
      $src = $matches[1];
      $separator = str_contains($src, '?') ? '&' : '?';
      return 'src="' . $src . $separator . 'rel=0&modestbranding=1"';
    },
    $data['html']
  );
}

/**
 * Implements hook_entity_bundle_field_info_alter().
 */
function mukurtu_media_entity_bundle_info_alter(array &$bundles): void
{
  if (isset($bundles['media']['document'])) {
    $bundles['media']['document']['class'] = Document::class;
  }
  if (isset($bundles['media']['audio'])) {
    $bundles['media']['audio']['class'] = Audio::class;
  }
  if (isset($bundles['media']['image'])) {
    $bundles['media']['image']['class'] = Image::class;
  }
  if (isset($bundles['media']['remote_video'])) {
    $bundles['media']['remote_video']['class'] = RemoteVideo::class;
  }
  if (isset($bundles['media']['video'])) {
    $bundles['media']['video']['class'] = Video::class;
  }
  if (isset($bundles['media']['external_embed'])) {
    $bundles['media']['external_embed']['class'] = ExternalEmbed::class;
  }
  if (isset($bundles['media']['soundcloud'])) {
    $bundles['media']['soundcloud']['class'] = SoundCloud::class;
  }
}

/**
 * Implements hook_media_source_info_alter().
 */
function mukurtu_media_media_source_info_alter(array &$sources)
{
  if (empty($sources['external_embed']['forms']['media_library_add'])) {
    $sources['external_embed']['forms']['media_library_add'] = ExternalEmbedForm::class;
  }
  if (empty($sources['soundcloud']['forms']['media_library_add'])) {
    $sources['soundcloud']['forms']['media_library_add'] = SoundCloud::class;
  }

  // Replace core's FileUploadForm with our subclass for all file-based sources.
  // This clears stale 'media' user input before creating new entities, which
  // prevents cultural protocol checkboxes from being pre-selected when an
  // existing media item is already selected in the library browser.
  foreach ($sources as &$source) {
    $current = $source['forms']['media_library_add'] ?? NULL;
    if ($current === FileUploadForm::class) {
      $source['forms']['media_library_add'] = MukurtuFileUploadForm::class;
    }
  }
}

/**
 * Implements hook_entity_field_storage_info().
 */
function mukurtu_media_entity_field_storage_info(EntityTypeInterface $entity_type){
  if ($entity_type->id() == 'media') {
    $fields = Audio::bundleFieldDefinitions($entity_type, 'audio', []);
    $fields += Document::bundleFieldDefinitions($entity_type, 'document', []);
    $fields += ExternalEmbed::bundleFieldDefinitions($entity_type, 'external_embed', []);
    $fields += Image::bundleFieldDefinitions($entity_type, 'image', []);
    $fields += RemoteVideo::bundleFieldDefinitions($entity_type, 'remote_video', []);
    $fields += SoundCloud::bundleFieldDefinitions($entity_type, 'soundcloud', []);
    $fields += Video::bundleFieldDefinitions($entity_type, 'video', []);
    return $fields;
  }
}

/**
 * Implements hook_preprocess_entity_add_list().
 *
 * Adds bulk upload/create items to the media type list on /admin/media/add.
 */
function mukurtu_media_preprocess_entity_add_list(&$variables) {
  if (\Drupal::routeMatch()->getRouteName() !== 'entity.media.add_page') {
    return;
  }

  $bulk_items = [
    'bulk_upload_image' => [
      'bundle' => 'image',
      'route' => 'mukurtu_media.bulk_upload',
      'params' => ['media_type' => 'image'],
      'label' => t('Bulk upload images'),
      'description' => t('Upload multiple images at once.'),
    ],
    'bulk_upload_audio' => [
      'bundle' => 'audio',
      'route' => 'mukurtu_media.bulk_upload',
      'params' => ['media_type' => 'audio'],
      'label' => t('Bulk upload audio'),
      'description' => t('Upload multiple audio files at once.'),
    ],
    'bulk_upload_document' => [
      'bundle' => 'document',
      'route' => 'mukurtu_media.bulk_upload',
      'params' => ['media_type' => 'document'],
      'label' => t('Bulk upload documents'),
      'description' => t('Upload multiple documents at once.'),
    ],
    'bulk_upload_video' => [
      'bundle' => 'video',
      'route' => 'mukurtu_media.bulk_upload',
      'params' => ['media_type' => 'video'],
      'label' => t('Bulk upload videos'),
      'description' => t('Upload multiple video files at once.'),
    ],
    'bulk_create_remote_video' => [
      'bundle' => 'remote_video',
      'route' => 'mukurtu_media.bulk_create',
      'params' => ['media_type' => 'remote_video'],
      'label' => t('Bulk add remote videos'),
      'description' => t('Add multiple remote videos by URL at once.'),
    ],
    'bulk_create_soundcloud' => [
      'bundle' => 'soundcloud',
      'route' => 'mukurtu_media.bulk_create',
      'params' => ['media_type' => 'soundcloud'],
      'label' => t('Bulk add SoundCloud items'),
      'description' => t('Add multiple SoundCloud items by URL at once.'),
    ],
  ];

  foreach ($bulk_items as $key => $item) {
    // Only show bulk item if the corresponding single-add bundle is accessible.
    if (!isset($variables['bundles'][$item['bundle']])) {
      continue;
    }
    $url = Url::fromRoute($item['route'], $item['params']);
    $variables['bundles'][$key] = [
      'label' => $item['label'],
      'description' => ['#markup' => $item['description']],
      'add_link' => Link::fromTextAndUrl($item['label'], $url),
    ];
  }

  // Reorder bundles so each single-item type is immediately followed by its
  // bulk variant, producing a two-column paired layout.
  $pair_order = [
    'image'        => 'bulk_upload_image',
    'audio'        => 'bulk_upload_audio',
    'document'     => 'bulk_upload_document',
    'video'        => 'bulk_upload_video',
    'remote_video' => 'bulk_create_remote_video',
    'soundcloud'   => 'bulk_create_soundcloud',
  ];

  $ordered = [];
  foreach ($pair_order as $single_key => $bulk_key) {
    if (isset($variables['bundles'][$single_key])) {
      $ordered[$single_key] = $variables['bundles'][$single_key];
    }
    if (isset($variables['bundles'][$bulk_key])) {
      $ordered[$bulk_key] = $variables['bundles'][$bulk_key];
    }
  }
  // Append any remaining bundles that have no bulk pair (e.g. external_embed).
  foreach ($variables['bundles'] as $key => $bundle) {
    if (!isset($ordered[$key])) {
      $ordered[$key] = $bundle;
    }
  }

  $variables['bundles'] = $ordered;
  $variables['attributes']['class'][] = 'media-add-list--paired';
  $variables['#attached']['library'][] = 'mukurtu_media/media_add_page';
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_media_form_media_external_embed_add_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['actions']['submit']['#submit'][] = 'mukurtu_media_external_embed_add_redirect';
}

/**
 * Redirect to the media overview after external embed creation.
 *
 * MediaForm::save() redirects to the canonical URL (the edit form) for users
 * who lack 'access media overview' permission. Appending this handler ensures
 * all users land on /admin/content/media after creating an external embed.
 */
function mukurtu_media_external_embed_add_redirect(array &$form, FormStateInterface $form_state) {
  $form_state->setRedirectUrl(Url::fromRoute('entity.media.collection'));
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_media_form_media_document_add_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  // For new document forms, don't show the "Extracted Text" field because no
  // text has been extracted yet.
  if (isset($form['field_extracted_text'])) {
    $form['field_extracted_text']['#disabled'] = TRUE;
    $form['field_extracted_text']['#type'] = 'hidden';
  }

  // Add a process callback for the document file field. This handler will
  // attach our AJAX callback. We need to do this via a process callback because
  // ManagedFile builds its AJAX callbacks inside of its own process callbacks.
  $form['field_media_document']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';

  // Prepend a process callback for the thumbnail field to add our default
  // thumbnail logic.
  array_unshift($form["field_thumbnail"]["widget"][0]["#process"], 'mukurtu_media_process_thumb');
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_media_form_media_document_edit_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  // For existing document forms, make the "Extracted Text" field read only.
  if (isset($form['field_extracted_text'])) {
    $form['field_extracted_text']['#disabled'] = TRUE;
  }

  // Re-attach thumbnail generation and AJAX callbacks so that replacing a PDF
  // on an existing document also regenerates the thumbnail.
  $form['field_media_document']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';
  array_unshift($form['field_thumbnail']['widget'][0]['#process'], 'mukurtu_media_process_thumb');
}

function mukurtu_media_form_media_video_add_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $form['field_media_video_file']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';

  array_unshift($form["field_thumbnail"]["widget"][0]["#process"], 'mukurtu_media_process_thumb');
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_media_form_media_audio_add_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  // Add custom handling on media upload/removal.
  $form['field_media_audio_file']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function mukurtu_media_form_media_image_add_form_alter(&$form, FormStateInterface $form_state, $form_id)
{
  $form['field_media_image']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';
}

/**
 * AJAX callback for media upload with our custom thumbnail field refresh.
 *
 * Note: This is almost a 100% duplication of ManagedFile::uploadAjaxCallback.
 * If it changes, we'll need to change this. Maybe there's a way to merge our
 * thumbnail ReplaceCommand with the output of uploadAjaxCallback, but I
 * couldn't see one the first time around.
 */
function mukurtu_media_upload_ajax_callback(array &$form, FormStateInterface $form_state, Request $request) {
  /** @var \Drupal\Core\Render\RendererInterface $renderer */
  $renderer = \Drupal::service('renderer');
  $response = new AjaxResponse();

  // Handle the thumbnail replacement only if there is an uploaded media file.
  $entity = $form_state->getformObject()->getEntity();
  if (method_exists($entity, 'hasUploadedMediaFile') && $entity->hasUploadedMediaFile()) {
    // Autofill the name of the media item based on the filename.
    if (method_exists($entity, 'getMediaFilename')) {
      $filename = $entity->getMediaFilename();
      $filenameNoExt = substr($filename, 0, strrpos($filename, "."));
      $form['name']['widget'][0]['value']['#value'] = $filenameNoExt;
      $response->addCommand(new ReplaceCommand("#edit-name-wrapper > div", $form['name']['widget'][0]));

      // Use the new name as the alt text for the thumbnail image.
      if ($entity instanceof ImageInterface) {
        // Images require special handling.
        $form['field_media_image']['widget'][0]['alt']['#value'] = $filenameNoExt;
      }
      else {
        $form["field_thumbnail"]["widget"][0]["alt"]["#value"] = $filenameNoExt;
      }
    }

    $response->addCommand(new ReplaceCommand("#edit-field-thumbnail-wrapper > div > div", $form['field_thumbnail']['widget']));
  }

  $form_parents = explode('/', $request->query->get('element_parents'));

  // Sanitize form parents before using them.
  $form_parents = array_filter($form_parents, [Element::class, 'child']);

  // Retrieve the element to be rendered.
  $form = NestedArray::getValue($form, $form_parents);

  // Add the special AJAX class if a new file was added.
  $current_file_count = $form_state->get('file_upload_delta_initial');
  if (isset($form['#file_upload_delta']) && $current_file_count < $form['#file_upload_delta']) {
    $form[$current_file_count]['#attributes']['class'][] = 'ajax-new-content';
  }

  $status_messages = ['#type' => 'status_messages'];
  $form['#prefix'] .= $renderer->renderRoot($status_messages);
  $output = $renderer->renderRoot($form);
  $response->setAttachments($form['#attached']);
  $response->addCommand(new ReplaceCommand(NULL, $output));
  return $response;
}

/**
 * AJAX callback for media remove.
 *
 * Note: This is almost a 100% duplication of ManagedFile::uploadAjaxCallback.
 * If it changes, we'll need to change this. Maybe there's a way to merge our
 * thumbnail ReplaceCommand with the output of uploadAjaxCallback, but I
 * couldn't see one the first time around.
 */
function mukurtu_media_remove_ajax_callback(array &$form, FormStateInterface $form_state, Request $request) {
  /** @var \Drupal\Core\Render\RendererInterface $renderer */
  $renderer = \Drupal::service('renderer');
  $response = new AjaxResponse();

  // The file has been removed, clear the name field.
  $form['name']['widget'][0]['value']['#value'] = '';

  // Redraw the name widget.
  $response->addCommand(new ReplaceCommand("#edit-name-wrapper > div", $form['name']['widget'][0]));

  // Redraw the thumbnail field widget. The thumbnail may have been altered in the managed file process handler.
  $response->addCommand(new ReplaceCommand("#edit-field-thumbnail-wrapper > div", $form['field_thumbnail']['widget']));

  $form_parents = explode('/', $request->query->get('element_parents'));

  // Sanitize form parents before using them.
  $form_parents = array_filter($form_parents, [Element::class, 'child']);

  // Retrieve the element to be rendered.
  $form = NestedArray::getValue($form, $form_parents);

  // Add the special AJAX class if a new file was added.
  $current_file_count = $form_state->get('file_upload_delta_initial');
  if (isset($form['#file_upload_delta']) && $current_file_count < $form['#file_upload_delta']) {
    $form[$current_file_count]['#attributes']['class'][] = 'ajax-new-content';
  }

  $status_messages = ['#type' => 'status_messages'];
  $form['#prefix'] .= $renderer->renderRoot($status_messages);
  $output = $renderer->renderRoot($form);
  $response->setAttachments($form['#attached']);
  $response->addCommand(new ReplaceCommand(NULL, $output));
  return $response;
}

/**
 * Process callback for the media file upload to attach our AJAX callback.
 */
function mukurtu_media_refresh_media_process(&$element, FormStateInterface $form_state, &$complete_form) {
  $element['upload_button']['#ajax']['callback'] = 'mukurtu_media_upload_ajax_callback';
  $element['remove_button']['#ajax']['callback'] = 'mukurtu_media_remove_ajax_callback';

  return $element;
}

/**
 * Process callback for the thumbnail field to generate a thumbnail from the
 * media file.
 */
function mukurtu_media_process_thumb(&$element, FormStateInterface $form_state, &$complete_form)
{
  $entity = $form_state->getformObject()->getEntity();

  // If the user manually removes the thumbnail, don't immediately generate it
  // again.
  $triggeringElementName = $form_state->getTriggeringElement()['#name'] ?? NULL;
  $isMediaUploadButton = FALSE;

  if ($triggeringElementName && method_exists($entity, 'mediaUploadIsTriggeringElement')) {
    $isMediaUploadButton = $entity->mediaUploadIsTriggeringElement($form_state, $triggeringElementName);
  }
  if ($isMediaUploadButton) {
    // Only try thumbnail generation if the user hit the media upload button.
    // Then, only proceed if no thumbnail exists.
    $existingThumb = $complete_form['field_thumbnail']['widget'][0]['#value']['fids'] ?? NULL;
    if (!$existingThumb) {
      if (method_exists($entity, 'generateThumbnail')) {
        $fid = $entity->generateThumbnail($element, $form_state, $complete_form);
        if ($fid) {
          $element['#value']['fids'] = [$fid];
        }
        // If thumbnail generation failed, try and set the default thumbnail.
        elseif (method_exists($entity, 'getDefaultThumbnail')) {
          $defaultThumb = $entity->getDefaultThumbnail();
          if ($defaultThumb) {
            $element['#value']['fids'] = [$defaultThumb];
          }
        }
      }
    }
  }
  return $element;
}

/**
 * Implements hook_entity_base_field_info_alter().
 *
 * @param \Drupal\Core\Field\BaseFieldDefinition[] $fields
 *   The base field definitions.
 * @param \Drupal\Core\Entity\EntityTypeInterface $entity_type
 *   The entity type.
 */
function mukurtu_media_entity_base_field_info_alter(&$fields, EntityTypeInterface $entity_type) {
  if ($entity_type->id() == 'media') {
    $fields['name']->setDescription('Most media names will auto-fill from the filename or external source. This field is not usually shown to end users. While the media name can be changed, we generally recommend using the auto-filled names so that they match your other records and systems.');
  }
}

/**
 * Implements hook_entity_view_alter().
 *
 * Injects placeholder images for media reference fields in two scenarios:
 *
 * 1. Restricted media: a referenced media item exists but the current user
 *    cannot view it due to protocol restrictions.
 * 2. No media: the field has no items at all.
 *
 * hook_preprocess_field cannot be used here because Drupal's FormatterBase::view()
 * only wraps elements with #theme = 'field' when the formatter returns non-empty
 * output. When all media items are inaccessible (or absent) the formatter returns
 * [], so the preprocess hook is never called. hook_entity_view_alter fires after
 * the entity build is complete and lets us inject the field render array even when
 * it is missing entirely.
 */
function mukurtu_media_entity_view_alter(array &$build, \Drupal\Core\Entity\EntityInterface $entity, \Drupal\Core\Entity\Display\EntityViewDisplayInterface $display) {
  $config = \Drupal::config('mukurtu_media.settings');

  $restricted_fid = ($config->get('restricted_media_placeholder') ?? [])[0] ?? NULL;
  $no_media_fid   = ($config->get('no_media_placeholder') ?? [])[0] ?? NULL;

  // Nothing to do if neither placeholder is configured.
  if (!$restricted_fid && !$no_media_fid) {
    return;
  }

  // Placeholders apply to content nodes only.
  if ($entity->getEntityTypeId() !== 'node') {
    return;
  }

  $restricted_file = $restricted_fid ? \Drupal\file\Entity\File::load($restricted_fid) : NULL;
  $no_media_file   = $no_media_fid   ? \Drupal\file\Entity\File::load($no_media_fid)   : NULL;

  $account = \Drupal::currentUser();
  $media_storage = \Drupal::entityTypeManager()->getStorage('media');

  foreach ($entity->getFields() as $field_name => $field_items) {
    $def = $field_items->getFieldDefinition();
    if ($def->getType() !== 'entity_reference') {
      continue;
    }
    if ($def->getSetting('target_type') !== 'media') {
      continue;
    }

    $component = $display->getComponent($field_name);

    // --- Scenario 1: field has no items at all ---
    if ($field_items->isEmpty()) {
      if (!$component) {
        continue;
      }

      // field_representative_media is a computed field that defers to this hook
      // when a placeholder is configured. Check the source fields to determine
      // whether the underlying media is restricted (exists but inaccessible) or
      // simply absent, so we can pick the correct placeholder.
      $placeholder_file_to_use = $no_media_file;
      if ($field_name === 'field_representative_media' && $restricted_file) {
        $source_fields = ['field_thumbnail', 'field_media_assets', 'field_collection_image', 'field_word_list_image'];
        // Batch-load all source media to avoid N+1 queries.
        $source_ids = [];
        foreach ($source_fields as $source) {
          if (!$entity->hasField($source)) {
            continue;
          }
          foreach ($entity->get($source) as $source_item) {
            if ($source_item->target_id) {
              $source_ids[] = $source_item->target_id;
            }
          }
        }
        if (!empty($source_ids)) {
          foreach ($media_storage->loadMultiple($source_ids) as $source_media) {
            if (!$source_media->access('view', $account)) {
              $placeholder_file_to_use = $restricted_file;
              break;
            }
          }
        }
      }

      if (!$placeholder_file_to_use) {
        continue;
      }

      $alt = $placeholder_file_to_use === $restricted_file
        ? (string) t('Media not available due to protocol restrictions')
        : (string) t('No media available');

      $build[$field_name] = _mukurtu_media_build_placeholder_field(
        $def, $entity, $field_items, $build['#view_mode'] ?? 'full', $component,
        [
          '#theme' => 'image',
          '#uri' => $placeholder_file_to_use->getFileUri(),
          '#alt' => $alt,
          '#attributes' => ['class' => [str_replace('_', '-', $field_name) . '-placeholder']],
        ]
      );
      continue;
    }

    // --- Scenario 2: field has items but some are inaccessible ---
    if (!$restricted_file) {
      continue;
    }

    // Batch-load all media items in this field once, avoiding N+1 queries.
    $target_ids = [];
    foreach ($field_items as $item) {
      if ($item->target_id) {
        $target_ids[] = $item->target_id;
      }
    }
    if (empty($target_ids)) {
      continue;
    }
    $loaded_media = $media_storage->loadMultiple($target_ids);

    $inaccessible_count = 0;
    foreach ($loaded_media as $media) {
      if (!$media->access('view', $account)) {
        $inaccessible_count++;
      }
    }

    if ($inaccessible_count === 0) {
      continue;
    }

    $restricted_render = [
      '#theme' => 'image',
      '#uri' => $restricted_file->getFileUri(),
      '#alt' => (string) t('Media not available due to protocol restrictions'),
      '#attributes' => ['class' => ['restricted-media-placeholder']],
    ];

    $field_in_build = isset($build[$field_name]) && !empty($build[$field_name]);
    if (!$field_in_build && !$component) {
      continue;
    }

    // Walk raw items in order, mixing accessible renders with placeholders.
    $rendered_index = 0;
    $new_items = [];
    foreach ($field_items as $item) {
      $media = $loaded_media[$item->target_id] ?? NULL;
      if (!$media) {
        continue;
      }
      if ($media->access('view', $account)) {
        if ($field_in_build && isset($build[$field_name][$rendered_index])) {
          $new_items[] = $build[$field_name][$rendered_index];
        }
        $rendered_index++;
      }
      else {
        $new_items[] = $restricted_render;
      }
    }

    if (empty($new_items)) {
      continue;
    }

    if ($field_in_build) {
      foreach (array_keys($build[$field_name]) as $key) {
        if (is_numeric($key)) {
          unset($build[$field_name][$key]);
        }
      }
      foreach ($new_items as $i => $item) {
        $build[$field_name][$i] = $item;
      }
      $build[$field_name]['#cache']['contexts'][] = 'user';
    }
    else {
      $build[$field_name] = _mukurtu_media_build_placeholder_field(
        $def, $entity, $field_items, $build['#view_mode'] ?? 'full', $component,
        ...$new_items
      );
    }
  }
}

/**
 * Builds a field render array populated with placeholder item render arrays.
 *
 * @param \Drupal\Core\Field\FieldDefinitionInterface $def
 * @param \Drupal\Core\Entity\EntityInterface $entity
 * @param \Drupal\Core\Field\FieldItemListInterface $field_items
 * @param string $view_mode
 * @param array $component  Display component config (label, settings, etc.).
 * @param array ...$items   One or more render arrays to use as field items.
 *
 * @return array
 */
function _mukurtu_media_build_placeholder_field($def, $entity, $field_items, $view_mode, $component, array ...$items) {
  $build = [
    '#theme' => 'field',
    '#title' => $def->getLabel(),
    '#label_display' => $component['label'] ?? 'hidden',
    '#view_mode' => $view_mode,
    '#language' => $entity->language()->getId(),
    '#field_name' => $def->getName(),
    '#field_type' => 'entity_reference',
    '#field_translatable' => $def->isTranslatable(),
    '#entity_type' => $entity->getEntityTypeId(),
    '#bundle' => $entity->bundle(),
    '#object' => $entity,
    '#items' => $field_items,
    '#formatter' => 'entity_reference_entity_view',
    '#is_multiple' => $def->getFieldStorageDefinition()->isMultiple(),
    '#cache' => [
      'contexts' => ['user'],
      'tags' => $def->getCacheTags(),
    ],
  ];
  foreach ($items as $i => $item) {
    $build[$i] = $item;
  }
  return $build;
}

  if (!empty($widget['#upload_validators']['FileExtension']['extensions'])) {
    $ext = $widget['#upload_validators']['FileExtension']['extensions'];
    $widget['#accept'] = '.' . implode(',.', array_filter(explode(' ', $ext)));
  }

  $form['field_media_image']['widget'][0]['#process'][] = 'mukurtu_media_refresh_media_process';

}


/**
 * AJAX callback for media upload with our custom thumbnail field refresh.
 *
 * Note: This is almost a 100% duplication of ManagedFile::uploadAjaxCallback.
 * If it changes, we'll need to change this. Maybe there's a way to merge our
 * thumbnail ReplaceCommand with the output of uploadAjaxCallback, but I
 * couldn't see one the first time around.
 */
function mukurtu_media_upload_ajax_callback(array &$form, FormStateInterface $form_state, Request $request) {
  /** @var \Drupal\Core\Render\RendererInterface $renderer */
  $renderer = \Drupal::service('renderer');
  $response = new AjaxResponse();

  // Handle the thumbnail replacement only if there is an uploaded media file.
  $entity = $form_state->getformObject()->getEntity();
  if (method_exists($entity, 'hasUploadedMediaFile') && $entity->hasUploadedMediaFile()) {
    // Autofill the name of the media item based on the filename.
    if (method_exists($entity, 'getMediaFilename')) {
      $filename = $entity->getMediaFilename();
      $filenameNoExt = substr($filename, 0, strrpos($filename, "."));
      $form['name']['widget'][0]['value']['#value'] = $filenameNoExt;
      $response->addCommand(new ReplaceCommand("#edit-name-wrapper > div", $form['name']['widget'][0]));

      // Use the new name as the alt text for the thumbnail image.
      // Note: do NOT pass the alt element to a ReplaceCommand here — that would
      // pre-render it (setting #printed = TRUE) and cause renderRoot() below to
      // skip it, leaving the alt field empty. Setting #value is enough; the main
      // ReplaceCommand(NULL, $output) below re-renders the whole widget.
      if ($entity instanceof ImageInterface) {
        $form['field_media_image']['widget'][0]['alt']['#value'] = $filenameNoExt;
      }
      else {
        $form["field_thumbnail"]["widget"][0]["alt"]["#value"] = $filenameNoExt;
      }
    }

    if (!($entity instanceof ImageInterface)) {
      $response->addCommand(new ReplaceCommand("#edit-field-thumbnail-wrapper > div > div", $form['field_thumbnail']['widget']));
    }
  }

  $form_parents = explode('/', $request->query->get('element_parents'));

  // Sanitize form parents before using them.
  $form_parents = array_filter($form_parents, [Element::class, 'child']);

  // Retrieve the element to be rendered.
  $form = NestedArray::getValue($form, $form_parents);

  // Add the special AJAX class if a new file was added.
  $current_file_count = $form_state->get('file_upload_delta_initial');
  if (isset($form['#file_upload_delta']) && $current_file_count < $form['#file_upload_delta']) {
    $form[$current_file_count]['#attributes']['class'][] = 'ajax-new-content';
  }

  $status_messages = ['#type' => 'status_messages'];
  $form['#prefix'] .= $renderer->renderRoot($status_messages);
  $output = $renderer->renderRoot($form);
  $response->setAttachments($form['#attached']);
  $response->addCommand(new ReplaceCommand(NULL, $output));
  return $response;
}

/**
 * AJAX callback for media remove.
 *
 * Note: This is almost a 100% duplication of ManagedFile::uploadAjaxCallback.
 * If it changes, we'll need to change this. Maybe there's a way to merge our
 * thumbnail ReplaceCommand with the output of uploadAjaxCallback, but I
 * couldn't see one the first time around.
 */
function mukurtu_media_remove_ajax_callback(array &$form, FormStateInterface $form_state, Request $request) {
  /** @var \Drupal\Core\Render\RendererInterface $renderer */
  $renderer = \Drupal::service('renderer');
  $response = new AjaxResponse();

  // The file has been removed, clear the name field.
  $form['name']['widget'][0]['value']['#value'] = '';

  // Redraw the name widget.
  $response->addCommand(new ReplaceCommand("#edit-name-wrapper > div", $form['name']['widget'][0]));

  $entity = $form_state->getFormObject()->getEntity();
  if ($entity instanceof ImageInterface) {
    // Clear the alt text field (same no-extra-ReplaceCommand rationale as in the upload callback).
    $form['field_media_image']['widget'][0]['alt']['#value'] = '';
  }
  else {
    // Redraw the thumbnail field widget. The thumbnail may have been altered in the managed file process handler.
    $response->addCommand(new ReplaceCommand("#edit-field-thumbnail-wrapper > div", $form['field_thumbnail']['widget']));
  }

  $form_parents = explode('/', $request->query->get('element_parents'));

  // Sanitize form parents before using them.
  $form_parents = array_filter($form_parents, [Element::class, 'child']);

  // Retrieve the element to be rendered.
  $form = NestedArray::getValue($form, $form_parents);

  // Add the special AJAX class if a new file was added.
  $current_file_count = $form_state->get('file_upload_delta_initial');
  if (isset($form['#file_upload_delta']) && $current_file_count < $form['#file_upload_delta']) {
    $form[$current_file_count]['#attributes']['class'][] = 'ajax-new-content';
  }

  $status_messages = ['#type' => 'status_messages'];
  $form['#prefix'] .= $renderer->renderRoot($status_messages);
  $output = $renderer->renderRoot($form);
  $response->setAttachments($form['#attached']);
  $response->addCommand(new ReplaceCommand(NULL, $output));
  return $response;
}

/**
 * Process callback for the media file upload to attach our AJAX callback.
 */
function mukurtu_media_refresh_media_process(&$element, FormStateInterface $form_state, &$complete_form) {
  $element['upload_button']['#ajax']['callback'] = 'mukurtu_media_upload_ajax_callback';
  $element['remove_button']['#ajax']['callback'] = 'mukurtu_media_remove_ajax_callback';

  return $element;
}

/**
 * Process callback for the thumbnail field to generate a thumbnail from the
 * media file.
 */
function mukurtu_media_process_thumb(&$element, FormStateInterface $form_state, &$complete_form)
{
  $entity = $form_state->getformObject()->getEntity();

  // If the user manually removes the thumbnail, don't immediately generate it
  // again.
  $triggeringElementName = $form_state->getTriggeringElement()['#name'] ?? NULL;
  $isMediaUploadButton = FALSE;

  if ($triggeringElementName && method_exists($entity, 'mediaUploadIsTriggeringElement')) {
    $isMediaUploadButton = $entity->mediaUploadIsTriggeringElement($form_state, $triggeringElementName);
  }
  if ($isMediaUploadButton) {
    // Only try thumbnail generation if the user hit the media upload button.
    // Then, only proceed if no thumbnail exists.
    $existingThumb = $complete_form['field_thumbnail']['widget'][0]['#value']['fids'] ?? NULL;
    if (!$existingThumb) {
      if (method_exists($entity, 'generateThumbnail')) {
        $fid = $entity->generateThumbnail($element, $form_state, $complete_form);
        if ($fid) {
          $element['#value']['fids'] = [$fid];
        }
        // If thumbnail generation failed, try and set the default thumbnail.
        elseif (method_exists($entity, 'getDefaultThumbnail')) {
          $defaultThumb = $entity->getDefaultThumbnail();
          if ($defaultThumb) {
            $element['#value']['fids'] = [$defaultThumb];
          }
        }
      }
    }
  }
  return $element;
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Fixes #1096: set the HTML accept attribute on the file input in the media
 * library upload modal so the OS file picker greys out invalid extensions, the
 * same way the admin /admin/media/add forms do.
 *
 * Also fixes #198: after an image is uploaded in the modal, strip the extension
 * from the auto-generated media name and attach the JS behavior that copies the
 * name into the alt text field (PHP form alter cannot reliably set alt #value
 * in this context because ImageWidget::process adds the element after the form
 * has already been walked).
 *
 * The FID is read from the media entity stored in form state rather than from
 * the widget's #value['fids'], because the fids hidden input is not rendered
 * before the first upload AJAX and therefore has no user-submitted value.
 */
function mukurtu_media_form_media_library_add_form_upload_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (!empty($form['container']['upload']['#upload_validators']['FileExtension']['extensions'])) {
    $extensions = $form['container']['upload']['#upload_validators']['FileExtension']['extensions'];
    $accept = '.' . implode(',.', array_filter(explode(' ', $extensions)));
    $form['container']['upload']['#accept'] = $accept;
  }

  if (!isset($form['media'])) {
    return;
  }

  $added_media = $form_state->get('media') ?? [];
  $has_image = FALSE;

  foreach (Element::children($form['media']) as $delta) {
    $media_entity = $added_media[$delta] ?? NULL;
    if (!$media_entity || $media_entity->bundle() !== 'image') {
      continue;
    }

    $has_image = TRUE;

    // Get the FID from the media entity (reliable after upload).
    $fid = $media_entity->get('field_media_image')->target_id ?? NULL;
    if (!$fid) {
      continue;
    }

    $file = \Drupal\file\Entity\File::load($fid);
    if (!$file) {
      continue;
    }

    $filename = $file->getFilename();
    $basename = strrpos($filename, '.') !== FALSE
      ? substr($filename, 0, strrpos($filename, '.'))
      : $filename;

    // Strip the file extension from the auto-generated media name.
    $name_value = &$form['media'][$delta]['fields']['name']['widget'][0]['value'];
    if (isset($name_value)) {
      $current_name = $name_value['#value'] ?? $name_value['#default_value'] ?? '';
      if (preg_match('/\.[a-z0-9]{1,5}$/i', $current_name)) {
        $name_value['#value'] = $basename;
      }
    }
  }

  // Attach the JS behavior that copies the media name into the alt text field.
  // PHP cannot reliably set the alt #value here because ImageWidget::process
  // adds the alt element after hook_form_alter has run; JS runs after the full
  // DOM is written and is the reliable approach.
  if ($has_image) {
    $form['#attached']['library'][] = 'mukurtu_media/media-library-image-alt';
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Attaches the thumbnail focus behavior to the external embed modal once the
 * embed has been added and the metadata fields (including field_thumbnail) are
 * visible. Without this, uploading a thumbnail causes the modal to scroll to
 * the top because Drupal's AJAX refocus logic calls .trigger('focus') on an
 * ancestor element, which scrolls the browser to it.
 */
function mukurtu_media_form_media_library_add_form_external_embed_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (!isset($form['media'])) {
    return;
  }
  $form['#attached']['library'][] = 'mukurtu_media/media-thumb-focus';
  // Add a process callback to the thumbnail widget so we can set
  // disable_refocus on the upload/remove buttons after ManagedFile builds them.
  foreach (Element::children($form['media']) as $delta) {
    if (isset($form['media'][$delta]['fields']['field_thumbnail']['widget'][0])) {
      $form['media'][$delta]['fields']['field_thumbnail']['widget'][0]['#process'][] = 'mukurtu_media_ext_embed_thumb_disable_refocus';
    }
  }
}

/**
 * Process callback: disables AJAX refocus on the thumbnail upload/remove btns.
 *
 * Prevents Drupal's post-AJAX refocus from scrolling the media library modal
 * back to the top after a thumbnail is uploaded or removed.
 */
function mukurtu_media_ext_embed_thumb_disable_refocus(&$element, FormStateInterface $form_state, &$complete_form) {
  foreach (['upload_button', 'remove_button'] as $btn) {
    if (isset($element[$btn]['#ajax'])) {
      $element[$btn]['#ajax']['disable_refocus'] = TRUE;
    }
  }
  return $element;
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Fixes #194: auto-fill the name field for SoundCloud media created via the
 * admin form at /admin/media/add/soundcloud, matching modal behaviour.
 * AJAX fires on URL field change (blur with changed value); submit handler
 * is a fallback in case AJAX was bypassed.
 */
function mukurtu_media_form_media_soundcloud_add_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['field_media_soundcloud']['widget'][0]['value']['#ajax'] = [
    'callback' => 'mukurtu_media_soundcloud_url_ajax',
    'event' => 'change',
    'progress' => ['type' => 'throbber', 'message' => NULL],
  ];
  array_unshift($form['actions']['submit']['#submit'], 'mukurtu_media_soundcloud_admin_name_submit');
}

/**
 * AJAX callback: fetches the SoundCloud title and sets the name field value.
 */
function mukurtu_media_soundcloud_url_ajax(array &$form, FormStateInterface $form_state) {
  $response = new AjaxResponse();
  $url = trim($form_state->getValue(['field_media_soundcloud', 0, 'value']) ?? '');
  if ($url) {
    $title = SoundCloudAddForm::fetchSoundCloudTitle($url);
    if ($title) {
      $response->addCommand(new InvokeCommand('input[name="name[0][value]"]', 'val', [$title]));
    }
  }
  return $response;
}

/**
 * Submit handler: fetches the SoundCloud track title and fills the name field.
 */
function mukurtu_media_soundcloud_admin_name_submit(array &$form, FormStateInterface $form_state) {
  $name = trim($form_state->getValue(['name', 0, 'value']) ?? '');
  if ($name) {
    return;
  }
  $url = trim($form_state->getValue(['field_media_soundcloud', 0, 'value']) ?? '');
  if (!$url) {
    return;
  }
  $title = SoundCloudAddForm::fetchSoundCloudTitle($url);
  if ($title) {
    $form_state->setValue(['name', 0, 'value'], $title);
  }
}

/**
 * Implements hook_form_FORM_ID_alter().
 *
 * Fixes #194: auto-fill the name field for remote video (YouTube/Vimeo) media
 * created via the admin form at /admin/media/add/remote_video, matching modal
 * behaviour.
 * AJAX fires on URL field change (blur with changed value); submit handler
 * is a fallback in case AJAX was bypassed.
 */
function mukurtu_media_form_media_remote_video_add_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $form['field_media_oembed_video']['widget'][0]['value']['#ajax'] = [
    'callback' => 'mukurtu_media_remote_video_url_ajax',
    'event' => 'change',
    'progress' => ['type' => 'throbber', 'message' => NULL],
  ];
  array_unshift($form['actions']['submit']['#submit'], 'mukurtu_media_remote_video_admin_name_submit');
}

/**
 * AJAX callback: fetches the oEmbed title for a YouTube/Vimeo URL and sets
 * the name field value.
 */
function mukurtu_media_remote_video_url_ajax(array &$form, FormStateInterface $form_state) {
  $response = new AjaxResponse();
  $url = trim($form_state->getValue(['field_media_oembed_video', 0, 'value']) ?? '');
  if ($url) {
    try {
      $oembed_url = \Drupal::service('media.oembed.url_resolver')->getResourceUrl($url);
      $resource = \Drupal::service('media.oembed.resource_fetcher')->fetchResource($oembed_url);
      $title = $resource->getTitle();
      if ($title) {
        $response->addCommand(new InvokeCommand('input[name="name[0][value]"]', 'val', [$title]));
      }
    }
    catch (\Exception $e) {
      // oEmbed fetch failed; leave name field as-is.
    }
  }
  return $response;
}

/**
 * Submit handler: fetches the oEmbed title for a YouTube/Vimeo URL and fills
 * the name field.
 */
function mukurtu_media_remote_video_admin_name_submit(array &$form, FormStateInterface $form_state) {
  $name = trim($form_state->getValue(['name', 0, 'value']) ?? '');
  if ($name) {
    return;
  }
  $url = trim($form_state->getValue(['field_media_oembed_video', 0, 'value']) ?? '');
  if (!$url) {
    return;
  }
  try {
    $oembed_url = \Drupal::service('media.oembed.url_resolver')->getResourceUrl($url);
    $resource = \Drupal::service('media.oembed.resource_fetcher')->fetchResource($oembed_url);
    $title = $resource->getTitle();
    if ($title) {
      $form_state->setValue(['name', 0, 'value'], $title);
    }
  }
  catch (\Exception $e) {
    // oEmbed fetch failed; proceed without auto-filling name.
  }
}

/**
 * Implements hook_entity_base_field_info_alter().
 *
 * @param \Drupal\Core\Field\BaseFieldDefinition[] $fields
 *   The base field definitions.
 * @param \Drupal\Core\Entity\EntityTypeInterface $entity_type
 *   The entity type.
 */
function mukurtu_media_entity_base_field_info_alter(&$fields, EntityTypeInterface $entity_type) {
  if ($entity_type->id() == 'media') {
    $fields['name']->setDescription('Most media names will auto-fill from the filename or external source. This field is not usually shown to end users. While the media name can be changed, we generally recommend using the auto-filled names so that they match your other records and systems.');
  }
}
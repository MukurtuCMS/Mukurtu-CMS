{#
/**
 * @file
 * Template for the Mukurtu Footer block.
 *
 * Available variables:
 *   - text_field: Render array for formatted footer text (top of footer).
 *   - logos: Array of logo items, each with keys: url, alt, link_url.
 *   - social_links: Array of social link items, each with: platform, url, label.
 *   - other_links: Array of link items, each with: url, label.
 *   - contact_email_text: Label shown before the email address.
 *   - contact_email_address: The contact email address.
 *   - copyright_message: Copyright text (tokens already replaced).
 */
#}

{# --- Platform display labels for accessible link names --- #}
{% set platform_labels = {
  'twitter':   'Twitter / X',
  'facebook':  'Facebook',
  'instagram': 'Instagram',
  'youtube':   'YouTube',
  'linkedin':  'LinkedIn',
  'tiktok':    'TikTok',
  'bluesky':   'Bluesky',
  'mastodon':  'Mastodon',
} %}

{# --- SVG icon macro — keyed by platform value from the select field --- #}

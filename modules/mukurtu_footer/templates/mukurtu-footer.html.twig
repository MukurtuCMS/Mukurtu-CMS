  {% else %}
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false"><path d="M12 0C5.374 0 0 5.373 0 12c0 6.628 5.374 12 12 12s12-5.372 12-12c0-6.627-5.374-12-12-12zm0 2c5.523 0 10 4.477 10 10s-4.477 10-10 10S2 17.523 2 12 6.477 2 12 2zm1 5h-2v6H7l5 5 5-5h-4z"/></svg>
  {% endif %}
{% endmacro %}

{% import _self as icons %}

<div class="mukurtu-footer">

  {# 1. Formatted text field #}
  {% if text_field %}
    <div class="footer-text">
      {{ text_field }}
    </div>
  {% endif %}

  {# 2. Logos #}
  {% if logos %}
    <div class="logos">
      {% for logo in logos %}
        <div class="logo">
          {% if logo.link_url %}
            <a href="{{ logo.link_url }}" target="_blank" rel="noopener noreferrer"
               aria-label="{{ logo.alt ?: 'Logo'|t }}{% if logo.alt %} {% endif %}{{ '(opens in new tab)'|t }}">
              <img src="{{ logo.url }}" alt="" aria-hidden="true">
            </a>
          {% else %}
            <img src="{{ logo.url }}" alt="{{ logo.alt }}">
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# 3. Social links + other links — single flex row #}
  {% if social_links or other_links %}
    <div class="footer-links-row">
      {% for link in social_links %}
        {% set platform_label = platform_labels[link.platform] ?? link.platform %}
        {% set visible_label = link.label ?: platform_label %}
        <div class="socials__item socials__item--{{ link.platform }}">
          <a href="{{ link.url }}"
             target="_blank"
             rel="noopener noreferrer me"
             aria-label="{{ visible_label }}, {{ '(opens in new tab)'|t }}">
            <span class="socials__icon">
              {{ icons.social_icon(link.platform) }}
            </span>
            <span class="socials__label" aria-hidden="true">{{ visible_label }}</span>
          </a>
        </div>
      {% endfor %}
      {% for link in other_links %}
        <div class="footer-link-item">
          <a href="{{ link.url }}">{{ link.label ?: link.url }}</a>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {# 4. Contact email + copyright — single flex row at the bottom #}
  {% if contact_email_address or copyright_message %}
    <div class="footer-bottom-row">
      {% if contact_email_address %}
        <div class="email">
          <a href="mailto:{{ contact_email_address }}"
             aria-label="{{ 'Send an email to'|t }} {{ contact_email_address }}">
            <svg aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 21 13" fill="currentColor"><path d="M19.87.04 19.69 0H1.31L1.2.02l9.3 8.21zM20.91.86l-6.62 5.79 6.54 5.66c.1-.18.17-.39.17-.61V1.3c0-.15-.04-.3-.09-.44zM.1.8c-.06.15-.1.32-.1.5v10.4c0 .19.05.37.12.53l6.59-5.6z"/><path d="M10.5 9.97 7.7 7.5l-6.46 5.49.07.01h18.32L13.3 7.52z"/></svg>
            <span aria-hidden="true">{% if contact_email_text %}{{ contact_email_text }}{% else %}{{ contact_email_address }}{% endif %}</span>
          </a>
        </div>
      {% endif %}
      {% if copyright_message %}
        <p class="copyright-message">{{ copyright_message }}</p>
      {% endif %}
    </div>
  {% endif %}

</div>

/**
 * Implements hook_module_implements_alter().
 *
 * field_group moves its own hook_form_alter() to the end of the module list
 * so it can attach group metadata after everyone else has had a chance to
 * alter the form. Our own alter needs to run after that (to strip the
 * "Mukurtu Essentials" tabs from the embedded personal collection form), so
 * move mukurtu_collection to the end too - since this runs after
 * field_group's own reordering, it ends up after field_group.
 */
function mukurtu_collection_module_implements_alter(&$implementations, $hook) {
  mukurtu_core_move_form_alter_to_end($implementations, $hook, 'mukurtu_collection');
}

/**
 * Implements hook_form_alter().
 */
function mukurtu_collection_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Hide revision log on personal collection edit and add forms.
  if ($form_id == 'personal_collection_edit_form' || $form_id == 'personal_collection_add_form') {
    $form['revision_log']['#access'] = FALSE;
  }

  // Only run on node forms.
  if (strpos($form_id, 'node_') === 0 && strpos($form_id, '_edit_form') > 0) {
    $args = $form_state->getBuildInfo()['args'];

    // Are there any mukurtu_collection specific arguments to handle?
    if (!empty($args) && isset($args[0]['mukurtu_collection']['submit'])) {
      // We want to add this node to the target collection after the node form is submitted.
      // Add the collection ID to the form.
      $form['mukurtu_collection_target'] = [
        '#type' => 'hidden',
        '#value' => $args[0]['mukurtu_collection']['target'],
      ];

      // Attach our custom submit handler that will run after the default handler.
      $form['actions']['submit']['#submit'][] = $args[0]['mukurtu_collection']['submit'][0];
    }
  }

  // Trim the embedded "create a new personal collection" entity form down to
  // just the fields needed for a quick create - the rest can be filled in
  // later by editing the collection normally. This applies whether the form
  // is reached via the modal or its no-JS fallback page, since the same
  // overwhelming full entity form is the underlying issue either way.
  if ($form_id === 'personal_collection_form' && \Drupal::routeMatch()->getRouteName() === 'mukurtu_collection.add_item_to_personal_collection') {
    foreach (['field_summary', 'field_description', 'field_media_assets', 'field_items_in_collection', 'revision_log', 'path'] as $fieldName) {
      if (isset($form[$fieldName])) {
        $form[$fieldName]['#access'] = FALSE;
      }
    }

    // Drop the "Mukurtu Essentials" / "Items" tabs entirely - with only
    // Name and Privacy Setting left, a tabbed layout is unnecessary. Emptying
    // #fieldgroups makes field_group leave the remaining fields in their
    // normal flat positions instead of wrapping them in tab markup.
    $form['#fieldgroups'] = [];
    $form['#group_children'] = [];

    // Marks this as a quick-create dialog form for mukurtu_gin_custom's CSS,
    // which shrinks field description text so it doesn't visually dominate
    // these short forms.
    $form['#attributes']['class'][] = 'mukurtu-quick-create-form';
  }

  // Same trim for the embedded "create a new collection" entity form - keep
  // only Title and Cultural Protocols (both required; Cultural Protocols
  // can't be defaulted, since it must reflect an actual protocol the user
  // belongs to). Everything else can be filled in later by editing the
  // collection normally.
  if ($form_id === 'node_collection_form' && \Drupal::routeMatch()->getRouteName() === 'mukurtu_collection.add_item_to_collection') {
    $hideFields = [
      'field_summary', 'field_description', 'field_collection_image',
      'field_source', 'field_items_in_collection', 'field_child_collections',
      'field_related_content', 'field_keywords', 'field_coverage',
      'field_coverage_description', 'field_location', 'field_local_contexts_projects',
      'field_local_contexts_labels_and_notices', 'field_credit',
      'revision_log', 'path', 'promote', 'sticky', 'og_audience', 'uid', 'created',
      'comment', 'moderation_state',
    ];
    foreach ($hideFields as $fieldName) {
      if (isset($form[$fieldName])) {
        $form[$fieldName]['#access'] = FALSE;
      }
    }

    $form['#fieldgroups'] = [];
    $form['#group_children'] = [];

    // Not useful for a quick "create and add" flow.
    if (isset($form['actions']['preview'])) {
      $form['actions']['preview']['#access'] = FALSE;
    }

    // Marks this as a quick-create dialog form for mukurtu_gin_custom's CSS,
    // which shrinks field description text so it doesn't visually dominate
    // this short form.
    $form['#attributes']['class'][] = 'mukurtu-quick-create-form';

    // Status, Menu settings, and Review note aren't set directly on $form
    // by this point - Status/Menu settings come from core (NodeForm/menu_ui)
    // and Review note is added by
    // mukurtu_workflows_form_node_form_alter(), all via
    // hook_form_BASE_FORM_ID_alter() implementations that can run after this
    // hook_form_alter(), so #access can't be set on them here yet. Must be a
    // #pre_render callback, which runs at actual render time after all
    // alters/#process callbacks have finished, regardless of module order.
    $form['#pre_render'][] = function (array $element): array {
      foreach (['status', 'menu', 'review_note'] as $key) {
        if (isset($element[$key])) {
          $element[$key]['#access'] = FALSE;
        }
      }
      return $element;
    };
  }

  // When the "Add to Collection" or "Add to Personal Collection" forms are
  // opened inside a modal dialog (see the "use-ajax" local task links in
  // mukurtu_collection.links.task.yml), wire their submit buttons to an AJAX
  // callback that closes the dialog on success instead of doing a full page
  // navigation. The ?mukurtu_modal=1 query flag persists across the
  // drupal_modal -> drupal_ajax wrapper format switch Drupal's dialog JS
  // performs on submit, so it reliably signals "this form is in a modal."
  if (\Drupal::request()->query->get('mukurtu_modal')) {
    if (in_array($form_id, ['mukurtu_collection_add_item_to_collection_form', 'mukurtu_collection_add_item_to_personal_collection_form'])) {
      $form['submit']['#ajax'] = [
        'callback' => 'mukurtu_collection_add_to_x_dialog_ajax',
        'progress' => ['type' => 'throbber'],
      ];
    }
    elseif ($form_id === 'personal_collection_form' && \Drupal::routeMatch()->getRouteName() === 'mukurtu_collection.add_item_to_personal_collection') {
      // This is the embedded "create a new personal collection" entity form.
      // It has no "node" value of its own, so stash the item being added
      // (taken from the route, since that's what the controller built this
      // form for) so the AJAX callback knows where to send the user back to.
      $node = \Drupal::routeMatch()->getParameter('node');
      if ($node) {
        $form['mukurtu_return_node'] = [
          '#type' => 'hidden',
          '#value' => $node->id(),
        ];
      }
      $form['actions']['submit']['#ajax'] = [
        'callback' => 'mukurtu_collection_add_to_x_dialog_ajax',
        'progress' => ['type' => 'throbber'],
      ];
      // Core's dialog JS hoists any ".form-actions" button into the dialog's
      // shared buttonpane (see prepareDialogButtons() in
      // core/misc/dialog/dialog.ajax.js), even while this form's <details>
      // is collapsed. With two forms in one dialog that makes this form's
      // Save button look like "the" dialog action and swallow clicks meant
      // for the other (picker) form. Strip the class so it stays inline.
      // Must be a #pre_render callback, not done directly here - the class
      // is added by Actions::processActions(), which runs later than
      // hook_form_alter, so it isn't there yet to remove at this point.
      $form['actions']['#pre_render'][] = 'mukurtu_core_strip_form_actions_class';
    }
    elseif ($form_id === 'node_collection_form' && \Drupal::routeMatch()->getRouteName() === 'mukurtu_collection.add_item_to_collection') {
      // This is the embedded "create a new collection" entity form. It has
      // no "node" value of its own, so stash the item being added (taken
      // from the route, since that's what the controller built this form
      // for) so the AJAX callback knows where to send the user back to.
      $node = \Drupal::routeMatch()->getParameter('node');
      if ($node) {
        $form['mukurtu_return_node'] = [
          '#type' => 'hidden',
          '#value' => $node->id(),
        ];
      }
      $form['actions']['submit']['#ajax'] = [
        'callback' => 'mukurtu_collection_add_to_x_dialog_ajax',
        'progress' => ['type' => 'throbber'],
      ];
      // See the matching comment in the personal_collection_form branch
      // above - keeps this form's Save button inline instead of being
      // hoisted into the dialog's shared buttonpane.
      $form['actions']['#pre_render'][] = 'mukurtu_core_strip_form_actions_class';
    }
  }
}

/**
 * AJAX callback for the "Add to Collection" / "Add to Personal Collection"
 * forms (including the embedded "create a new personal collection" form)
 * when submitted from a modal dialog.
 *
 * Closes the dialog and returns to the item's page on a clean save; replaces
 * the dialog content with the rebuilt form (including validation messages)
 * when there are errors.
 */
function mukurtu_collection_add_to_x_dialog_ajax(array &$form, FormStateInterface $form_state): AjaxResponse {
  return mukurtu_core_modal_form_ajax_response($form, $form_state);
}

/**
 * Implements hook_entity_access().
 */
function mukurtu_collection_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  // Allow viewing of collections. Protocol access checks down the line will
  // catch any forbidden access.
  if ($operation == 'view') {
    return AccessResult::allowed();
  }
}

/**
 * Install "Manage roles" bulk actions for community and protocol members pages.
 *
 * For fresh installs, config/install/ handles these action configs automatically.
 * This hook only applies to existing sites updating from a prior release.
 */
function mukurtu_protocol_update_40011(): void {
  $module_path = \Drupal::service('extension.list.module')->getPath('mukurtu_protocol');
  $action_ids = [
    'mukurtu_manage_community_roles_action',
    'mukurtu_manage_protocol_roles_action',
  ];
  foreach ($action_ids as $action_id) {
    $config_path = $module_path . '/config/install/system.action.' . $action_id . '.yml';
    $data = \Drupal\Core\Serialization\Yaml::decode(file_get_contents($config_path));
    \Drupal::configFactory()->getEditable('system.action.' . $action_id)->setData($data)->save(TRUE);
  }
  \Drupal::service('router.builder')->rebuild();
}

/**
 * Reorder community roles: Community Member, Community Affiliate, Community Manager.
 */
function mukurtu_protocol_update_40012(): void {
  $weights = [
    'community-community-community_member'    => 13,
    'community-community-community_affiliate' => 15,
    'community-community-community_manager'   => 17,
  ];
  foreach ($weights as $role_id => $weight) {
    $config = \Drupal::configFactory()->getEditable('og.og_role.' . $role_id);
    if (!$config->isNew()) {
      $config->set('weight', $weight)->save(TRUE);
    }
  }
}

/**
 * Reorder protocol roles: Member, Affiliate, Contributor, Curator,
 * Language Contributor, Language Steward, Community Record Steward, Protocol Steward.
 */
function mukurtu_protocol_update_40013(): void {
  $weights = [
    'protocol-protocol-protocol_member'           => 10,
    'protocol-protocol-protocol_affiliate'        => 11,
    'protocol-protocol-contributor'               => 12,
    'protocol-protocol-curator'                   => 13,
    'protocol-protocol-language_contributor'      => 14,
    'protocol-protocol-language_steward'          => 15,
    'protocol-protocol-community_record_steward'  => 16,
    'protocol-protocol-protocol_steward'          => 17,
  ];
  foreach ($weights as $role_id => $weight) {
    $config = \Drupal::configFactory()->getEditable('og.og_role.' . $role_id);
    if (!$config->isNew()) {
      $config->set('weight', $weight)->save(TRUE);
    }
  }
}

/**
 * Rebuild node access grants so community-blocked users lose protocol access.

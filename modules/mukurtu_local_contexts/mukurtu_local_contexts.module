<?php

use Drupal\Core\Url;
use Drupal\mukurtu_local_contexts\LocalContextsProject;
use Drupal\mukurtu_local_contexts\LocalContextsSupportedProjectManager;

/**
 *  Implements hook_theme().
 */
function mukurtu_local_contexts_theme($existing, $type, $theme, $path) {
  return [
    'local_contexts_project' => [
      'template' => 'local-contexts-project',
      'variables' => [
        'title' => [],
        'privacy' => [],
        'project_url' => NULL,
        'tk_labels' => [],
        'bc_labels' => [],
        'notices' => [],
      ],
    ],
    'local_contexts_label' => [
      'template' => 'local-contexts-item',
      'variables' => [
        'type' => 'label',
        'text' => [],
        'name' => [],
        'svg_url' => NULL,
        'img_url' => NULL,
        'audio_url' => NULL,
        'community' => NULL,
        'translations' => [],
        'dialog_id' => NULL,
        'project_title' => NULL,
        'project_url' => NULL,
      ],
    ],
    'local_contexts_notice' => [
      'template' => 'local-contexts-item',
      'variables' => [
        'type' => 'notice',
        'text' => [],
        'name' => [],
        'svg_url' => NULL,
        'img_url' => NULL,
        'translations' => [],
        'dialog_id' => NULL,
        'project_title' => NULL,
        'project_url' => NULL,
      ],
    ],
    'local_contexts_label_group' => [
      'template' => 'local-contexts-label-group',
      'variables' => [
        'project_title' => NULL,
        'items' => [],
      ],
    ],
    'local_contexts_site_project_directory' => [
      'template' => 'local-contexts-site-project-directory',
      'variables' => [
        'description' => NULL,
        'projects' => [],
      ],
    ],
  ];
}

/**
 * Implements hook_cron().
 *
 * Note that Drupal 11.x does not yet support cron implementations using
 * classes/services. See https://www.drupal.org/project/drupal/issues/3383487.
 */
function mukurtu_local_contexts_cron() {
  // Set up the required services.
  $logger = \Drupal::logger('cron');
  $state = \Drupal::state();
  $now = \Drupal::time()->getCurrentTime();

  //$interval = (int) $config->get('hub_refresh_interval') ?: 86400;
  $interval = 1;
  $last_run = (int) $state->get('mukurtu_local_contexts.hub_last_refresh', 0);

  // Only run if the configured interval has passed.
  if ($now - $last_run < $interval) {
    return;
  }

  // Update the last run timestamp.
  $state->set('mukurtu_local_contexts.hub_last_refresh', $now);

  $projects = [];
  $project_count = 0;

  try {
    $supported_project_manager = \Drupal::service('mukurtu_local_contexts.supported_project_manager');
    assert($supported_project_manager instanceof LocalContextsSupportedProjectManager);
    $projects = $supported_project_manager->getAllProjects();

    // If no Local Contexts projects are configured, skip the sync.
    if (empty($projects)) {
      return;
    }

    // Each supported project now records which API key added/owns it, so
    // resolution happens per project rather than per group. This allows a
    // site, community, or protocol to sync projects added under different
    // Local Contexts Hub API keys.
    foreach ($projects as $project_id => $project) {
      $api_key = $project['api_key'] ?? NULL;

      // Skip (and log) projects with no known API key. This does not affect
      // sibling projects in the same site/community/protocol.
      if (empty($api_key)) {
        if ($project['type'] === 'site') {
          $error_message = 'No Local Contexts API key found for the site project @title (ID @id). This prevented it from syncing. <a href=":url">Configure the Local Contexts settings to add or update a site-wide API key</a>.';
          $error_url = Url::fromRoute('mukurtu_local_contexts.manage_site_supported_projects')->toString();
        }
        else {
          $error_message = 'No Local Contexts API key found for the project @title (ID @id) on the @type with ID @group_id. This prevented it from syncing. <a href=":url">Edit the Local Contexts settings to add or update an API key for this @type</a>.';
          $error_url = Url::fromRoute('mukurtu_local_contexts.manage_' . $project['type'] . '_supported_projects', ['group' => $project['group_id']])->toString();
        }
        $logger->error($error_message, [
          '@type' => $project['type'],
          '@title' => $project['title'] ?? $project_id,
          '@id' => $project_id,
          '@group_id' => $project['group_id'],
          ':url' => $error_url,
        ]);
        continue;
      }

      $lc_project = new LocalContextsProject($project_id);
      if ($lc_project->fetchFromHub($api_key)) {
        $project_count++;
      }
    }
  }
  catch (\Exception $e) {
    $logger->error('Mukurtu Local Contexts sync failed: @msg', ['@msg' => $e->getMessage()]);
  }

  $logger->info('Mukurtu Local Contexts synced @count of @total projects with Local Contexts hub.', ['@time' => date('c', $now), '@count' => $project_count, '@total' => count($projects)]);
}

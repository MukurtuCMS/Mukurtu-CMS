<?php

/**
 * @file
 * Provides the Mukurtu content moderation workflows.
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\FieldableEntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeInterface;
use Drupal\views\ViewExecutable;
use Drupal\views\Plugin\views\query\QueryPluginBase;

/**
 * Implements hook_theme().
 */
function mukurtu_workflows_theme(): array {
  return [
    'mukurtu_review_panel' => [
      'variables' => [
        'notes' => [],
        'form' => NULL,
        'state' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_form_workflow_edit_form_alter().
 *
 * Redirects back to the Mukurtu workflow settings page after saving.
 */
function mukurtu_workflows_form_workflow_edit_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['actions']['submit']['#submit'][] = 'mukurtu_workflows_redirect_to_settings';
}

/**
 * Implements hook_form_workflow_add_form_alter().
 *
 * - Renames "Label" to "Workflow name".
 * - Hides the workflow type select (only one option exists on this site).
 * - Redirects to the workflow edit form so users can configure states and
 *   transitions immediately after naming their workflow.
 */
function mukurtu_workflows_form_workflow_add_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  $form['label']['#title'] = t('Workflow name');

  // Only one workflow type plugin exists (content_moderation), so hide the
  // select and set the value automatically.
  $form['workflow_type'] = [
    '#type' => 'value',
    '#value' => 'content_moderation',
  ];

  $form['actions']['submit']['#submit'][] = 'mukurtu_workflows_redirect_to_workflow_edit';
}

/**
 * Submit handler: redirect to the workflow edit form.
 */
function mukurtu_workflows_redirect_to_workflow_edit(array &$form, FormStateInterface $form_state): void {
  /** @var \Drupal\workflows\WorkflowInterface $workflow */
  $workflow = $form_state->getFormObject()->getEntity();
  $form_state->setRedirectUrl($workflow->toUrl('edit-form'));
}

/**
 * Submit handler: redirect to the Mukurtu publishing workflow settings page.
 */
function mukurtu_workflows_redirect_to_settings(array &$form, FormStateInterface $form_state): void {
  $form_state->setRedirectUrl(Url::fromRoute('mukurtu_workflows.settings'));
}

/**
 * Implements hook_entity_view().
 *
 * Adds CSS classes for editorial workflow states so themes can style
 * needs_review and revision_requested content distinctly.
 */
function mukurtu_workflows_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode): void {
  if (!$entity instanceof FieldableEntityInterface || !$entity->hasField('moderation_state')) {
    return;
  }
  $state = $entity->get('moderation_state')->value;
  if (in_array($state, ['needs_review', 'revision_requested'], TRUE)) {
    $build['#attributes']['class'][] = 'node--editorial-' . str_replace('_', '-', $state);
  }
}

/**
 * Implements hook_preprocess_node().
 *
 * Injects the review history and state-change panel into title_prefix (after
 * the status banner) on full node view pages. Only visible to users with edit
 * access on the node and not shown for published content.
 */
function mukurtu_workflows_preprocess_node(array &$variables): void {
  if ($variables['view_mode'] !== 'full') {
    return;
  }

  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];
  if (!($node instanceof NodeInterface) || !$node->hasField('moderation_state')) {
    return;
  }

  $state = $node->get('moderation_state')->value;

  // No panel needed on published content; state changes go through edit.
  if ($state === 'published') {
    return;
  }

  // Restrict to users who can edit this node (authors + protocol stewards).
  if (!$node->access('update')) {
    return;
  }

  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('mukurtu_review_note')) {
    return;
  }

  $nid = (int) $node->id();

  // Load review notes oldest-first.
  $rows = \Drupal::database()->select('mukurtu_review_note', 'mrn')
    ->fields('mrn')
    ->condition('mrn.nid', $nid)
    ->orderBy('mrn.created', 'ASC')
    ->execute()
    ->fetchAll();

  // Build human-readable state labels from the node's workflow.
  $state_labels = [];
  /** @var \Drupal\content_moderation\ModerationInformationInterface $mod_info */
  $mod_info = \Drupal::service('content_moderation.moderation_information');
  $workflow = $mod_info->getWorkflowForEntity($node);
  if ($workflow) {
    foreach ($workflow->getTypePlugin()->getStates() as $sid => $wf_state) {
      $state_labels[$sid] = $wf_state->label();
    }
  }

  // Batch-load all authors in a single query to avoid N+1 per note.
  $user_storage = \Drupal::entityTypeManager()->getStorage('user');
  $date_formatter = \Drupal::service('date.formatter');
  $uids = array_unique(array_column((array) $rows, 'uid'));
  $authors = $user_storage->loadMultiple($uids);

  $notes = [];
  foreach ($rows as $row) {
    $author = $authors[$row->uid] ?? NULL;
    $notes[] = [
      'author' => $author ? $author->getDisplayName() : \Drupal::t('Unknown'),
      'created' => $date_formatter->format((int) $row->created, 'medium'),
      'from_state' => $row->from_state,
      'to_state' => $row->to_state,
      'from_state_label' => $state_labels[$row->from_state] ?? $row->from_state,
      'to_state_label' => $state_labels[$row->to_state] ?? $row->to_state,
      'state_changed' => $row->from_state !== $row->to_state,
      'note' => $row->note,
    ];
  }

  // Build the state-change form; it returns empty if the user has no allowed
  // transitions, so we only embed it when it has actionable elements.
  $form = \Drupal::formBuilder()->getForm(
    \Drupal\mukurtu_workflows\Form\ReviewStateForm::class,
    $node
  );
  $has_form = !empty($form['actions']);

  // Only show the panel when there is something to display.
  if (empty($notes) && !$has_form) {
    return;
  }

  // Place in title_prefix (weight 10, after the status banner at weight 0) so
  // the panel's summary visually attaches to the bottom of the state banner in
  // all node templates, including type-specific overrides that don't use
  // {{ content }}.
  $variables['title_prefix']['review_panel'] = [
    '#theme' => 'mukurtu_review_panel',
    '#notes' => $notes,
    '#form' => $has_form ? $form : NULL,
    '#state' => $state,
    '#weight' => 10,
    '#attached' => [
      'library' => ['mukurtu_workflows/review-panel'],
    ],
    '#cache' => [
      'contexts' => ['user', 'user.permissions'],
      'tags' => ['node:' . $nid],
    ],
  ];
}

/**
 * Implements hook_views_query_alter().
 *
 * Scopes the content-under-review view to protocols where the current user
 * is a Protocol Steward. Site admins (bypass node access) see all content.
 */
function mukurtu_workflows_views_query_alter(ViewExecutable $view, QueryPluginBase $query): void {
  $is_content_under_review = $view->id() === 'mukurtu_content_under_review';
  $is_review_queue = $view->id() === 'mukurtu_workflow_overview' && $view->current_display === 'review_queue';
  if (!$is_content_under_review && !$is_review_queue) {
    return;
  }

  $account = \Drupal::currentUser();

  if ($account->hasPermission('bypass node access') || $account->hasPermission('administer nodes')) {
    return;
  }

  /** @var \Drupal\og\MembershipManagerInterface $membership_manager */
  $membership_manager = \Drupal::service('og.membership_manager');
  $memberships = $membership_manager->getMemberships($account->id());

  $steward_protocol_ids = [];
  foreach ($memberships as $membership) {
    // Protocols are a custom OG group entity type 'protocol', not 'node'.
    if ($membership->getGroupEntityType() === 'protocol' &&
        $membership->hasRole('protocol-protocol-protocol_steward')) {
      $steward_protocol_ids[] = (int) $membership->getGroupId();
    }
  }

  if (empty($steward_protocol_ids)) {
    // User stewards no protocols; return an empty result set.
    $query->addWhereExpression(0, '1 = 0');
    return;
  }

  // Find nodes in stewarded protocols via EntityQuery so the cultural_protocol
  // field's pipe-delimited storage format is handled correctly regardless of
  // the underlying table structure.
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $nid_query = $node_storage->getQuery()->accessCheck(FALSE);
  $or = $nid_query->orConditionGroup();
  foreach ($steward_protocol_ids as $pid) {
    $or->condition('field_cultural_protocols.protocols', '|' . $pid . '|', 'CONTAINS');
  }
  $nid_query->condition($or);
  $nids = array_values($nid_query->execute());
  if (empty($nids)) {
    $query->addWhereExpression(0, '1 = 0');
    return;
  }
  $query->addWhere(0, 'node_field_data.nid', $nids, 'IN');
}

/**
 * Implements hook_form_node_form_alter().
 *
 * Adds a "Review note" textarea below the moderation state widget on node
 * edit forms. A post-save submit handler persists the note.
 */
function mukurtu_workflows_form_node_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  // Only add the field when the moderation state widget is present.
  if (empty($form['moderation_state'])) {
    return;
  }

  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_state->getFormObject()->getEntity();
  if (!$node->hasField('moderation_state')) {
    return;
  }

  // Capture the node's current state at form-build time so the submit handler
  // can record a from_state without reloading the pre-save node.
  $form['review_note_from_state'] = [
    '#type' => 'hidden',
    '#value' => $node->get('moderation_state')->value,
  ];

  $form['review_note'] = [
    '#type' => 'textarea',
    '#title' => t('Review note'),
    '#required' => FALSE,
    '#rows' => 3,
    '#weight' => $form['moderation_state']['#weight'] ?? 100,
    '#states' => [],
  ];

  // Append post-save handler. Form-level #submit handlers run after the node
  // has already been saved by EntityForm::save(), so the new node state is
  // available via the entity on the form object.
  $form['#submit'][] = 'mukurtu_workflows_node_form_submit';
}

/**
 * Form submit handler: saves a review note after the node edit form saves.
 */
function mukurtu_workflows_node_form_submit(array &$form, FormStateInterface $form_state): void {
  $note_text = trim((string) ($form_state->getValue('review_note') ?? ''));
  $from_state = (string) ($form_state->getValue('review_note_from_state') ?? '');

  /** @var \Drupal\node\NodeInterface $node */
  $node = $form_state->getFormObject()->getEntity();
  $to_state = $node->get('moderation_state')->value;
  $nid = (int) $node->id();

  // Only save a note if the state changed or the user left a note.
  if ($from_state === $to_state && $note_text === '') {
    return;
  }

  $schema = \Drupal::database()->schema();
  if (!$schema->tableExists('mukurtu_review_note')) {
    return;
  }

  \Drupal::database()->insert('mukurtu_review_note')
    ->fields([
      'nid' => $nid,
      'uid' => (int) \Drupal::currentUser()->id(),
      'created' => \Drupal::time()->getRequestTime(),
      'from_state' => $from_state,
      'to_state' => $to_state,
      'note' => $note_text !== '' ? $note_text : NULL,
    ])
    ->execute();
}

/**
 * Returns TRUE when the Mukurtu editorial workflow is the active workflow.
 *
 * Uses content_moderation's own API so the check is authoritative regardless
 * of how the workflow was configured. Result is statically cached.
 */
function _mukurtu_workflows_editorial_workflow_active(): bool {
  $cache = &drupal_static(__FUNCTION__);
  if (!isset($cache)) {
    $cache = FALSE;
    if (!\Drupal::hasService('content_moderation.moderation_information')) {
      return $cache;
    }
    /** @var \Drupal\content_moderation\ModerationInformationInterface $mod_info */
    $mod_info = \Drupal::service('content_moderation.moderation_information');
    $node_types = \Drupal::entityTypeManager()->getStorage('node_type')->loadMultiple();
    foreach ($node_types as $bundle_id => $type) {
      $workflow = $mod_info->getWorkflowForEntityTypeAndBundle('node', $bundle_id);
      if ($workflow && $workflow->id() === 'mukurtu_editorial_workflow') {
        $cache = TRUE;
        break;
      }
    }
  }
  return $cache;
}

/**
 * Implements hook_form_alter().
 *
 * Removes Publish and Unpublish from the VBO bulk-action select on
 * /admin/content when the editorial workflow is active. State changes should
 * go through the moderation widget, not direct publish/unpublish actions.
 */
function mukurtu_workflows_form_alter(array &$form, FormStateInterface $form_state, string $form_id): void {
  if ($form_id !== 'views_form_mukurtu_manage_all_content_mukurtu_manage_content') {
    return;
  }
  if (!_mukurtu_workflows_editorial_workflow_active()) {
    return;
  }
  $vbo_actions = ['entity:publish_action:node', 'entity:unpublish_action:node'];
  _mukurtu_workflows_remove_vbo_actions($form, $vbo_actions);
}

/**
 * Recursively removes specific action IDs from any VBO action select element.
 */
function _mukurtu_workflows_remove_vbo_actions(array &$element, array $action_ids): void {
  // Modify this element if it is a select with the target action IDs, then
  // always recurse -- the form has many selects (filter dropdowns, etc.) and
  // the VBO action select may appear anywhere in the tree.
  if (isset($element['#type']) && $element['#type'] === 'select' && isset($element['#options'])) {
    foreach ($action_ids as $id) {
      unset($element['#options'][$id]);
    }
  }
  foreach (\Drupal\Core\Render\Element::children($element) as $key) {
    _mukurtu_workflows_remove_vbo_actions($element[$key], $action_ids);
  }
}

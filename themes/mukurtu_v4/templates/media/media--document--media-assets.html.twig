{#
/**
 * @file
 * Theme override to present a document in the media assets field.
 *
 * Available variables:
 * - media: The media item, with limited access to object properties and
 *   methods. Only method names starting with "get", "has", or "is" and
 *   a few common methods such as "id", "label", and "bundle" are available.
 *   For example:
 *   - entity.getEntityTypeId() will return the entity type ID.
 *   - entity.hasField('field_example') returns TRUE if the entity includes
 *     field_example. (This does not indicate the presence of a value in this
 *     field.)
 *   Calling other methods, such as entity.delete(), will result in
 *   an exception.
 *   See \Drupal\Core\Entity\EntityInterface for a full list of methods.
 * - name: Name of the media item.
 * - content: Media content.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 * - view_mode: View mode; for example, "teaser" or "full".
 * - attributes: HTML attributes for the containing element.
 * - title_attributes: Same as attributes, except applied to the main title
 *   tag that appears in the template.
 * - bundle: machine name of media type.
 * @see template_preprocess_media()
 */
#}
{%
  set classes = [
    'media',
    'media--' ~ bundle
  ]
%}

<div{{ attributes.addClass(classes) }}>
  {{ content.media_content_warnings }}

  <a href="#document-{{ media.id }}" data-type="inline" class="media-asset--link" aria-label="Expand {{ name }} document">
    <span class="media-asset--expand">Expand +</span>
    <span class="media-asset--content">
      <img alt="document {{ name }}" src="{{ base_path }}profiles/mukurtu/themes/mukurtu_v4/images/document.png">
    </span>
  </a>

  <div id="document-{{ media.id }}" class="media-asset--glightbox-inline">
    <object data="{{ media_url }}#navpanes=0" type="application/pdf"
            title="Document: {{ name }}" class="media-asset--document-viewer">
      <p>This PDF cannot be displayed inline.
        <a href="{{ media_url }}" target="_blank" rel="noopener">Open {{ name }}</a> or
        <a href="{{ media_url }}" download>download it</a>.
      </p>
    </object>
    <div class="media-asset--pdf-actions">
      <a href="{{ media_url }}" class="button" target="_blank" rel="noopener"
         aria-label="Open {{ name }} document in new tab">Open full screen
        <span class="visually-hidden">(opens in new tab)</span>
      </a>
      {% if media_download_enabled %}
        <a href="{{ media_url }}" class="button button--download" download aria-label="Download {{ name }} document">Download document <svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" width="16" height="18" aria-hidden="true"><path d="M11.61 0H3.87v5.57H0L7.74 13l7.74-7.43h-3.87z"/><path fill-rule="evenodd" d="M.52 15H16v3H.52z" clip-rule="evenodd"/></svg></a>
      {% endif %}
    </div>
  </div>

</div>

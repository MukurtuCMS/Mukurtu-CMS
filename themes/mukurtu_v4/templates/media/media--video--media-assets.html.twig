{#
/**
 * @file
 * Theme override to present an uploaded video in the media assets field.
 *
 * Available variables:
 * - media: The media item, with limited access to object properties and
 *   methods. Only method names starting with "get", "has", or "is" and
 *   a few common methods such as "id", "label", and "bundle" are available.
 *   For example:
 *   - entity.getEntityTypeId() will return the entity type ID.
 *   - entity.hasField('field_example') returns TRUE if the entity includes
 *     field_example. (This does not indicate the presence of a value in this
 *     field.)
 *   Calling other methods, such as entity.delete(), will result in
 *   an exception.
 *   See \Drupal\Core\Entity\EntityInterface for a full list of methods.
 * - name: Name of the media item.
 * - content: Media content.
 * - title_prefix: Additional output populated by modules, intended to be
 *   displayed in front of the main title tag that appears in the template.
 * - title_suffix: Additional output populated by modules, intended to be
 *   displayed after the main title tag that appears in the template.
 * - view_mode: View mode; for example, "teaser" or "full".
 * - attributes: HTML attributes for the containing element.
 * - title_attributes: Same as attributes, except applied to the main title
 *   tag that appears in the template.
 * - bundle: machine name of media type.
 * @see template_preprocess_media()
 */
#}
{%
  set classes = [
    'media',
    'media--' ~ bundle
  ]
%}

<div class="media-asset--slide">
  <div{{ attributes.addClass(classes) }}>
    {{ title_suffix.contextual_links }}

    {{ content.media_content_warnings }}
    <div class="media-asset--content">
      {{ content|without('media_content_warnings') }}
    </div>

    <div id="video-{{ media.id }}" class="media-asset--glightbox-inline">
      <div class="media media--video">
        {{ content.media_content_warnings }}
        {{ content.field_media_video_file }}
      </div>
    </div>
  </div>

  <div class="media-asset--actions">
    <a href="#video-{{ media.id }}" data-type="inline" class="media-asset--link button" aria-label="Expand {{ name }} video">Expand +</a>
    {% if media_download_enabled %}
      <a href="{{ media_url }}" class="button button--download" download aria-label="Download video: {{ name }}">Download video <svg xmlns="http://www.w3.org/2000/svg" xml:space="preserve" width="16" height="18" aria-hidden="true"><path d="M11.61 0H3.87v5.57H0L7.74 13l7.74-7.43h-3.87z"/><path fill-rule="evenodd" d="M.52 15H16v3H.52z" clip-rule="evenodd"/></svg></a>
    {% endif %}
  </div>
</div>

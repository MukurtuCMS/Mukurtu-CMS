{#
/**
 * @file
 * Theme override for Digital Heritage nodes in the grid browse view mode.
 */
#}

{% set media_bundle = node.field_representative_media.0.entity.bundle.value.0['target_id'] %}

<article{{ attributes.addClass("vertical-card") }}>
  {% if media_bundle or content.field_representative_media %}
    <div class="vertical-card__media">
      {% include '@mukurtu_v4/content/_card-media.html.twig' with {
        media_bundle: media_bundle,
        media: content.field_representative_media,
        url: url,
      } %}
    </div>
  {% endif %}

  <div{{ content_attributes }} class="vertical-card__content">
    <div class="vertical-card__content-header">
      {{ title_prefix }}
      <h2{{ title_attributes }}>
        <a href="{{ url }}" rel="bookmark">{{ label.0 }}</a>
      </h2>
      {{ title_suffix }}
      {% if content_type_label %}
        <div class="vertical-card__content-type">{{ content_type_label }}</div>
      {% endif %}
    </div>

    <div class="vertical-card__content-body">
      {{ content.field_communities }}
      {{ content.field_category }}
    </div>
  </div>
</article>
